@{
    Layout = "_AdminTablerLayout";
    ViewData["Title"] = "Giám sát hiệu năng";
}

<!-- Page Header -->
<div class="page-header d-print-none mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title text-2xl font-bold">Giám sát hiệu năng (Health Check)</h2>
            <div class="text-muted small mt-1">Thông số hiệu năng thực tế của máy chủ ứng dụng và dịch vụ nền</div>
        </div>
    </div>
</div>

<div class="row row-cards mb-4">
    <!-- CPU Usage -->
    <div class="col-md-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body text-center py-4 d-flex flex-column justify-content-between">
                <div class="h4 text-muted mb-0">CPU (Kestrel)</div>
                <div class="display-5 text-primary" style="font-weight: 900;">@ViewBag.CpuUsage%</div>
                <div class="progress progress-sm mt-1 mx-4">
                    <div class="progress-bar bg-primary" style="width: @(ViewBag.CpuUsage)%"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- RAM Usage -->
    <div class="col-md-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body text-center py-4 d-flex flex-column justify-content-between">
                <div class="h4 text-muted mb-0">Bộ nhớ RAM</div>
                <div class="display-5 text-primary" style="font-weight: 900;">@ViewBag.RamUsage%</div>
                <div class="progress progress-sm mt-1 mx-4">
                    <div class="progress-bar bg-primary" style="width: @(ViewBag.RamUsage)%"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- Database Status -->
    <div class="col-md-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body text-center py-4 d-flex flex-column justify-content-between">
                <div class="h4 text-muted mb-0">CSDL (SQL Server)</div>
                <div class="display-5 text-green" style="font-weight: 900;">Ổn định</div>
                <div class="h5 text-muted mb-0 mt-1" style="font-weight: 500;">Máy chủ Somee SQL Server</div>
            </div>
        </div>
    </div>

    <!-- Queue Status -->
    <div class="col-md-6 col-lg-3">
        <div class="card h-100">
            <div class="card-body text-center py-4 d-flex flex-column justify-content-between">
                <div class="h4 text-muted mb-0">Hàng đợi nền (Jobs)</div>
                <div class="display-5 text-primary" style="font-weight: 900;">@ViewBag.QueueLength</div>
                <div class="h5 text-muted mb-0 mt-1" style="font-weight: 500;">Ca trực SLA Checker</div>
            </div>
        </div>
    </div>
</div>

<div class="row row-cards">
    <!-- Server specs card -->
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-transparent border-0 py-3">
                <h3 class="card-title font-weight-bold"><i class="bi bi-info-square text-primary me-2"></i>Thông số kỹ thuật máy chủ</h3>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="h5 text-muted mb-1">Môi trường Runtime</div>
                        <div class="text-lg font-weight-bold" style="color: #133B2F;">.NET 8.0 (ASP.NET Core)</div>
                    </div>
                    <div class="col-md-4">
                        <div class="h5 text-muted mb-1">Hệ quản trị CSDL</div>
                        <div class="text-lg font-weight-bold" style="color: #133B2F;">Microsoft SQL Server</div>
                    </div>
                    <div class="col-md-4">
                        <div class="h5 text-muted mb-1">Web Server Gateway</div>
                        <div class="text-lg font-weight-bold" style="color: #133B2F;">Kestrel + IIS Reverse Proxy</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
