@{
    Layout = "_AdminTablerLayout";
    ViewData["Title"] = "Cấu hình hệ thống";
    var successMsg = TempData["SuccessMessage"]?.ToString();
}

<!-- Page Header -->
<div class="page-header d-print-none mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title text-2xl font-bold">Cài đặt hệ thống</h2>
            <div class="text-muted small mt-1">Quản lý cấu hình toàn diện, tham số vận hành và chính sách an ninh hệ thống</div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(successMsg))
{
    <div class="alert alert-success alert-dismissible" role="alert">
        <div class="d-flex">
            <div><i class="bi bi-check-circle-fill me-2"></i></div>
            <div>@successMsg</div>
        </div>
        <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
    </div>
}

<div class="row row-cards">
    <!-- Configuration Form -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header py-2 bg-light">
                <h3 class="card-title font-weight-bold"><i class="bi bi-sliders text-primary me-2"></i>Cấu hình tham số hệ thống</h3>
            </div>
            <div class="card-body">
                <form action="/Admin/System/SaveSettings" method="post" class="space-y-4">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Tên tổ chức vận hành chính thức *</label>
                        <input type="text" name="orgName" class="form-control" value="@ViewBag.OrgName" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Thời gian Timezone hệ thống</label>
                        <select class="form-select" disabled>
                            <option>Hanoi, Bangkok, Jakarta (UTC+07:00)</option>
                        </select>
                    </div>

                    <div class="border-top pt-3 mb-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <label class="form-label font-weight-bold mb-1">Chế độ bảo trì (Maintenance Mode)</label>
                                <span class="text-muted small d-block">Tạm khóa gửi phản ánh mới để nâng cấp cơ sở dữ liệu.</span>
                            </div>
                            <div class="form-check form-switch fs-3">
                                <input class="form-check-input" type="checkbox" id="maintSwitch" @(ViewBag.MaintenanceMode == "True" ? "checked" : "")>
                                <input type="hidden" name="maintenanceMode" id="maintValue" value="@ViewBag.MaintenanceMode">
                            </div>
                        </div>
                    </div>

                    <div class="border-top pt-3">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-2"></i>Lưu cấu hình</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Backup SQL Panel -->
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header py-2 bg-light">
                <h3 class="card-title font-weight-bold"><i class="bi bi-database text-primary me-2"></i>Sao lưu & Phục hồi CSDL</h3>
            </div>
            <div class="card-body">
                <p class="text-muted small">
                    Khuyến nghị sao lưu dữ liệu trước khi tiến hành chỉnh sửa hoặc cập nhật quy mô lớn. Tệp tin sao lưu chứa đầy đủ schema và dữ liệu hiện tại.
                </p>
                <form action="/Admin/System/TriggerBackup" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-white w-100 mb-2"><i class="bi bi-download me-2"></i>Tải tệp sao lưu (.BAK)</button>
                </form>
                <button class="btn btn-light w-100" onclick="alert('Vui lòng liên hệ bộ phận kỹ thuật để tải lên tệp tin khôi phục SQL Server.')"><i class="bi bi-upload me-2"></i>Khôi phục dữ liệu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Update hidden maintenance mode value on switch toggle
            $('#maintSwitch').on('change', function () {
                $('#maintValue').val(this.checked ? "True" : "False");
            });
        });
    </script>
}
