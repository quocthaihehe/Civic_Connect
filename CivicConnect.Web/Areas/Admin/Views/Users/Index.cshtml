@model IEnumerable<CivicConnect.Web.Models.Entities.ApplicationUser>
@using CivicConnect.Web.Models.Enums
@{
    Layout = "_AdminTablerLayout";
    ViewData["Title"] = "Quản lý công dân";
    var successMsg = TempData["SuccessMessage"]?.ToString();
}

<!-- Page Header -->
<div class="page-header d-print-none mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title text-2xl font-bold">Danh sách Công dân</h2>
            <div class="text-muted small mt-1">Hồ sơ định danh, mức độ tin cậy và trạng thái hoạt động của công dân đô thị</div>
        </div>
        <div class="col-auto ms-auto d-print-none flex gap-2">
            <button class="btn btn-white" data-bs-toggle="modal" data-bs-target="#importExcelModal"><i class="bi bi-file-earmark-excel me-2"></i>Nhập từ Excel</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(successMsg))
{
    <div class="alert alert-success alert-dismissible" role="alert">
        <div class="d-flex">
            <div><i class="bi bi-check-circle-fill me-2"></i></div>
            <div>@successMsg</div>
        </div>
        <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
    </div>
}

<div class="row row-cards">
    <!-- Citizens Table -->
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-transparent border-0 py-3">
                <h3 class="card-title font-weight-bold"><i class="bi bi-people text-primary me-2"></i>Hồ sơ danh sách cư dân</h3>
            </div>
            <div class="table-responsive">
                <table class="table table-vcenter table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Họ tên</th>
                            <th>Email & Số điện thoại</th>
                            <th>Điểm công dân</th>
                            <th>Huy hiệu KYC</th>
                            <th>Tình trạng vi phạm</th>
                            <th class="w-1">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Chưa có hồ sơ công dân nào khớp điều kiện tìm kiếm</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var user in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <span class="avatar avatar-sm bg-blue-lt text-blue rounded-circle me-2">@user.FullName.Substring(0, 1)</span>
                                            <div>
                                                <div class="font-weight-bold text-body">@user.FullName</div>
                                                <div class="text-xs text-muted">Mã: @user.Id.Substring(0, 8)...</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div>@user.Email</div>
                                        <div class="text-xs text-muted">@user.PhoneNumber</div>
                                    </td>
                                    <td>
                                        <div class="font-weight-bold @(user.CitizenPoints >= 80 ? "text-green" : (user.CitizenPoints >= 50 ? "text-warning" : "text-danger"))">
                                            @user.CitizenPoints / 100 pt
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge @GetKycBadgeClass(user.KYCLevel)">
                                            @GetKycLevelName(user.KYCLevel)
                                        </span>
                                    </td>
                                    <td>
                                        @if (user.IsRestricted)
                                        {
                                            <span class="badge bg-red" title="Hạn chế gửi phản ánh do vi phạm: @user.RestrictionReason">Hạn chế gửi tin</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-green-lt">Bình thường</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-list flex-nowrap">
                                            @if (user.KYCLevel == KYCLevel.PendingReview)
                                            {
                                                <button class="btn btn-primary btn-sm text-white" data-bs-toggle="modal" data-bs-target="#kycModal-@user.Id">Duyệt KYC</button>
                                            }
                                            else if (user.KYCLevel != KYCLevel.Verified)
                                            {
                                                <!-- Verify KYC Action -->
                                                <form action="/Admin/Users/VerifyKYC/@user.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="level" value="@KYCLevel.Verified" />
                                                    <button type="submit" class="btn btn-white btn-sm text-green">Xác nhận tay</button>
                                                </form>
                                            }
                                            
                                            @if (user.IsRestricted)
                                            {
                                                <form action="/Admin/Users/Unrestrict/@user.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-white btn-sm text-blue">Gỡ phạt</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <!-- Restrict Modal Trigger -->
                                                <button class="btn btn-white btn-sm text-danger" data-bs-toggle="modal" data-bs-target="#restrictModal-@user.Id">Phạt</button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modals rendered outside of layout flow to prevent backdrop/nested rendering issues -->
@foreach (var user in Model)
{
    <!-- KYC AI Modal -->
    @if (user.KYCLevel == KYCLevel.PendingReview)
    {
        <div class="modal fade" id="kycModal-@user.Id" tabindex="-1" role="dialog" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title font-weight-bold">Duyệt hồ sơ KYC - @user.FullName</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body p-0">
                        <!-- Carousel -->
                        <div id="carousel-kyc-@user.Id" class="carousel slide" data-bs-ride="false" data-bs-interval="false">
                            <div class="carousel-inner">
                                <!-- Stage 1 -->
                                <div class="carousel-item active p-4">
                                    <h4 class="mb-3 text-primary"><i class="bi bi-1-circle-fill me-2"></i>Giai đoạn 1: Xác minh giấy tờ</h4>
                                    <div class="row g-3">
                                        <div class="col-6">
                                            <div class="border rounded text-center p-2">
                                                <img src="@user.IdCardFrontUrl" class="img-fluid rounded" style="max-height: 200px; object-fit: contain;" />
                                                <div class="mt-2 fw-bold text-muted small">Mặt trước</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="border rounded text-center p-2">
                                                <img src="@user.IdCardBackUrl" class="img-fluid rounded" style="max-height: 200px; object-fit: contain;" />
                                                <div class="mt-2 fw-bold text-muted small">Mặt sau</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mt-4 text-center">
                                        <button type="button" class="btn btn-info" onclick="scanIdCard('@user.Id')" id="btn-scan-@user.Id">
                                            <i class="bi bi-upc-scan me-2"></i> Quét nhận diện
                                        </button>
                                        <div id="scan-result-@user.Id" class="mt-3 text-start bg-light p-3 rounded d-none" style="white-space: pre-wrap; font-family: monospace; max-height: 200px; overflow-y: auto;"></div>
                                    </div>
                                </div>
                                
                                <!-- Stage 2 -->
                                <div class="carousel-item p-4">
                                    <h4 class="mb-3 text-primary"><i class="bi bi-2-circle-fill me-2"></i>Giai đoạn 2: Xác minh khuôn mặt</h4>
                                    <div class="row g-3">
                                        <div class="col-6">
                                            <div class="border rounded text-center p-2">
                                                <img src="@user.IdCardFrontUrl" class="img-fluid rounded" style="max-height: 200px; object-fit: contain;" />
                                                <div class="mt-2 fw-bold text-muted small">Ảnh CCCD</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="border rounded text-center p-2">
                                                <img src="@user.SelfieUrl" class="img-fluid rounded" style="max-height: 200px; object-fit: contain;" />
                                                <div class="mt-2 fw-bold text-muted small">Ảnh Selfie tải lên</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="mt-4 text-center">
                                        <button type="button" class="btn btn-warning" onclick="checkFaceMatch('@user.Id')" id="btn-face-@user.Id">
                                            <i class="bi bi-person-bounding-box me-2"></i> Đối chiếu khuôn mặt
                                        </button>
                                        <div id="face-result-@user.Id" class="mt-3 p-3 rounded d-none"></div>
                                    </div>
                                </div>
                            </div>
                            
                            <button class="carousel-control-prev" type="button" data-bs-target="#carousel-kyc-@user.Id" data-bs-slide="prev" style="width: 5%; background: rgba(0,0,0,0.1);">
                                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#carousel-kyc-@user.Id" data-bs-slide="next" style="width: 5%; background: rgba(0,0,0,0.1);">
                                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            </button>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <form action="/Admin/Users/VerifyKYC/@user.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="level" value="@KYCLevel.Rejected" />
                            <button type="submit" class="btn btn-danger btn-outline">Từ chối KYC</button>
                        </form>
                        
                        <form action="/Admin/Users/VerifyKYC/@user.Id" method="post" class="d-inline ms-auto">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="level" value="@KYCLevel.Verified" />
                            <button type="submit" class="btn btn-success" id="btn-approve-@user.Id">Duyệt thành công</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Restrict Modal -->
    <div class="modal fade" id="restrictModal-@user.Id" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content">
                <form action="/Admin/Users/Restrict/@user.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-header">
                        <h5 class="modal-title font-weight-bold">Hạn chế quyền gửi phản ánh</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Thời gian hạn chế (Ngày)</label>
                            <input type="number" name="days" class="form-control" value="7" min="1" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Lý do áp dụng hình phạt</label>
                            <textarea name="reason" rows="3" class="form-control" placeholder="VD: Gửi tin rác, phản ánh sai sự thật nhiều lần..." required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-link link-secondary me-auto" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger">Áp dụng hình phạt</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- Import Excel Modal -->
<div class="modal modal-blur fade" id="importExcelModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <form action="/Admin/Users/ImportExcel" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title font-weight-bold">Nhập cư dân từ tệp Excel</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label font-weight-bold">Chọn tệp dữ liệu (.xlsx, .xls)</label>
                        <input type="file" name="file" class="form-control" accept=".xlsx, .xls" required>
                        <span class="text-muted small mt-1 d-block">Tải về <a href="#" class="text-primary text-decoration-none">Tệp biểu mẫu Excel chuẩn</a></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-link link-secondary me-auto" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Bắt đầu nhập dữ liệu</button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    public string GetKycLevelName(KYCLevel level) => level switch
    {
        KYCLevel.Unverified => "Chưa xác minh",
        KYCLevel.EmailVerified => "Xác minh Email",
        KYCLevel.PhoneVerified => "Xác minh SĐT",
        KYCLevel.PendingReview => "Chờ duyệt KYC",
        KYCLevel.Verified => "Đã xác thực danh tính",
        KYCLevel.Rejected => "Từ chối KYC",
        _ => "Chưa xác minh"
    };

    public string GetKycBadgeClass(KYCLevel level) => level switch
    {
        KYCLevel.Unverified => "bg-secondary-lt",
        KYCLevel.EmailVerified => "bg-blue-lt",
        KYCLevel.PhoneVerified => "bg-cyan-lt",
        KYCLevel.PendingReview => "bg-warning-lt",
        KYCLevel.Verified => "bg-green",
        KYCLevel.Rejected => "bg-danger-lt",
        _ => "bg-secondary-lt"
    };
}

@section Scripts {
    <script>
        function getAntiforgeryToken() {
            return $('input[name="__RequestVerificationToken"]').val();
        }

        async function scanIdCard(userId) {
            const btn = $(`#btn-scan-${userId}`);
            const resultDiv = $(`#scan-result-${userId}`);
            
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span> Đang quét...');
            resultDiv.addClass('d-none').removeClass('bg-danger text-white bg-light');

            try {
                const formData = new FormData();
                formData.append('userId', userId);
                
                const response = await fetch('/Admin/Users/FptAiScanId', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': getAntiforgeryToken() },
                    body: formData
                });

                if (!response.ok) throw new Error('API request failed');
                
                const data = await response.json();
                
                if (data.errorCode === 0) {
                    let info = '';
                    const d = data.data[0];
                    if (d) {
                        info += `Họ tên: ${d.name}\n`;
                        info += `Số thẻ: ${d.id}\n`;
                        info += `Ngày sinh: ${d.dob}\n`;
                        info += `Quê quán: ${d.home}\n`;
                        info += `Thường trú: ${d.address}\n`;
                    }
                    resultDiv.text(info).addClass('bg-light').removeClass('d-none');
                } else {
                    resultDiv.text(`Lỗi nhận diện: ${data.errorMessage}`).addClass('bg-danger text-white').removeClass('d-none');
                }
            } catch (error) {
                resultDiv.text(`Lỗi hệ thống: ${error.message}`).addClass('bg-danger text-white').removeClass('d-none');
            } finally {
                btn.prop('disabled', false).html('<i class="bi bi-upc-scan me-2"></i> Quét nhận diện');
            }
        }

        async function checkFaceMatch(userId) {
            const btn = $(`#btn-face-${userId}`);
            const resultDiv = $(`#face-result-${userId}`);
            
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span> Đang đối chiếu...');
            resultDiv.addClass('d-none').removeClass('bg-success text-white bg-danger');

            try {
                const formData = new FormData();
                formData.append('userId', userId);
                
                const response = await fetch('/Admin/Users/FptAiFaceMatch', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': getAntiforgeryToken() },
                    body: formData
                });

                if (!response.ok) throw new Error('API request failed');
                
                const data = await response.json();
                
                if (data.code === '200' && data.data) {
                    const isMatch = data.data.isMatch;
                    const similarity = (data.data.similarity).toFixed(2);
                    
                    if (isMatch && similarity > 85) {
                        resultDiv.html(`<i class="bi bi-check-circle-fill fs-4 me-2"></i> Trùng khớp: ${similarity}%`).addClass('bg-success text-white fs-5').removeClass('d-none');
                    } else {
                        resultDiv.html(`<i class="bi bi-x-circle-fill fs-4 me-2"></i> Không khớp: ${similarity}%`).addClass('bg-danger text-white fs-5').removeClass('d-none');
                    }
                } else {
                    resultDiv.text(`Lỗi đối chiếu: ${data.message}`).addClass('bg-danger text-white').removeClass('d-none');
                }
            } catch (error) {
                resultDiv.text(`Lỗi hệ thống: ${error.message}`).addClass('bg-danger text-white').removeClass('d-none');
            } finally {
                btn.prop('disabled', false).html('<i class="bi bi-person-bounding-box me-2"></i> Đối chiếu khuôn mặt');
            }
        }
    </script>
}
