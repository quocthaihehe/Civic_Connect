@using CivicConnect.Web.Models.Enums
@{
    Layout = "_AdminTablerLayout";
    ViewData["Title"] = "Báo cáo thống kê";
}

<!-- Page Header -->
<div class="page-header d-print-none mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title text-2xl font-bold">Báo cáo & Thống kê dữ liệu</h2>
            <div class="text-muted small mt-1">Xuất báo cáo định kỳ và thiết kế mẫu biểu thống kê tuỳ biến</div>
        </div>
    </div>
</div>

<div class="row row-cards mb-4">
    <!-- Standard Reports List -->
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header bg-transparent border-0 py-3">
                <h3 class="card-title font-weight-bold"><i class="bi bi-file-earmark-bar-graph text-primary me-2"></i>Các biểu mẫu báo cáo tiêu chuẩn</h3>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="card card-sm border border-light">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="font-weight-bold">Báo cáo SLA & Đúng hạn</div>
                                    <div class="text-muted small">Tỷ lệ xử lý đúng SLA của cơ quan</div>
                                </div>
                                <a href="/Admin/Issues/ExportExcel?status=Resolved" class="btn btn-white btn-sm"><i class="bi bi-download"></i> Tải</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card card-sm border border-light">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="font-weight-bold">Báo cáo CSAT Hài lòng</div>
                                    <div class="text-muted small">Khảo sát ý kiến chấm điểm công dân</div>
                                </div>
                                <a href="/Admin/Issues/ExportExcel" class="btn btn-white btn-sm"><i class="bi bi-download"></i> Tải</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card card-sm border border-light">
                            <div class="card-body d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="font-weight-bold">Báo cáo Tài chính Quyên góp</div>
                                    <div class="text-muted small">Dòng tiền thu chi các quỹ xã hội</div>
                                </div>
                                <a href="/Admin/Issues/ExportExcel" class="btn btn-white btn-sm"><i class="bi bi-download"></i> Tải</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom Report Builder -->
<div class="row row-cards">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-transparent border-0 py-3">
                <h3 class="card-title font-weight-bold"><i class="bi bi-gear-wide-connected text-primary me-2"></i>Bộ kiến thiết báo cáo tùy chỉnh (Custom Builder)</h3>
            </div>
            <div class="card-body">
                <form id="customReportForm" class="row g-3">
                    <!-- Choose Columns -->
                    <div class="col-12">
                        <label class="form-label font-weight-bold mb-2">1. Chọn cột dữ liệu hiển thị</label>
                        <div class="d-flex flex-wrap gap-3">
                            <label class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" name="columns" value="Id" checked>
                                <span class="form-check-label">Mã ID</span>
                            </label>
                            <label class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" name="columns" value="Title" checked>
                                <span class="form-check-label">Tiêu đề phản ánh</span>
                            </label>
                            <label class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" name="columns" value="Status" checked>
                                <span class="form-check-label">Trạng thái</span>
                            </label>
                            <label class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" name="columns" value="Priority" checked>
                                <span class="form-check-label">Độ khẩn</span>
                            </label>
                            <label class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" name="columns" value="Address" checked>
                                <span class="form-check-label">Địa chỉ xảy ra</span>
                            </label>
                            <label class="form-check form-check-inline">
                                <input class="form-check-input" type="checkbox" name="columns" value="CreatedAt" checked>
                                <span class="form-check-label">Ngày gửi</span>
                            </label>
                        </div>
                    </div>

                    <!-- Filters -->
                    <div class="col-md-3">
                        <label class="form-label font-weight-bold">Bộ lọc: Trạng thái</label>
                        <select name="status" class="form-select">
                            <option value="">Tất cả</option>
                            @foreach (IssueStatus stat in Enum.GetValues(typeof(IssueStatus)))
                            {
                                <option value="@stat">@stat</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label font-weight-bold">Bộ lọc: Độ ưu tiên</label>
                        <select name="priority" class="form-select">
                            <option value="">Tất cả</option>
                            @foreach (IssuePriority pri in Enum.GetValues(typeof(IssuePriority)))
                            {
                                <option value="@pri">@pri</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label font-weight-bold">Từ ngày</label>
                        <input type="date" name="fromDate" class="form-control">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label font-weight-bold">Đến ngày</label>
                        <input type="date" name="toDate" class="form-control">
                    </div>

                    <div class="col-12 pt-2">
                        <button type="button" id="btnRunQuery" class="btn btn-primary"><i class="bi bi-play-fill me-2"></i>Trích xuất dữ liệu</button>
                    </div>
                </form>

                <!-- Dynamic results area -->
                <div class="mt-4 border-top pt-3 d-none" id="resultsArea">
                    <h4 class="font-weight-bold mb-3"><i class="bi bi-table text-success me-2"></i>Bảng kết quả trích xuất</h4>
                    <div class="table-responsive">
                        <table class="table table-vcenter mb-0" id="resultsTable">
                            <thead>
                                <tr id="resultsHeader"></tr>
                            </thead>
                            <tbody id="resultsBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#btnRunQuery').on('click', function () {
                const formData = $('#customReportForm').serialize();
                
                $.post('/Admin/Reports/CustomQuery', formData, function (res) {
                    $('#resultsHeader').empty();
                    $('#resultsBody').empty();

                    if (!res.rows || res.rows.length === 0) {
                        $('#resultsHeader').append('<th>Thông tin</th>');
                        $('#resultsBody').append('<tr><td class="text-center py-4 text-muted">Không tìm thấy dữ liệu khớp bộ lọc</td></tr>');
                    } else {
                        // Append headers
                        res.headers.forEach(h => {
                            $('#resultsHeader').append(`<th>${h}</th>`);
                        });

                        // Append rows
                        res.rows.forEach(row => {
                            let tr = '<tr>';
                            res.headers.forEach(h => {
                                tr += `<td>${row[h] || ''}</td>`;
                            });
                            tr += '</tr>';
                            $('#resultsBody').append(tr);
                        });
                    }

                    $('#resultsArea').removeClass('d-none');
                });
            });
        });
    </script>
}
