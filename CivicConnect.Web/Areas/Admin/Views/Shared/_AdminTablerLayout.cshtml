@{
    var currentPath = Context.Request.Path.Value ?? "";
    bool isDashboardActive = currentPath.Equals("/Admin", StringComparison.OrdinalIgnoreCase) || currentPath.StartsWith("/Admin/Dashboard", StringComparison.OrdinalIgnoreCase);
    bool isDashboardOverview = currentPath.Equals("/Admin/Dashboard", StringComparison.OrdinalIgnoreCase) || currentPath.Equals("/Admin/Dashboard/Index", StringComparison.OrdinalIgnoreCase) || currentPath.Equals("/Admin", StringComparison.OrdinalIgnoreCase);
    bool isDashboardAnalytics = currentPath.Equals("/Admin/Dashboard/Analytics", StringComparison.OrdinalIgnoreCase);
    bool isDashboardFinance = currentPath.Equals("/Admin/Dashboard/Finance", StringComparison.OrdinalIgnoreCase);

    bool isIssuesActive = currentPath.StartsWith("/Admin/Issues", StringComparison.OrdinalIgnoreCase);
    bool isOrgActive = currentPath.StartsWith("/Admin/Units", StringComparison.OrdinalIgnoreCase) || currentPath.StartsWith("/Admin/Officials", StringComparison.OrdinalIgnoreCase);
    bool isUsersActive = currentPath.StartsWith("/Admin/Users", StringComparison.OrdinalIgnoreCase);
    bool isContentActive = currentPath.StartsWith("/Admin/Policies", StringComparison.OrdinalIgnoreCase) || currentPath.StartsWith("/Admin/Content", StringComparison.OrdinalIgnoreCase);
    bool isReportsActive = currentPath.StartsWith("/Admin/Reports", StringComparison.OrdinalIgnoreCase);
    bool isSystemActive = currentPath.StartsWith("/Admin/System", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản trị CivicConnect</title>
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <!-- Tabler CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@@1.0.0-beta20/dist/css/tabler.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Leaflet.js -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <!-- Google Fonts: EB Garamond & Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <!-- Admin Custom Theme (Base Design System) -->
    <link rel="stylesheet" href="~/css/admin-theme.css" asp-append-version="true" />
    
    <style>
        .theme-dark {
            --tb-body-bg: #1a2234;
        }
        .page {
            min-height: 100vh;
        }
        @@media (min-width: 992px) {
            .navbar-vertical.navbar-expand-lg {
                width: 260px !important;
            }
            .navbar-vertical.navbar-expand-lg ~ .page-wrapper,
            .navbar-vertical.navbar-expand-lg ~ .navbar {
                margin-left: 260px !important;
            }
        }
        .navbar-vertical .navbar-brand-autodark {
            font-size: 1.4rem;
            font-weight: 800;
        }
        /* Search Icon positioning fix */
        .input-icon {
            position: relative;
        }
        .input-icon .input-icon-addon {
            position: absolute;
            top: 50%;
            left: 0.75rem;
            transform: translateY(-50%);
            display: flex;
            align-items: center;
            justify-content: center;
            pointer-events: none;
            color: #627d98;
            z-index: 4;
        }
        .input-icon .form-control {
            padding-left: 2.5rem;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="layout-fluid">
    <script>
        // Restoring dark mode preference
        const theme = localStorage.getItem('tablerTheme') || 'light';
        if (theme === 'dark') {
            document.body.classList.add('theme-dark');
            document.body.setAttribute('data-bs-theme', 'dark');
        } else {
            document.body.classList.remove('theme-dark');
            document.body.removeAttribute('data-bs-theme');
        }
    </script>
    
    <div class="page">
        <!-- Sidebar -->
        <aside class="navbar navbar-vertical navbar-expand-lg navbar-dark d-print-none" style="background-color: #133B2F;">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <h1 class="navbar-brand navbar-brand-autodark">
                    <a href="/Admin/Dashboard" class="text-decoration-none d-flex align-items-center">
                        <img src="/images/favicon.png" alt="CivicConnect Logo" class="me-2" style="height: 32px; width: 32px; object-fit: contain;" />
                        <span style="color: #133B2F; font-family: 'EB Garamond', serif; font-weight: 700; font-size: 26px; letter-spacing: -0.5px; line-height: 1;">CivicConnect</span>
                    </a>
                </h1>
                
                <div class="navbar-nav flex-row d-lg-none">
                    <!-- Notifications button for small screen -->
                    <div class="nav-item dropdown d-none d-md-flex me-3">
                        <a href="#" class="nav-link px-0" data-bs-toggle="dropdown" tabindex="-1">
                            <i class="bi bi-bell fs-2 text-white"></i>
                        </a>
                    </div>
                </div>

                <div class="collapse navbar-collapse" id="sidebar-menu">
                    <ul class="navbar-nav pt-lg-3">
                        
                        <!-- Dashboard -->
                        <li class="nav-item dropdown @(isDashboardActive ? "show" : "")">
                            <a class="nav-link dropdown-toggle @(isDashboardActive ? "active" : "")" href="#menu-dashboards" data-bs-toggle="dropdown" data-bs-auto-close="false" role="button" aria-expanded="false">
                                <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="bi bi-speedometer2"></i></span>
                                <span class="nav-link-title">Bảng điều hành</span>
                            </a>
                            <div class="dropdown-menu @(isDashboardActive ? "show" : "")">
                                <a class="dropdown-item @(isDashboardOverview ? "active" : "")" href="/Admin/Dashboard">Tổng quan điều hành</a>
                                <a class="dropdown-item @(isDashboardAnalytics ? "active" : "")" href="/Admin/Dashboard/Analytics">Phân tích chuyên sâu</a>
                                <a class="dropdown-item @(isDashboardFinance ? "active" : "")" href="/Admin/Dashboard/Finance">Quỹ & Tài chính</a>
                            </div>
                        </li>

                        <!-- Issues -->
                        <li class="nav-item dropdown @(isIssuesActive ? "show" : "")">
                            <a class="nav-link dropdown-toggle @(isIssuesActive ? "active" : "")" href="#menu-issues" data-bs-toggle="dropdown" data-bs-auto-close="false" role="button" aria-expanded="false">
                                <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="bi bi-exclamation-octagon"></i></span>
                                <span class="nav-link-title">Quản lý phản ánh</span>
                            </a>
                            <div class="dropdown-menu @(isIssuesActive ? "show" : "")">
                                <a class="dropdown-item" href="/Admin/Issues">Bảng dữ liệu phản ánh</a>
                                <a class="dropdown-item" href="/Admin/Issues/Kanban">Bảng Kanban</a>
                                <a class="dropdown-item" href="/Admin/Issues/RoutingRules">Quy tắc phân luồng</a>
                            </div>
                        </li>

                        <!-- Organization -->
                        <li class="nav-item dropdown @(isOrgActive ? "show" : "")">
                            <a class="nav-link dropdown-toggle @(isOrgActive ? "active" : "")" href="#menu-org" data-bs-toggle="dropdown" data-bs-auto-close="false" role="button" aria-expanded="false">
                                <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="bi bi-diagram-3"></i></span>
                                <span class="nav-link-title">Tổ chức & Cán bộ</span>
                            </a>
                            <div class="dropdown-menu @(isOrgActive ? "show" : "")">
                                <a class="dropdown-item" href="/Admin/Units">Cơ quan liên kết</a>
                                <a class="dropdown-item" href="/Admin/Officials">Danh sách cán bộ</a>
                                <a class="dropdown-item" href="/Admin/Officials/Shifts">Lịch trực & Phân ca</a>
                            </div>
                        </li>

                        <!-- Users -->
                        <li class="nav-item">
                            <a class="nav-link @(isUsersActive ? "active" : "")" href="/Admin/Users">
                                <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="bi bi-people"></i></span>
                                <span class="nav-link-title">Quản lý người dùng</span>
                            </a>
                        </li>

                        <!-- Content -->
                        <li class="nav-item dropdown @(isContentActive ? "show" : "")">
                            <a class="nav-link dropdown-toggle @(isContentActive ? "active" : "")" href="#menu-content" data-bs-toggle="dropdown" data-bs-auto-close="false" role="button" aria-expanded="false">
                                <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="bi bi-journal-text"></i></span>
                                <span class="nav-link-title">Quản lý nội dung</span>
                            </a>
                            <div class="dropdown-menu @(isContentActive ? "show" : "")">
                                <a class="dropdown-item" href="/Admin/Policies">Tin tức & Chính sách</a>
                                <a class="dropdown-item" href="/Admin/Content/Notifications">Gửi thông báo hàng loạt</a>
                                <a class="dropdown-item" href="/Admin/Content/Categories">Danh mục & SLA</a>
                            </div>
                        </li>

                        <!-- Reports -->
                        <li class="nav-item">
                            <a class="nav-link @(isReportsActive ? "active" : "")" href="/Admin/Reports">
                                <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="bi bi-bar-chart-line"></i></span>
                                <span class="nav-link-title">Báo cáo thống kê</span>
                            </a>
                        </li>

                        <!-- System Settings -->
                        <li class="nav-item dropdown @(isSystemActive ? "show" : "")">
                            <a class="nav-link dropdown-toggle @(isSystemActive ? "active" : "")" href="#menu-system" data-bs-toggle="dropdown" data-bs-auto-close="false" role="button" aria-expanded="false">
                                <span class="nav-link-icon d-md-none d-lg-inline-block"><i class="bi bi-gear"></i></span>
                                <span class="nav-link-title">Cấu hình hệ thống</span>
                            </a>
                            <div class="dropdown-menu @(isSystemActive ? "show" : "")">
                                <a class="dropdown-item" href="/Admin/System/Settings">Cài đặt chung</a>
                                <a class="dropdown-item" href="/Admin/System/Logs">Nhật ký hoạt động</a>
                                <a class="dropdown-item" href="/Admin/System/Health">Giám sát hiệu năng</a>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </aside>

        <!-- Top Header -->
        <header class="navbar navbar-expand-md navbar-light d-none d-lg-flex d-print-none sticky-top" style="background-color: #F8FAFC; min-height: 64px; border-bottom: 1px solid var(--tblr-border-color);">
            <div class="container-fluid">
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbar-menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbar-menu">
                    <div class="d-flex w-100 align-items-center">
                        <form action="./" method="get" autocomplete="off" novalidate class="me-auto my-2 my-md-0" style="max-width: 350px;">
                            <div class="input-icon">
                                <span class="input-icon-addon">
                                    <i class="bi bi-search text-muted"></i>
                                </span>
                                <input type="text" class="form-control" placeholder="Tìm kiếm nhanh..." aria-label="Search" style="border-radius: 8px; border: 1px solid #e2e8f0; background-color: #ffffff;">
                            </div>
                        </form>
                    </div>
                </div>
                <div class="navbar-nav flex-row order-md-last ms-auto">
                    <!-- Toggle Dark Mode -->
                    <div class="nav-item d-none d-md-flex me-3">
                        <a href="javascript:void(0)" class="nav-link px-0" onclick="toggleDarkMode()" title="Đổi chế độ sáng tối">
                            <i class="bi bi-moon fs-3 text-secondary" id="dark-mode-icon"></i>
                        </a>
                    </div>
                    
                    <!-- Notifications -->
                    <div class="nav-item dropdown d-none d-md-flex me-3" id="notif-dropdown-wrapper">
                        <a href="#" class="nav-link px-0" data-bs-toggle="dropdown" tabindex="-1" aria-label="Show notifications" aria-expanded="false" id="notif-trigger">
                            <i class="bi bi-bell fs-3 text-secondary"></i>
                            <span class="badge bg-red badge-notification" id="notif-counter" style="display: none;">0</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-arrow dropdown-menu-end dropdown-menu-card" style="width: 380px;">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center py-2 bg-light">
                                    <h3 class="card-title text-xs font-weight-bold">Thông báo mới nhận</h3>
                                    <button class="btn btn-link btn-sm p-0 text-decoration-none text-primary" id="mark-all-read" style="font-size: 11px;">Đọc tất cả</button>
                                </div>
                                <div class="list-group list-group-flush list-group-hoverable overflow-y-auto" style="max-height: 300px;" id="notif-container">
                                    <div class="list-group-item text-center py-4 text-muted" id="notif-empty-state">
                                        <i class="bi bi-bell-slash fs-2 mb-2 d-block"></i>
                                        Không có thông báo mới
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- User menu -->
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link d-flex lh-1 text-reset p-0" data-bs-toggle="dropdown" aria-label="Open user menu">
                            <span class="avatar avatar-sm bg-blue text-white rounded-circle">A</span>
                            <div class="d-none d-xl-block ps-2">
                                <div>Quản trị viên</div>
                                <div class="mt-1 small text-muted">QUẢN TRỊ VIÊN CẤP CAO</div>
                            </div>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                            <a href="/Identity/Account/Profile" class="dropdown-item">Hồ sơ cá nhân</a>
                            <div class="dropdown-divider"></div>
                            <form action="/Identity/Account/Logout" method="post" id="logoutForm">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="dropdown-item text-danger">Đăng xuất</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Workspace -->
        <div class="page-wrapper">
            <style>
                .page-header {
                    margin-top: 0.5rem !important;
                    margin-bottom: 0.5rem !important;
                }
                .page-body {
                    margin-top: 0.5rem !important;
                    padding-top: 0 !important;
                }
            </style>
            <div class="page-body">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <!-- Tabler Core JS & Bootstrap Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/@@tabler/core@@1.0.0-beta20/dist/js/tabler.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script>
        // Xử lý lỗi Tabler tự auto-active nhầm menu con trùng tiền tố
        document.addEventListener("DOMContentLoaded", function () {
            setTimeout(function() {
                var dropdownMenus = document.querySelectorAll('.dropdown-menu');
                dropdownMenus.forEach(function(menu) {
                    var activeItems = Array.from(menu.querySelectorAll('.dropdown-item.active'));
                    if (activeItems.length > 1) {
                        // Sắp xếp các thẻ active theo độ dài URL giảm dần
                        activeItems.sort(function(a, b) {
                            return b.getAttribute('href').length - a.getAttribute('href').length;
                        });
                        
                        // Thẻ có URL dài nhất là thẻ khớp chính xác nhất, giữ lại thẻ đầu tiên
                        var bestMatch = activeItems[0];
                        activeItems.forEach(function(item) {
                            if (item !== bestMatch) {
                                item.classList.remove('active');
                            }
                        });
                    }
                });
            }, 150);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        // Dark Mode toggle function
        function toggleDarkMode() {
            const isDark = document.body.classList.toggle('theme-dark');
            if (isDark) {
                document.body.setAttribute('data-bs-theme', 'dark');
            } else {
                document.body.removeAttribute('data-bs-theme');
            }
            localStorage.setItem('tablerTheme', isDark ? 'dark' : 'light');
            updateDarkModeIcon(isDark);
        }

        function updateDarkModeIcon(isDark) {
            const icon = document.getElementById('dark-mode-icon');
            if (icon) {
                if (isDark) {
                    icon.className = 'bi bi-sun fs-3';
                } else {
                    icon.className = 'bi bi-moon fs-3';
                }
            }
        }

        $(document).ready(function () {
            // Set initial state of dark mode icon
            updateDarkModeIcon(document.body.classList.contains('theme-dark'));

            // Automatically set active class for vertical menu dropdown-item matching current URL path
            const currentPath = window.location.pathname;
            $(".navbar-vertical .dropdown-item, .navbar-vertical .nav-link").each(function () {
                const href = $(this).attr("href");
                if (href) {
                    // Normalize paths for comparison
                    const normalizedHref = href.toLowerCase().replace(/\/$/, "");
                    const normalizedPath = currentPath.toLowerCase().replace(/\/$/, "");
                    
                    if (normalizedPath === normalizedHref || (normalizedHref !== "" && normalizedHref !== "/admin" && normalizedPath.startsWith(normalizedHref))) {
                        $(this).addClass("active");
                        // If it is inside a dropdown, make sure the dropdown is shown
                        const $dropdown = $(this).closest(".dropdown-menu");
                        if ($dropdown.length) {
                            $dropdown.addClass("show");
                            $dropdown.prev(".dropdown-toggle").addClass("active");
                            $dropdown.closest(".nav-item").addClass("show");
                        }
                    }
                }
            });

            // SignalR notifications logic
            const $badge = $('#notif-counter');
            const $container = $('#notif-container');
            const $trigger = $('#notif-trigger');

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/notification")
                .withAutomaticReconnect()
                .build();

            connection.on("LoadNotifications", function (notifications) {
                renderNotifications(notifications);
            });

            connection.on("IssueStatusChanged", function (n) {
                addNewNotification(n);
            });

            connection.on("IssueAssigned", function (n) {
                addNewNotification(n);
            });

            connection.start()
                .then(() => console.log("SignalR connected to NotificationHub (Tabler Layout)"))
                .catch(err => console.error(err.toString()));

            // Mark all read
            $('#mark-all-read').on('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                $.post('/api/notifications/mark-all-read', function () {
                    $badge.hide().text('0');
                    $container.html(`
                        <div class="list-group-item text-center py-4 text-muted" id="notif-empty-state">
                            <i class="bi bi-bell-slash fs-2 mb-2 d-block"></i>
                            Không có thông báo mới
                        </div>
                    `);
                });
            });

            function renderNotifications(notifications) {
                if (!notifications || notifications.length === 0) {
                    $badge.hide().text('0');
                    return;
                }

                $badge.show().text(notifications.length);
                $container.empty();

                notifications.forEach(n => {
                    $container.append(createNotifHtml(n));
                });
            }

            function addNewNotification(n) {
                let count = parseInt($badge.text()) || 0;
                count++;
                $badge.show().text(count);

                const notifData = {
                    id: n.id || 0,
                    title: n.title,
                    message: n.message,
                    relatedIssueId: n.issueId || n.relatedIssueId
                };

                $('#notif-empty-state').remove();
                $container.prepend(createNotifHtml(notifData));
            }

            function createNotifHtml(n) {
                const link = n.relatedIssueId ? `/Admin/Issues/Details/${n.relatedIssueId}` : '#';
                return `
                    <a href="${link}" class="list-group-item list-group-item-action notif-item" data-id="${n.id}">
                        <div class="row align-items-center">
                            <div class="col-auto">
                                <span class="avatar bg-blue-lt"><i class="bi bi-info-circle text-primary"></i></span>
                            </div>
                            <div class="col text-truncate">
                                <div class="text-body d-block font-weight-bold text-truncate">${n.title}</div>
                                <div class="text-muted text-xs text-truncate mt-1">${n.message}</div>
                            </div>
                        </div>
                    </a>
                `;
            }

            // Click single notification
            $container.on('click', '.notif-item', function (e) {
                e.preventDefault();
                const id = $(this).data('id');
                const href = $(this).attr('href');
                
                if (id && id > 0) {
                    $.post(`/api/notifications/${id}/mark-read`).always(function() {
                        if (href && href !== '#') {
                            window.location.href = href;
                        }
                    });
                } else {
                    if (href && href !== '#') {
                        window.location.href = href;
                    }
                }
            });
        });
    </script>
</body>
</html>
