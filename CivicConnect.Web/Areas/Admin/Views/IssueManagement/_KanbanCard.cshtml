@model CivicConnect.Web.Models.Entities.Issue
@using CivicConnect.Web.Models.Enums

@{
    var borderClass = Model.Priority switch
    {
        IssuePriority.Low => "border-start border-3 border-secondary",
        IssuePriority.Medium => "border-start border-3 border-blue",
        IssuePriority.High => "border-start border-3 border-warning",
        IssuePriority.Critical => "border-start border-3 border-danger",
        _ => ""
    };

    var imageUrl = Model.Images.FirstOrDefault()?.Url;

    // Countdown formatting
    string countdownText = "Không có hạn";
    string textClass = "text-muted";
    if (Model.DueDate.HasValue)
    {
        var diff = Model.DueDate.Value - DateTime.UtcNow;
        if (diff.TotalSeconds < 0)
        {
            var absDays = Math.Abs((int)diff.TotalDays);
            countdownText = absDays == 0 ? "Quá hạn vài giờ" : $"Quá hạn {absDays} ngày";
            textClass = "text-danger font-weight-bold";
        }
        else
        {
            var days = (int)diff.TotalDays;
            if (days > 0)
            {
                countdownText = $"Còn {days} ngày";
                textClass = days <= 1 ? "text-warning font-weight-bold" : "text-muted";
            }
            else
            {
                var hours = (int)diff.TotalHours;
                countdownText = $"Còn {hours} giờ";
                textClass = "text-warning font-weight-bold";
            }
        }
    }
}

<div class="card mb-2 @borderClass kanban-card cursor-grab" draggable="true" data-id="@Model.Id" style="background: var(--tb-card-bg, #ffffff);">
    <div class="card-body p-2.5">
        <div class="d-flex justify-content-between align-items-start mb-1.5">
            <span class="text-xs text-muted font-weight-bold">#@Model.Id</span>
            <span class="badge bg-blue-lt text-xxs py-0.5 px-1.5">@GetCategoryLabel(Model.Category)</span>
        </div>
        
        <h4 class="card-title mb-1.5 text-sm font-weight-bold" style="line-height: 1.3;">
            <a href="/Admin/Issues/Details/@Model.Id" class="text-body text-decoration-none">@Model.Title</a>
        </h4>

        @if (!string.IsNullOrEmpty(imageUrl))
        {
            <div class="mb-2 rounded overflow-hidden" style="height: 100px; width: 100%;">
                <img src="@imageUrl" class="w-100 h-100 object-cover" alt="Hình ảnh hiện trường">
            </div>
        }

        <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top border-light">
            <div class="d-flex align-items-center">
                <i class="bi bi-clock me-1 text-xs"></i>
                <span class="text-xxs @textClass">@countdownText</span>
            </div>
            
            @if (Model.AssignedTo != null)
            {
                <span class="avatar avatar-xs rounded-circle bg-blue text-white" title="@Model.AssignedTo.FullName">
                    @Model.AssignedTo.FullName.Substring(0, 1)
                </span>
            }
            else
            {
                <span class="avatar avatar-xs rounded-circle bg-gray text-white" title="Chưa gán cán bộ">
                    ?
                </span>
            }
        </div>
    </div>
</div>

@functions {
    public string GetCategoryLabel(IssueCategory category) => category switch
    {
        IssueCategory.Traffic => "Giao thông",
        IssueCategory.Environment => "Môi trường",
        IssueCategory.Security => "An ninh",
        IssueCategory.Infrastructure => "Hạ tầng",
        IssueCategory.Administration => "Hành chính",
        _ => "Khác"
    };
}
