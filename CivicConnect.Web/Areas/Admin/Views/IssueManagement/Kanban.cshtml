@model IEnumerable<CivicConnect.Web.Models.Entities.Issue>
@using CivicConnect.Web.Models.Enums
@{
    Layout = "_AdminTablerLayout";
    ViewData["Title"] = "Bảng Kanban phản ánh";
}

<!-- Page Header -->
<div class="page-header d-print-none mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title text-2xl font-bold">Bảng Kanban điều hành</h2>
            <div class="text-muted small mt-1">Kéo thả các phản ánh để cập nhật trạng thái xử lý nhanh chóng</div>
        </div>
        <div class="col-auto ms-auto d-print-none">
            <a href="/Admin/Issues" class="btn btn-white"><i class="bi bi-list-task me-2"></i>Xem dạng danh sách</a>
        </div>
    </div>
</div>

<div class="row g-3 flex-nowrap" style="overflow-x: auto; min-height: calc(100vh - 220px); align-items: start; padding-bottom: 20px;">
    
    <!-- Column 1: Mới nhận (Pending) -->
    <div class="col" style="min-width: 240px; flex: 1 1 0;">
        <div class="card kanban-column-card">
            <div class="card-header py-2 bg-blue-lt d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold text-xs">MỚI NHẬN (@Model.Count(i => i.Status == IssueStatus.Pending))</h3>
            </div>
            <div class="card-body p-2 kanban-column" data-status="@IssueStatus.Pending" style="min-height: 450px;">
                @foreach (var issue in Model.Where(i => i.Status == IssueStatus.Pending))
                {
                    @await Html.PartialAsync("_KanbanCard", issue)
                }
            </div>
        </div>
    </div>

    <!-- Column 2: Đã phân công (Assigned) -->
    <div class="col" style="min-width: 240px; flex: 1 1 0;">
        <div class="card kanban-column-card">
            <div class="card-header py-2 bg-cyan-lt d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold text-xs">ĐÃ PHÂN CÔNG (@Model.Count(i => i.Status == IssueStatus.Assigned))</h3>
            </div>
            <div class="card-body p-2 kanban-column" data-status="@IssueStatus.Assigned" style="min-height: 450px;">
                @foreach (var issue in Model.Where(i => i.Status == IssueStatus.Assigned))
                {
                    @await Html.PartialAsync("_KanbanCard", issue)
                }
            </div>
        </div>
    </div>

    <!-- Column 3: Đang xử lý (Processing) -->
    <div class="col" style="min-width: 240px; flex: 1 1 0;">
        <div class="card kanban-column-card">
            <div class="card-header py-2 bg-yellow-lt d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold text-xs">ĐANG XỬ LÝ (@Model.Count(i => i.Status == IssueStatus.Processing))</h3>
            </div>
            <div class="card-body p-2 kanban-column" data-status="@IssueStatus.Processing" style="min-height: 450px;">
                @foreach (var issue in Model.Where(i => i.Status == IssueStatus.Processing))
                {
                    @await Html.PartialAsync("_KanbanCard", issue)
                }
            </div>
        </div>
    </div>

    <!-- Column 4: Từ chối (Rejected) -->
    <div class="col" style="min-width: 240px; flex: 1 1 0;">
        <div class="card kanban-column-card">
            <div class="card-header py-2 bg-red-lt d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold text-xs">TỪ CHỐI (@Model.Count(i => i.Status == IssueStatus.Rejected))</h3>
            </div>
            <div class="card-body p-2 kanban-column" data-status="@IssueStatus.Rejected" style="min-height: 450px;">
                @foreach (var issue in Model.Where(i => i.Status == IssueStatus.Rejected))
                {
                    @await Html.PartialAsync("_KanbanCard", issue)
                }
            </div>
        </div>
    </div>

    <!-- Column 5: Hoàn tất (Resolved / Closed) -->
    <div class="col" style="min-width: 240px; flex: 1 1 0;">
        <div class="card kanban-column-card">
            <div class="card-header py-2 bg-green-lt d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold text-xs">HOÀN TẤT (@Model.Count(i => i.Status == IssueStatus.Resolved || i.Status == IssueStatus.Closed))</h3>
            </div>
            <div class="card-body p-2 kanban-column" data-status="@IssueStatus.Resolved" style="min-height: 450px;">
                @foreach (var issue in Model.Where(i => i.Status == IssueStatus.Resolved || i.Status == IssueStatus.Closed))
                {
                    @await Html.PartialAsync("_KanbanCard", issue)
                }
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script>
        $(document).ready(function () {
            // Cấu hình Toastr
            if (typeof toastr !== 'undefined') {
                toastr.options = {
                    "closeButton": true,
                    "progressBar": true,
                    "positionClass": "toast-top-right",
                    "timeOut": "3000"
                };
            } else {
                // Fallback nếu không có toastr
                window.toastr = {
                    success: function(msg) { alert('Thành công: ' + msg); },
                    error: function(msg) { alert('Lỗi: ' + msg); },
                    warning: function(msg) { alert('Cảnh báo: ' + msg); }
                };
            }

            const columns = document.querySelectorAll('.kanban-column');
            columns.forEach(column => {
                new Sortable(column, {
                    group: 'shared', // set both lists to same group
                    animation: 150,
                    ghostClass: 'bg-light', // Class for the drop placeholder
                    dragClass: 'opacity-50', // Class for the dragging item
                    scroll: true, // Enable auto-scrolling
                    forceFallback: true, // Force fallback for better auto-scroll on all browsers
                    onEnd: function (evt) {
                        const itemEl = evt.item;  // dragged HTMLElement
                        const toColumn = evt.to;    // target list
                        const fromColumn = evt.from;  // previous list
                        
                        // Nếu không đổi cột, bỏ qua
                        if (toColumn === fromColumn) return;

                        const issueId = itemEl.getAttribute('data-id');
                        const newStatusEnum = parseInt(toColumn.getAttribute('data-status'));
                        const oldStatusEnum = parseInt(itemEl.getAttribute('data-status'));

                        // Status ordering
                        let isBackward = false;
                        if (oldStatusEnum >= 0 && oldStatusEnum <= 4 && newStatusEnum >= 0 && newStatusEnum <= 4) {
                            if (newStatusEnum < oldStatusEnum) isBackward = true;
                        }

                        let auditNote = "";
                        if (isBackward) {
                            auditNote = prompt("Bạn đang kéo lùi trạng thái phản ánh. Hệ thống yêu cầu phải nhập lý do (Audit Note):");
                            if (auditNote === null || auditNote.trim() === "") {
                                toastr.warning("Bắt buộc phải nhập lý do khi kéo lùi trạng thái.");
                                // Revert item back to original column
                                fromColumn.insertBefore(itemEl, evt.item.nextSibling || fromColumn.children[evt.oldIndex]);
                                return;
                            }
                        }

                        // Hiển thị loading nhẹ hoặc disable card
                        $(itemEl).css('opacity', '0.5');

                        $.post('/Admin/Issues/UpdateKanbanStatus', { issueId: issueId, newStatus: newStatusEnum, auditNote: auditNote }, function (res) {
                            $(itemEl).css('opacity', '1');
                            if (res.success) {
                                toastr.success(`Đã cập nhật trạng thái thành công!`);
                                // Cập nhật data-status cho thẻ
                                itemEl.setAttribute('data-status', newStatusEnum);
                                
                                // Cập nhật số lượng trên header
                                updateColumnCount(fromColumn);
                                updateColumnCount(toColumn);
                            } else {
                                toastr.error(res.message || 'Cập nhật trạng thái thất bại!');
                                // Hoàn trả lại vị trí ban đầu
                                fromColumn.insertBefore(itemEl, evt.item.nextSibling || fromColumn.children[evt.oldIndex]);
                            }
                        }).fail(function() {
                            $(itemEl).css('opacity', '1');
                            toastr.error('Lỗi kết nối. Vui lòng thử lại sau!');
                            // Hoàn trả lại vị trí ban đầu
                            fromColumn.insertBefore(itemEl, evt.item.nextSibling || fromColumn.children[evt.oldIndex]);
                        });
                    }
                });
            });

            function updateColumnCount(columnEl) {
                const count = $(columnEl).children('.kanban-card').length;
                // Cập nhật text trong h3 header
                const headerTextEl = $(columnEl).closest('.kanban-column-card').find('.card-header h3');
                const text = headerTextEl.text();
                // Replace everything between ()
                headerTextEl.text(text.replace(/\(.*\)/, `(${count})`));
            }
        });
    </script>
}
