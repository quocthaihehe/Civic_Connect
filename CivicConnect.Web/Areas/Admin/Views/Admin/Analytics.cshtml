@{
    ViewData["Title"] = "Thống kê & Báo cáo";
    var totalCount = ViewData["TotalCount"] ?? 0;
    var pendingCount = ViewData["PendingCount"] ?? 0;
    var processingCount = ViewData["ProcessingCount"] ?? 0;
    var resolvedCount = ViewData["ResolvedCount"] ?? 0;
    var rejectedCount = ViewData["RejectedCount"] ?? 0;
    var byCategory = ViewData["ByCategory"] as Dictionary<CivicConnect.Web.Models.Enums.IssueCategory, int> ?? new Dictionary<CivicConnect.Web.Models.Enums.IssueCategory, int>();
}

<div class="space-y-6">
    <!-- Row 1: Key Stats -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-5">
        <!-- Stat Card 1 -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100 p-5">
            <div class="flex items-center">
                <div class="bg-blue-150 text-primary rounded-md p-3">
                    <i class="fas fa-list-ul text-lg"></i>
                </div>
                <div class="ml-4">
                    <div class="text-xs font-semibold text-gray-400 uppercase">Tổng phản ánh</div>
                    <div class="text-xl font-bold text-gray-900 mt-0.5">@totalCount</div>
                </div>
            </div>
        </div>

        <!-- Stat Card 2 -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100 p-5">
            <div class="flex items-center">
                <div class="bg-yellow-150 text-warning rounded-md p-3">
                    <i class="fas fa-clock text-lg"></i>
                </div>
                <div class="ml-4">
                    <div class="text-xs font-semibold text-gray-400 uppercase">Chờ tiếp nhận</div>
                    <div class="text-xl font-bold text-gray-900 mt-0.5">@pendingCount</div>
                </div>
            </div>
        </div>

        <!-- Stat Card 3 -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100 p-5">
            <div class="flex items-center">
                <div class="bg-indigo-150 text-indigo-600 rounded-md p-3">
                    <i class="fas fa-spinner text-lg"></i>
                </div>
                <div class="ml-4">
                    <div class="text-xs font-semibold text-gray-400 uppercase">Đang xử lý</div>
                    <div class="text-xl font-bold text-gray-900 mt-0.5">@processingCount</div>
                </div>
            </div>
        </div>

        <!-- Stat Card 4 -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100 p-5">
            <div class="flex items-center">
                <div class="bg-green-150 text-success rounded-md p-3">
                    <i class="fas fa-check-double text-lg"></i>
                </div>
                <div class="ml-4">
                    <div class="text-xs font-semibold text-gray-400 uppercase">Đã giải quyết</div>
                    <div class="text-xl font-bold text-gray-900 mt-0.5">@resolvedCount</div>
                </div>
            </div>
        </div>

        <!-- Stat Card 5 -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100 p-5">
            <div class="flex items-center">
                <div class="bg-red-150 text-danger rounded-md p-3">
                    <i class="fas fa-ban text-lg"></i>
                </div>
                <div class="ml-4">
                    <div class="text-xs font-semibold text-gray-400 uppercase">Đã từ chối</div>
                    <div class="text-xl font-bold text-gray-900 mt-0.5">@rejectedCount</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2: Charts Panel -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Main Line Chart (2/3 width) -->
        <div class="bg-white p-6 rounded-lg border border-gray-100 shadow-sm lg:col-span-2">
            <h3 class="text-sm font-semibold text-gray-700 uppercase mb-4"><i class="fas fa-chart-line text-primary mr-1.5"></i>Xu hướng phản ánh qua các tháng</h3>
            <div class="h-80">
                <canvas id="trendChart"></canvas>
            </div>
        </div>

        <!-- Doughnut Chart (1/3 width) -->
        <div class="bg-white p-6 rounded-lg border border-gray-100 shadow-sm">
            <h3 class="text-sm font-semibold text-gray-700 uppercase mb-4"><i class="fas fa-chart-pie text-primary mr-1.5"></i>Phân bố theo Danh mục</h3>
            <div class="h-80 flex justify-center items-center">
                <canvas id="categoryBreakdownChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Row 3: Performance Metrics & SLA -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Metric Card 1 -->
        <div class="bg-white p-6 rounded-lg border border-gray-100 shadow-sm">
            <div class="flex flex-col items-center text-center">
                <span class="text-xs font-semibold text-gray-400 uppercase">Thời gian xử lý trung bình</span>
                <span class="text-4xl font-extrabold text-primary mt-2">3.8 ngày</span>
                <p class="text-xs text-gray-450 mt-2">Thấp hơn định mức tối đa cho phép (7 ngày làm việc)</p>
                <div class="w-full bg-gray-100 rounded-full h-1.5 mt-4">
                    <div class="bg-primary h-1.5 rounded-full" style="width: 55%"></div>
                </div>
            </div>
        </div>

        <!-- Metric Card 2 -->
        <div class="bg-white p-6 rounded-lg border border-gray-100 shadow-sm">
            <div class="flex flex-col items-center text-center">
                <span class="text-xs font-semibold text-gray-400 uppercase">Mức độ hài lòng của công dân</span>
                <span class="text-4xl font-extrabold text-green-600 mt-2">94.8%</span>
                <p class="text-xs text-gray-450 mt-2">Dựa trên 184 đánh giá chấm sao sau khi hoàn thành</p>
                <div class="w-full bg-gray-100 rounded-full h-1.5 mt-4">
                    <div class="bg-green-500 h-1.5 rounded-full" style="width: 94%"></div>
                </div>
            </div>
        </div>

        <!-- Metric Card 3 -->
        <div class="bg-white p-6 rounded-lg border border-gray-100 shadow-sm">
            <div class="flex flex-col items-center text-center">
                <span class="text-xs font-semibold text-gray-400 uppercase">Tỷ lệ giải quyết đúng hạn (SLA)</span>
                <span class="text-4xl font-extrabold text-indigo-650 mt-2">98.2%</span>
                <p class="text-xs text-gray-450 mt-2">Chỉ có 3 trường hợp trễ hạn chuyển đổi tự động</p>
                <div class="w-full bg-gray-100 rounded-full h-1.5 mt-4">
                    <div class="bg-indigo-650 h-1.5 rounded-full" style="width: 98%"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Trend Line Chart
            const trendCtx = document.getElementById('trendChart').getContext('2d');
            new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: ['Tháng 1', 'Tháng 2', 'Tháng 3', 'Tháng 4', 'Tháng 5', 'Tháng 6'],
                    datasets: [{
                        label: 'Số phản ánh tiếp nhận',
                        data: [42, 59, 65, 81, 74, @totalCount],
                        borderColor: '#2563eb',
                        backgroundColor: 'rgba(37, 99, 235, 0.05)',
                        fill: true,
                        tension: 0.3,
                        borderWidth: 2,
                        pointRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: '#f3f4f6' }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });

            // Category Breakdown Chart
            const catBreakCtx = document.getElementById('categoryBreakdownChart').getContext('2d');
            
            // Collect category values from ViewData
            const categories = [];
            const counts = [];
            
            @foreach (var entry in byCategory)
            {
                var catName = entry.Key switch
                {
                    CivicConnect.Web.Models.Enums.IssueCategory.Traffic => "Giao thông",
                    CivicConnect.Web.Models.Enums.IssueCategory.Environment => "Môi trường",
                    CivicConnect.Web.Models.Enums.IssueCategory.Security => "An ninh",
                    CivicConnect.Web.Models.Enums.IssueCategory.Infrastructure => "Hạ tầng",
                    CivicConnect.Web.Models.Enums.IssueCategory.Administration => "Hành chính",
                    _ => "Khác"
                };
                <text>
                    categories.push("@catName");
                    counts.push(@entry.Value);
                </text>
            }

            // Fallback mock labels if empty
            const chartLabels = categories.length > 0 ? categories : ['Giao thông', 'Môi trường', 'An ninh', 'Hạ tầng', 'Khác'];
            const chartData = counts.length > 0 ? counts : [15, 25, 8, 12, 5];

            new Chart(catBreakCtx, {
                type: 'doughnut',
                data: {
                    labels: chartLabels,
                    datasets: [{
                        data: chartData,
                        backgroundColor: [
                            '#3b82f6', // Traffic (blue)
                            '#10b981', // Environment (green)
                            '#ef4444', // Security (red)
                            '#f59e0b', // Infrastructure (orange)
                            '#8b5cf6'  // Others
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                boxWidth: 12,
                                font: { size: 11 }
                            }
                        }
                    },
                    cutout: '65%'
                }
            });
        });
    </script>
}
