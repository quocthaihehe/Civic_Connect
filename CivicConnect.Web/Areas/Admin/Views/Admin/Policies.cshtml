@model IEnumerable<CivicConnect.Web.Models.Entities.Policy>
@{
    ViewData["Title"] = "Quản lý chính sách";
    var successMsg = TempData["SuccessMessage"]?.ToString();
}

<div class="space-y-6 relative">
    <!-- Header Actions -->
    <div class="flex justify-between items-center bg-white shadow-sm rounded-lg border border-gray-100 p-5">
        <div>
            <h2 class="text-base font-bold text-gray-900">Quản lý Chính sách & Tin tức</h2>
            <p class="text-xs text-gray-500 mt-1">Quản lý các thông báo điều hành và chính sách pháp luật của đô thị</p>
        </div>
        <button id="open-drawer-btn" class="bg-primary hover:bg-blue-700 text-white font-medium py-2.5 px-4 rounded-md text-sm transition-colors flex items-center">
            <i class="fas fa-plus mr-2"></i> Thêm chính sách mới
        </button>
    </div>

    <!-- Toast Alert -->
    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center shadow-sm">
            <i class="fas fa-check-circle mr-2 text-green-500"></i>
            <span class="text-sm font-medium">@successMsg</span>
        </div>
    }

    <!-- Table -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Mã</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Tiêu đề văn bản</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Số hiệu</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Cơ quan ban hành</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Người ký</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Phân loại</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Ngày ban hành</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Hành động</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="px-6 py-10 text-center text-sm text-gray-500">
                                Chưa có chính sách hay thông báo nào được đăng tải.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var policy in Model)
                        {
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">#@policy.Id</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">
                                    <div class="max-w-xs truncate" title="@policy.Title">@policy.Title</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 font-mono">@(policy.DocumentNumber ?? "N/A")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@policy.IssuingUnit</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(policy.Signer ?? "N/A")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <span class="px-2 py-0.5 inline-flex text-[10px] font-bold rounded-full @GetTagClass(policy.Tag)">
                                        @policy.Tag
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@policy.PublishedDate.ToString("dd/MM/yyyy")</td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <a href="/Policy/Details/@policy.Id" target="_blank" class="text-primary hover:text-blue-800 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-md transition-colors mr-2">Xem</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Sliding Drawer Panel (Form to Create Policy) -->
    <div id="drawer-backdrop" class="fixed inset-0 bg-gray-500 bg-opacity-75 z-40 hidden transition-opacity duration-300"></div>
    
    <div id="drawer-panel" class="fixed inset-y-0 right-0 max-w-full flex pl-10 z-50 transform translate-x-full transition-transform duration-300 ease-in-out">
        <div class="w-screen max-w-md bg-white shadow-xl flex flex-col">
            <!-- Drawer Header -->
            <div class="px-4 py-5 bg-gray-50 border-b border-gray-100 sm:px-6 flex justify-between items-center">
                <h2 class="text-base font-bold text-gray-900">Thêm Chính sách / Thông báo mới</h2>
                <button id="close-drawer-btn" class="text-gray-400 hover:text-gray-500 focus:outline-none">
                    <i class="fas fa-times text-lg"></i>
                </button>
            </div>

            <!-- Drawer Content (Form) -->
            <form action="/Admin/Policies/Create" method="post" class="flex-1 overflow-y-auto px-4 py-6 sm:px-6 space-y-4">
                @Html.AntiForgeryToken()
                
                <div>
                    <label for="title" class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">Tiêu đề văn bản *</label>
                    <input type="text" name="title" id="title" required class="block w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-primary focus:border-primary" placeholder="Nhập tiêu đề công văn, chỉ thị, tin tức...">
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label for="tag" class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">Phân loại *</label>
                        <select name="tag" id="tag" required class="block w-full py-2 px-3 border border-gray-300 bg-white rounded-md text-sm focus:outline-none focus:ring-primary focus:border-primary">
                            <option value="Thông báo">Thông báo</option>
                            <option value="Tin tức">Tin tức</option>
                            <option value="Hướng dẫn">Hướng dẫn</option>
                            <option value="Văn bản pháp luật">Văn bản pháp luật</option>
                        </select>
                    </div>
                    <div>
                        <label for="issuingUnit" class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">Cơ quan ban hành *</label>
                        <input type="text" name="issuingUnit" id="issuingUnit" required class="block w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-primary focus:border-primary" placeholder="VD: UBND TP.HCM">
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label for="documentNumber" class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">Số hiệu văn bản</label>
                        <input type="text" name="documentNumber" id="documentNumber" class="block w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-primary focus:border-primary" placeholder="VD: 100/2026/NĐ-CP">
                    </div>
                    <div>
                        <label for="signer" class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">Người ký duyệt</label>
                        <input type="text" name="signer" id="signer" class="block w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-primary focus:border-primary" placeholder="VD: Nguyễn Văn A">
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label for="effectiveDate" class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">Ngày có hiệu lực</label>
                        <input type="date" name="effectiveDate" id="effectiveDate" class="block w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-primary focus:border-primary">
                    </div>
                    <div>
                        <label for="sourceUrl" class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">URL liên kết ngoài (nếu có)</label>
                        <input type="url" name="sourceUrl" id="sourceUrl" class="block w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-primary focus:border-primary" placeholder="https://...">
                    </div>
                </div>

                <div>
                    <label for="excerpt" class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">Tóm tắt ngắn *</label>
                    <textarea name="excerpt" id="excerpt" rows="2" required class="block w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-primary focus:border-primary" placeholder="Tóm tắt ngắn gọn nội dung văn bản chính sách..."></textarea>
                </div>

                <div>
                    <label for="content" class="block text-xs font-semibold text-gray-500 uppercase mb-1.5">Nội dung chi tiết *</label>
                    <textarea name="content" id="content" rows="6" required class="block w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-primary focus:border-primary" placeholder="Điền toàn văn nội dung chính sách pháp lý hoặc thông báo điều hành..."></textarea>
                </div>

                <!-- Footer button inside drawer -->
                <div class="border-t border-gray-150 pt-4 flex space-x-3">
                    <button type="button" id="cancel-drawer-btn" class="flex-1 bg-white border border-gray-300 text-gray-700 py-2.5 px-4 rounded-md text-sm font-medium hover:bg-gray-50 focus:outline-none text-center transition-colors">
                        Huỷ bỏ
                    </button>
                    <button type="submit" class="flex-1 bg-primary hover:bg-blue-700 text-white py-2.5 px-4 rounded-md text-sm font-medium focus:outline-none transition-colors">
                        Đăng tải
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            const $backdrop = $('#drawer-backdrop');
            const $panel = $('#drawer-panel');
            const $openBtn = $('#open-drawer-btn');
            const $closeBtn = $('#close-drawer-btn');
            const $cancelBtn = $('#cancel-drawer-btn');

            function openDrawer() {
                $backdrop.removeClass('hidden');
                setTimeout(() => $panel.removeClass('translate-x-full'), 50);
            }

            function closeDrawer() {
                $panel.addClass('translate-x-full');
                setTimeout(() => $backdrop.addClass('hidden'), 300);
            }

            $openBtn.on('click', openDrawer);
            $closeBtn.on('click', closeDrawer);
            $cancelBtn.on('click', closeDrawer);
            $backdrop.on('click', closeDrawer);
        });
    </script>
}

@functions {
    public string GetTagClass(string tag) => tag switch
    {
        "Thông báo" => "bg-yellow-50 text-yellow-750 border border-yellow-150",
        "Tin tức" => "bg-blue-50 text-blue-750 border border-blue-150",
        "Hướng dẫn" => "bg-green-50 text-green-750 border border-green-150",
        "Văn bản pháp luật" => "bg-purple-50 text-purple-755 border border-purple-150",
        _ => "bg-gray-100 text-gray-800"
    };
}
