@using CivicConnect.Web.Models.Enums
@{
    ViewData["Title"] = "Thống Kê Uy Tín Cơ Quan";
    var stats = ViewData["UnitStats"] as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="icon-box-lg bg-warning bg-opacity-10 rounded-3 p-3">
            <i class="bi bi-star-fill text-warning fs-3"></i>
        </div>
        <div>
            <h1 class="h3 fw-bold mb-0">Thống Kê Uy Tín Cơ Quan</h1>
            <p class="text-muted mb-0">Điểm đánh giá mức độ hài lòng của người dân theo từng đơn vị tiếp nhận</p>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var unit in stats)
        {
            double avg = unit.AvgRating ?? 0;
            int ratedCount = (int)unit.RatedCount;
            int totalResolved = (int)unit.TotalResolved;
            int totalAssigned = (int)unit.TotalAssigned;
            int fullStars = (int)Math.Floor(avg);
            bool halfStar = (avg - fullStars) >= 0.5;
            double resolveRate = totalAssigned > 0 ? (double)totalResolved / totalAssigned * 100 : 0;

            string cardBorder = avg >= 4 ? "border-success" : avg >= 3 ? "border-warning" : avg > 0 ? "border-danger" : "border-secondary";
            string badgeClass = avg >= 4 ? "bg-success" : avg >= 3 ? "bg-warning text-dark" : avg > 0 ? "bg-danger" : "bg-secondary";
            string badgeLabel = avg >= 4 ? "Xuất sắc" : avg >= 3 ? "Tốt" : avg > 0 ? "Cần cải thiện" : "Chưa đánh giá";

            <div class="col-md-6 col-xl-4">
                <div class="card h-100 shadow-sm border-2 @cardBorder">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="fw-bold mb-1">@unit.Name</h5>
                                <span class="badge bg-primary bg-opacity-10 text-primary">
                                    @(unit.Type == GovernmentUnitType.Ward ? "Phường/Xã" : unit.Type == GovernmentUnitType.District ? "Quận/Huyện" : "Tỉnh/TP")
                                </span>
                            </div>
                            <span class="badge @badgeClass px-3 py-2">@badgeLabel</span>
                        </div>

                        <!-- Star Rating Display -->
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <div class="star-display fs-4">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    if (s <= fullStars)
                                    {
                                        <i class="bi bi-star-fill text-warning"></i>
                                    }
                                    else if (s == fullStars + 1 && halfStar)
                                    {
                                        <i class="bi bi-star-half text-warning"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-star text-muted"></i>
                                    }
                                }
                            </div>
                            <span class="fs-5 fw-bold">@(avg > 0 ? avg.ToString("0.0") : "—")</span>
                            <span class="text-muted small">(@ratedCount đánh giá)</span>
                        </div>

                        <!-- Stats Row -->
                        <div class="row g-2 text-center">
                            <div class="col-4">
                                <div class="bg-light rounded-2 p-2">
                                    <div class="fw-bold fs-5 text-primary">@totalAssigned</div>
                                    <div class="text-muted" style="font-size:0.72rem">Tiếp nhận</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="bg-light rounded-2 p-2">
                                    <div class="fw-bold fs-5 text-success">@totalResolved</div>
                                    <div class="text-muted" style="font-size:0.72rem">Đã giải quyết</div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="bg-light rounded-2 p-2">
                                    <div class="fw-bold fs-5 text-info">@resolveRate.ToString("0")%</div>
                                    <div class="text-muted" style="font-size:0.72rem">Tỷ lệ xử lý</div>
                                </div>
                            </div>
                        </div>

                        <!-- Progress Bar -->
                        @if (avg > 0)
                        {
                            <div class="mt-3">
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar @(avg >= 4 ? "bg-success" : avg >= 3 ? "bg-warning" : "bg-danger")"
                                         role="progressbar"
                                         style="width: @(avg / 5 * 100)%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Back Button -->
    <div class="mt-4">
        <a asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Quay lại Dashboard
        </a>
    </div>
</div>
