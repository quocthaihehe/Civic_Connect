@model IEnumerable<CivicConnect.Web.Models.Entities.Issue>
@using CivicConnect.Web.Models.Enums
@{
    ViewData["Title"] = "Quản lý phản ánh";
}

<div class="space-y-6">
    <!-- Filters & Search Card -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-100 p-5">
        <form method="get" action="/Admin/Issues" class="grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-5 items-end">
            <!-- Search -->
            <div class="md:col-span-2">
                <label for="search" class="block text-xs font-semibold text-gray-500 uppercase mb-2">Tìm kiếm</label>
                <div class="relative flex items-center">
                    <i class="fas fa-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-sm"></i>
                    <input type="text" name="search" id="search" value="@Context.Request.Query["search"]" class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-md bg-gray-50 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-primary focus:border-primary text-sm" placeholder="Tiêu đề, nội dung, địa chỉ...">
                </div>
            </div>

            <!-- Category -->
            <div>
                <label for="category" class="block text-xs font-semibold text-gray-500 uppercase mb-2">Danh mục</label>
                <select name="category" id="category" class="block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-primary focus:border-primary text-sm">
                    <option value="">Tất cả danh mục</option>
                    @foreach (IssueCategory cat in Enum.GetValues(typeof(IssueCategory)))
                    {
                        var selectedAttr = Context.Request.Query["category"] == cat.ToString() ? "selected" : "";
                        <option value="@cat" selectedAttr>@GetCategoryName(cat)</option>
                    }
                </select>
            </div>

            <!-- Status -->
            <div>
                <label for="status" class="block text-xs font-semibold text-gray-500 uppercase mb-2">Trạng thái</label>
                <select name="status" id="status" class="block w-full py-2 px-3 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-primary focus:border-primary text-sm">
                    <option value="">Tất cả trạng thái</option>
                    @foreach (IssueStatus stat in Enum.GetValues(typeof(IssueStatus)))
                    {
                        var selectedAttr = Context.Request.Query["status"] == stat.ToString() ? "selected" : "";
                        <option value="@stat" selectedAttr>@GetStatusName(stat)</option>
                    }
                </select>
            </div>

            <!-- Action Buttons -->
            <div class="flex space-x-2">
                <button type="submit" class="flex-1 bg-primary text-white py-2 px-4 rounded-md text-sm font-medium hover:bg-blue-700 focus:outline-none transition-colors">
                    Lọc
                </button>
                <a href="/Admin/Issues" class="bg-gray-100 text-gray-700 py-2 px-4 rounded-md text-sm font-medium hover:bg-gray-250 focus:outline-none text-center transition-colors">
                    Xoá
                </a>
            </div>
        </form>
    </div>

    <!-- Data Table -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50 flex justify-between items-center">
            <h3 class="text-base font-semibold text-gray-900">Danh sách Phản ánh hiện trường</h3>
            <span class="text-xs text-gray-500 font-medium">Tổng số: @Model.Count() bản ghi</span>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Mã</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Tiêu đề</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Người gửi</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Danh mục</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Độ khẩn</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Ngày gửi</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Trạng thái</th>
                        <th scope="col" class="px-6 py-3 class="text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="px-6 py-10 text-center text-sm text-gray-500">
                                Không tìm thấy phản ánh nào phù hợp.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var issue in Model)
                        {
                            <tr>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">#@issue.Id</td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">
                                    <div class="max-w-xs truncate" title="@issue.Title">@issue.Title</div>
                                    <div class="text-xs text-gray-400 font-normal truncate max-w-xs">@issue.Address</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    @(issue.IsAnonymous ? "Ẩn danh" : issue.Author?.FullName ?? "Không rõ")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-50 text-primary">
                                        @GetCategoryName(issue.Category)
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                    <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full @GetPriorityClass(issue.Priority)">
                                        @GetPriorityName(issue.Priority)
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@issue.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="px-2.5 py-1 inline-flex text-[11px] leading-5 font-bold rounded-full @GetStatusClass(issue.Status)">
                                        @GetStatusName(issue.Status)
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <a href="/Admin/Issues/Details/@issue.Id" class="text-primary hover:text-blue-800 bg-blue-50 hover:bg-blue-100 px-3 py-1.5 rounded-md transition-colors">Chi tiết</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    public string GetStatusName(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "Chờ duyệt",
        IssueStatus.Assigned => "Đã phân công",
        IssueStatus.Processing => "Đang xử lý",
        IssueStatus.Resolved => "Đã giải quyết",
        IssueStatus.Rejected => "Từ chối",
        IssueStatus.Closed => "Đã đóng",
        _ => "Không xác định"
    };

    public string GetStatusClass(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "bg-yellow-50 text-yellow-700 border border-yellow-150",
        IssueStatus.Assigned => "bg-blue-50 text-blue-700 border border-blue-150",
        IssueStatus.Processing => "bg-indigo-50 text-indigo-700 border border-indigo-150",
        IssueStatus.Resolved => "bg-green-50 text-green-700 border border-green-150",
        IssueStatus.Rejected => "bg-red-50 text-red-700 border border-red-150",
        IssueStatus.Closed => "bg-gray-50 text-gray-700 border border-gray-150",
        _ => "bg-gray-100 text-gray-800"
    };

    public string GetPriorityName(IssuePriority priority) => priority switch
    {
        IssuePriority.Low => "Thấp",
        IssuePriority.Medium => "Trung bình",
        IssuePriority.High => "Cao",
        IssuePriority.Critical => "Khẩn cấp",
        _ => "Bình thường"
    };

    public string GetPriorityClass(IssuePriority priority) => priority switch
    {
        IssuePriority.Low => "bg-gray-100 text-gray-700",
        IssuePriority.Medium => "bg-blue-50 text-blue-600",
        IssuePriority.High => "bg-orange-50 text-orange-600",
        IssuePriority.Critical => "bg-red-100 text-red-700 font-bold",
        _ => "bg-gray-100 text-gray-700"
    };

    public string GetCategoryName(IssueCategory category) => category switch
    {
        IssueCategory.Traffic => "Giao thông",
        IssueCategory.Environment => "Môi trường",
        IssueCategory.Security => "An ninh",
        IssueCategory.Infrastructure => "Hạ tầng",
        IssueCategory.Administration => "Hành chính",
        _ => "Khác"
    };
}
