@model IEnumerable<CivicConnect.Web.Models.Entities.Issue>
@using CivicConnect.Web.Models.Enums
@{
    ViewData["Title"] = "Tổng quan";
    var totalReports = ViewData["TotalReports"];
    var inProgress = ViewData["InProgress"];
    var resolved = ViewData["Resolved"];
    var urgentCases = ViewData["UrgentCases"];
}

<div class="space-y-6">
    <!-- Row 1: KPI Statistics Cards -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Card 1 -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-blue-100 rounded-md p-3">
                        <i class="fas fa-file-alt text-primary text-xl"></i>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-semibold text-gray-500 truncate">Tổng số phản ánh</dt>
                            <dd class="flex items-baseline">
                                <div class="text-2xl font-bold text-gray-900">@totalReports</div>
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 2 -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-yellow-100 rounded-md p-3">
                        <i class="fas fa-spinner text-warning text-xl"></i>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-semibold text-gray-500 truncate">Đang xử lý</dt>
                            <dd class="flex items-baseline">
                                <div class="text-2xl font-bold text-gray-900">@inProgress</div>
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 3 -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-green-100 rounded-md p-3">
                        <i class="fas fa-check-circle text-success text-xl"></i>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-semibold text-gray-500 truncate">Đã giải quyết</dt>
                            <dd class="flex items-baseline">
                                <div class="text-2xl font-bold text-gray-900">@resolved</div>
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 4 -->
        <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-100">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-red-100 rounded-md p-3">
                        <i class="fas fa-exclamation-triangle text-danger text-xl"></i>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-semibold text-gray-500 truncate">Phản ánh khẩn cấp</dt>
                            <dd class="flex items-baseline">
                                <div class="text-2xl font-bold text-gray-900">@urgentCases</div>
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2: Central Heatmap Section -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center bg-gray-50">
            <h3 class="text-lg leading-6 font-bold text-gray-900">Bản đồ nhiệt phản ánh hiện trường</h3>
            <div class="flex space-x-2">
                <select class="block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm rounded-md">
                    <option>Tất cả danh mục</option>
                    <option>Giao thông</option>
                    <option>Môi trường</option>
                    <option>An ninh</option>
                </select>
            </div>
        </div>
        <div class="p-0">
            <div id="issueHeatmap" style="height: 450px; width: 100%; z-index: 1;"></div>
        </div>
    </div>

    <!-- Row 3: Analytics Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Left Panel: Bar Chart -->
        <div class="bg-white shadow-sm rounded-lg border border-gray-100 p-6">
            <h3 class="text-base font-bold text-gray-900 mb-4">Thống kê phản ánh theo Danh mục</h3>
            <div class="h-64">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>

        <!-- Right Panel: Pie Chart -->
        <div class="bg-white shadow-sm rounded-lg border border-gray-100 p-6">
            <h3 class="text-base font-bold text-gray-900 mb-4">Tình hình xử lý phản ánh</h3>
            <div class="h-64 flex justify-center">
                <canvas id="statusChart"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Row 4: Recent Issues -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-100 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 bg-gray-50">
            <h3 class="text-lg leading-6 font-bold text-gray-900">Phản ánh mới nhận</h3>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Mã</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Tiêu đề</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Người gửi</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Ngày gửi</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Trạng thái</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var issue in Model)
                    {
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">#@issue.Id</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">
                                <a href="/Admin/Issues/Details/@issue.Id" class="hover:text-primary">@issue.Title</a>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                @(issue.IsAnonymous ? "Ẩn danh" : issue.Author?.FullName ?? "Không rõ")
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@issue.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2.5 py-1 inline-flex text-xs leading-5 font-bold rounded-full @GetStatusClass(issue.Status)">
                                    @GetStatusName(issue.Status)
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@functions {
    public string GetStatusName(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "Chờ duyệt",
        IssueStatus.Assigned => "Đã phân công",
        IssueStatus.Processing => "Đang xử lý",
        IssueStatus.Resolved => "Đã giải quyết",
        IssueStatus.Rejected => "Từ chối",
        IssueStatus.Closed => "Đã đóng",
        _ => "Không xác định"
    };

    public string GetStatusClass(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "bg-yellow-50 text-yellow-700 border border-yellow-150",
        IssueStatus.Assigned => "bg-blue-50 text-blue-700 border border-blue-150",
        IssueStatus.Processing => "bg-indigo-50 text-indigo-700 border border-indigo-150",
        IssueStatus.Resolved => "bg-green-50 text-green-700 border border-green-150",
        IssueStatus.Rejected => "bg-red-50 text-red-700 border border-red-150",
        IssueStatus.Closed => "bg-gray-50 text-gray-700 border border-gray-150",
        _ => "bg-gray-100 text-gray-800"
    };
}

@section Scripts {
    <script>
        $(document).ready(function () {
            // Initialize Leaflet Map
            var map = L.map('issueHeatmap').setView([10.7769, 106.7009], 13);

            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap &copy; CARTO',
                subdomains: 'abcd',
                maxZoom: 20
            }).addTo(map);

            var mockPoints = [
                [10.782, 106.702],
                [10.775, 106.701],
                [10.771, 106.698]
            ];
            
            mockPoints.forEach(function(p) {
                L.circleMarker(p, {
                    radius: 8,
                    fillColor: "#ef4444",
                    color: "#fff",
                    weight: 1,
                    opacity: 1,
                    fillOpacity: 0.8
                }).addTo(map).bindPopup("Vị trí phản ánh hiện trường");
            });

            // Initialize Charts
            const catCtx = document.getElementById('categoryChart').getContext('2d');
            new Chart(catCtx, {
                type: 'bar',
                data: {
                    labels: ['Giao thông', 'Môi trường', 'An ninh', 'Hạ tầng', 'Hành chính'],
                    datasets: [{
                        label: 'Số lượng phản ánh',
                        data: [12, 19, 3, 5, 2],
                        backgroundColor: '#3b82f6',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } }
                }
            });

            const statCtx = document.getElementById('statusChart').getContext('2d');
            new Chart(statCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Đã giải quyết', 'Đang xử lý', 'Chờ tiếp nhận'],
                    datasets: [{
                        data: [60, 25, 15],
                        backgroundColor: ['#22c55e', '#3b82f6', '#f59e0b']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%'
                }
            });
        });
    </script>
}
