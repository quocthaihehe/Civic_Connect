@model IEnumerable<CivicConnect.Web.Models.Entities.Issue>
@using CivicConnect.Web.Models.Enums
@{
    ViewData["Title"] = "Quản trị hệ thống";
    var userCount = ViewData["UserCount"];
    var issueCount = ViewData["IssueCount"];
    var unitCount = ViewData["UnitCount"];
}

<div class="d-flex flex-column gap-4">
    <!-- Thống kê chung -->
    <div class="row g-3">
        <div class="col-md-4">
            <div class="glass-card p-4 d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted fw-semibold" style="font-size: 0.85rem;">Tổng số tài khoản</span>
                    <h2 class="fw-bold mt-1 text-primary mb-0">@userCount</h2>
                </div>
                <div class="bg-primary-light text-primary rounded-3 p-3 d-flex align-items-center justify-content-center" style="width: 54px; height: 54px; background: rgba(37,99,235,0.08);">
                    <i class="bi bi-people fs-3"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="glass-card p-4 d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted fw-semibold" style="font-size: 0.85rem;">Tổng số phản ánh</span>
                    <h2 class="fw-bold mt-1 text-danger mb-0">@issueCount</h2>
                </div>
                <div class="bg-danger-light text-danger rounded-3 p-3 d-flex align-items-center justify-content-center" style="width: 54px; height: 54px; background: rgba(239,68,68,0.08);">
                    <i class="bi bi-chat-right-text fs-3"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="glass-card p-4 d-flex align-items-center justify-content-between">
                <div>
                    <span class="text-muted fw-semibold" style="font-size: 0.85rem;">Cơ quan hành chính</span>
                    <h2 class="fw-bold mt-1 text-success mb-0">@unitCount</h2>
                </div>
                <div class="bg-success-light text-success rounded-3 p-3 d-flex align-items-center justify-content-center" style="width: 54px; height: 54px; background: rgba(16,185,129,0.08);">
                    <i class="bi bi-building fs-3"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Menu thao tác Admin -->
    <div class="d-flex flex-wrap gap-2">
        <a asp-action="Users" class="btn btn-outline-primary rounded-pill"><i class="bi bi-person-fill-lock me-1"></i> Quản lý tài khoản</a>
        <a asp-action="Units" class="btn btn-outline-success rounded-pill"><i class="bi bi-building-fill me-1"></i> Quản lý cơ quan</a>
        <a asp-action="UnitStats" class="btn btn-outline-warning rounded-pill"><i class="bi bi-star-fill me-1"></i> Thống kê uy tín cơ quan</a>
        <a asp-action="Issues" class="btn btn-outline-danger rounded-pill"><i class="bi bi-shield-lock-fill me-1"></i> Kiểm duyệt phản ánh</a>
        <a asp-action="Donations" class="btn btn-outline-info rounded-pill"><i class="bi bi-heart-fill me-1"></i> Quản lý quyên góp</a>
        <a asp-action="CreatePolicy" class="btn btn-outline-secondary rounded-pill"><i class="bi bi-journal-text me-1"></i> Đăng tin tức & chính sách</a>
    </div>

    <!-- Phản ánh gần đây -->
    <div class="glass-card p-4 p-md-5">
        <h5 class="fw-bold mb-4 text-white"><i class="bi bi-clock-history text-primary me-2"></i> Các phản ánh gửi lên gần đây</h5>
        @if (!Model.Any())
        {
            <div class="text-center py-4 text-muted">Không có phản ánh nào trong hệ thống.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle table-hover mb-0">
                    <thead class="table-light">
                        <tr style="font-size: 0.85rem;">
                            <th>ID</th>
                            <th>Tiêu đề</th>
                            <th>Người gửi</th>
                            <th>Ngày gửi</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 0.85rem;">
                        @foreach (var issue in Model)
                        {
                            <tr>
                                <td>#@issue.Id</td>
                                <td class="fw-bold text-white text-truncate" style="max-width: 250px;">
                                    <a asp-controller="Issues" asp-action="Details" asp-route-id="@issue.Id" class="text-decoration-none text-white hover-lift">@issue.Title</a>
                                </td>
                                <td>@(issue.IsAnonymous ? "Nặc danh" : issue.Author?.FullName)</td>
                                <td>@issue.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge @GetStatusClass(issue.Status) rounded-pill">@GetStatusName(issue.Status)</span>
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Issues" asp-action="Details" asp-route-id="@issue.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3">Xem chi tiết</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    public string GetStatusName(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "Chờ tiếp nhận",
        IssueStatus.Assigned => "Đã phân công",
        IssueStatus.Processing => "Đang xử lý",
        IssueStatus.Resolved => "Đã giải quyết",
        IssueStatus.Rejected => "Từ chối",
        IssueStatus.Closed => "Đóng tự động",
        _ => "Không xác định"
    };

    public string GetStatusClass(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "bg-warning text-dark",
        IssueStatus.Assigned => "bg-info text-white",
        IssueStatus.Processing => "bg-primary text-white",
        IssueStatus.Resolved => "bg-success text-white",
        IssueStatus.Rejected => "bg-danger text-white",
        _ => "bg-secondary text-white"
    };
}
