@model IEnumerable<CivicConnect.Web.Models.Entities.ApplicationUser>
@{
    ViewData["Title"] = "Quản lý tài khoản";
    var successMsg = TempData["SuccessMessage"]?.ToString();
}

<div class="space-y-6">
    <!-- Back Button -->
    <div>
        <a asp-action="Dashboard" class="inline-flex items-center text-sm text-gray-500 hover:text-gray-900 transition-colors">
            <i class="fas fa-arrow-left mr-2"></i> Quay lại Trang tổng quan
        </a>
    </div>

    <!-- Alert Message -->
    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center shadow-sm">
            <i class="fas fa-check-circle mr-2 text-green-500"></i>
            <span class="text-sm font-medium">@successMsg</span>
        </div>
    }

    <!-- User List Card -->
    <div class="bg-white shadow-sm rounded-lg border border-gray-100 p-6">
        <h3 class="text-base font-bold text-gray-900 mb-4 flex items-center">
            <i class="fas fa-users text-primary mr-2"></i> Quản lý danh sách tài khoản hệ thống
        </h3>

        <div class="overflow-x-auto border border-gray-100 rounded-lg">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Họ tên</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Số điện thoại</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Khu vực quản lý</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Trạng thái</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Hành động</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">@user.FullName</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@user.Email</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@(string.IsNullOrEmpty(user.PhoneNumber) ? "Chưa cập nhật" : user.PhoneNumber)</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                @if (!string.IsNullOrEmpty(user.WardCode) || !string.IsNullOrEmpty(user.DistrictCode))
                                {
                                    <span>P. @(user.WardCode ?? "N/A") / Q. @(user.DistrictCode ?? "N/A")</span>
                                }
                                else
                                {
                                    <span class="text-gray-400 italic">Không phân bổ</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                @if (user.IsActive)
                                {
                                    <span class="px-2.5 py-1 inline-flex text-[11px] font-bold rounded-full bg-green-50 text-green-700 border border-green-150">Đang hoạt động</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-1 inline-flex text-[11px] font-bold rounded-full bg-red-50 text-red-700 border border-red-150">Đã bị khoá</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <form asp-action="LockUser" asp-route-id="@user.Id" method="post" class="inline-block">
                                    @Html.AntiForgeryToken()
                                    @if (user.IsActive)
                                    {
                                        <button type="submit" class="bg-red-50 hover:bg-red-100 text-red-600 border border-red-200 px-3 py-1.5 rounded-md text-xs font-semibold transition-colors">Khoá tài khoản</button>
                                    }
                                    else
                                    {
                                        <button type="submit" class="bg-green-50 hover:bg-green-100 text-green-600 border border-green-200 px-3 py-1.5 rounded-md text-xs font-semibold transition-colors">Kích hoạt</button>
                                    }
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
