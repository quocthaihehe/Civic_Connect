@{
    Layout = "_AdminTablerLayout";
    ViewData["Title"] = "Phân tích chuyên sâu";
}

<style>
    /* Styling for Analytics overhaul */
    .analytics-wrapper {
        font-family: 'Inter', sans-serif;
    }
    .analytics-card {
        border: 1px solid #CCCCCC !important;
        border-radius: 8px !important;
        box-shadow: none !important;
        background-color: #ffffff;
        overflow: hidden;
    }
    .analytics-card .card-header {
        border-bottom: 1px solid #e2e8f0;
    }
    .text-civic-green { color: #133B2F; }
    .text-civic-gold { color: #D4AF37; }
</style>

<div class="analytics-wrapper">
    <!-- Page header -->
    <div class="page-header d-print-none mb-4 mt-2">
        <div class="row align-items-center">
            <div class="col">
                <h2 class="page-title text-2xl font-bold text-civic-green">Phân tích chuyên sâu</h2>
                <div class="text-muted small mt-1">Các chỉ số thống kê nâng cao về phễu xử lý, hành vi công dân và hiệu năng cán bộ</div>
            </div>
        </div>
    </div>

    <div class="row row-cards mb-4">
        <!-- Phễu chuyển đổi (Funnel) -->
        <div class="col-lg-6">
            <div class="card analytics-card" style="height: 350px;">
                <div class="card-header bg-transparent py-3">
                    <h3 class="card-title font-weight-bold"><i class="bi bi-funnel me-2 text-civic-green"></i>Phễu chuyển đổi phản ánh</h3>
                </div>
                <div class="card-body d-flex flex-column justify-content-between py-4">
                    @{
                        int countNew = ViewBag.CountNew ?? 5;
                        int countAssigned = ViewBag.CountAssigned ?? 10;
                        int countProcessing = ViewBag.CountProcessing ?? 15;
                        int countClosed = ViewBag.CountClosed ?? 45;
                        int total = countNew + countAssigned + countProcessing + countClosed;
                        if (total == 0) total = 100;
                        int pctNew = (countNew * 100) / total;
                        int pctAssigned = ((countNew + countAssigned) * 100) / total;
                        int pctProcessing = ((countNew + countAssigned + countProcessing) * 100) / total;
                        int pctClosed = 100;
                    }
                    <!-- Funnel Visual Steps -->
                    <div class="space-y-3">
                        <div>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="font-weight-bold text-dark">1. Tiếp nhận (Mới)</span>
                                <span class="text-muted">@countNew phản ánh</span>
                            </div>
                            <div class="progress progress-md" style="height: 18px; border-radius: 4px;">
                                <div class="progress-bar" style="width: 100%; background-color: #133B2F;">100%</div>
                            </div>
                        </div>
                        <div>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="font-weight-bold text-dark">2. Đã phân công cán bộ</span>
                                <span class="text-muted">@countAssigned phản ánh</span>
                            </div>
                            <div class="progress progress-md" style="height: 18px; border-radius: 4px;">
                                <div class="progress-bar" style="width: 85%; background-color: #2fb344;">85%</div>
                            </div>
                        </div>
                        <div>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="font-weight-bold text-dark">3. Đang xử lý</span>
                                <span class="text-muted">@countProcessing phản ánh</span>
                            </div>
                            <div class="progress progress-md" style="height: 18px; border-radius: 4px;">
                                <div class="progress-bar font-weight-bold" style="width: 68%; background-color: #D4AF37; color: #ffffff;">68%</div>
                            </div>
                        </div>
                        <div>
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span class="font-weight-bold text-dark">4. Giải quyết & Đóng</span>
                                <span class="text-muted">@countClosed phản ánh</span>
                            </div>
                            <div class="progress progress-md" style="height: 18px; border-radius: 4px;">
                                <div class="progress-bar" style="width: 58%; background-color: #0ca678;">58%</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cohort Analysis & Word Cloud -->
        <div class="col-lg-6">
            <div class="row row-cards" style="height: 350px;">
                <!-- Cohort Repeat Rate -->
                <div class="col-12" style="height: 130px;">
                    <div class="card h-100 analytics-card">
                        <div class="card-body d-flex align-items-center justify-content-between px-4">
                            <div class="d-flex flex-column justify-content-between h-100 py-1">
                                <div class="h4 text-muted mb-0">Tỷ lệ công dân gửi tiếp lần 2 (Cohort)</div>
                                <div class="display-5 text-civic-green" style="font-weight: 900;">@ViewBag.CohortRepeatRate%</div>
                                <div class="h5 text-muted mb-0" style="font-weight: 500;">Đo lường mức độ tin cậy và gắn kết lâu dài của người dân</div>
                            </div>
                            <div class="avatar avatar-md" style="background-color: #e6f2ee; color: #133B2F;"><i class="bi bi-people-fill fs-2"></i></div>
                        </div>
                    </div>
                </div>
                
                <!-- Word Cloud Card -->
                <div class="col-12" style="height: 200px;">
                    <div class="card h-100 analytics-card">
                        <div class="card-header py-3 bg-transparent">
                            <h3 class="card-title font-weight-bold"><i class="bi bi-cloud me-2 text-civic-gold"></i>Đám mây từ khóa nổi cộm (Word Cloud)</h3>
                        </div>
                        <div class="card-body d-flex flex-wrap align-items-center justify-content-center gap-3">
                            @foreach (var word in ViewBag.WordCloudWords)
                            {
                                var fontSize = 10 + (word.weight * 2.2);
                                string colorStyle = word.weight > 8 ? "color: #133B2F; font-weight: bold;" : (word.weight > 6 ? "color: #D4AF37;" : "color: #64748b;");
                                <span style="@colorStyle font-size: @(fontSize)px; padding: 0 4px; transition: transform 0.2s;">@word.text</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2: Hourly distribution -->
    <div class="row row-cards mb-4">
        <div class="col-lg-8">
            <div class="card analytics-card" style="height: 350px;">
                <div class="card-header bg-transparent py-3">
                    <h3 class="card-title font-weight-bold"><i class="bi bi-clock me-2 text-civic-green"></i>Tần suất phản ánh theo giờ trong ngày</h3>
                </div>
                <div class="card-body p-4">
                    <div style="height: 260px; width: 100%;">
                        <canvas id="hourlyChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bảng xếp hạng cán bộ xuất sắc -->
        <div class="col-lg-4">
            <div class="card analytics-card" style="height: 350px;">
                <div class="card-header bg-transparent py-3">
                    <h3 class="card-title font-weight-bold"><i class="bi bi-trophy-fill me-2 text-civic-gold"></i>Cán bộ xuất sắc của tháng</h3>
                </div>
                <div class="card-body p-0 overflow-y-auto">
                    <div class="list-group list-group-flush border-top-0">
                        @foreach (var official in ViewBag.OfficialsList)
                        {
                            <div class="list-group-item d-flex align-items-center py-3 border-0 border-bottom">
                                <span class="avatar avatar-sm rounded-circle me-3 font-weight-bold" style="background-color: #e6f2ee; color: #133B2F;">@official.FullName.Substring(0, 1)</span>
                                <div class="flex-fill">
                                    <div class="font-weight-bold text-dark">@official.FullName</div>
                                    <div class="text-muted small mt-1">Tỷ lệ đúng hạn: <span class="font-weight-bold" style="color: #0ca678;">98.5%</span></div>
                                </div>
                                <div class="text-right">
                                    <span class="badge" style="background-color: #fff3cd; color: #856404; border: 1px solid #ffeeba;">+15 Giải quyết</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Thiết lập font chữ mặc định chuẩn Tiếng Việt cho biểu đồ
            Chart.defaults.font.family = "'Inter', 'Segoe UI', sans-serif";
            Chart.defaults.color = '#334155';

            // Hourly distribution bar chart
            const hourlyCtx = document.getElementById('hourlyChart').getContext('2d');
            const hourlyCounts = @Html.Raw(Json.Serialize(ViewBag.HourlyCounts));
            const hours = Array.from({length: 24}, (_, i) => i + "h");

            new Chart(hourlyCtx, {
                type: 'bar',
                data: {
                    labels: hours,
                    datasets: [{
                        label: 'Số phản ánh tiếp nhận',
                        data: hourlyCounts,
                        backgroundColor: '#133B2F',
                        borderRadius: 4,
                        barPercentage: 0.6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#eef0f3' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        });
    </script>
}
