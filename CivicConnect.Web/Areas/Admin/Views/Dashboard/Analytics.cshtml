@{
    Layout = "_AdminTablerLayout";
    ViewData["Title"] = "Phân tích chuyên sâu";
}

<!-- Page header -->
<div class="page-header d-print-none mb-4">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title text-2xl font-bold">Phân tích chuyên sâu</h2>
            <div class="text-muted small mt-1">Các chỉ số thống kê nâng cao về phễu xử lý, hành vi công dân và hiệu năng cán bộ</div>
        </div>
    </div>
</div>

<div class="row row-cards mb-4">
    <!-- Phễu chuyển đổi (Funnel) -->
    <div class="col-lg-6">
        <div class="card" style="height: 350px;">
            <div class="card-header py-2 bg-light">
                <h3 class="card-title font-weight-bold"><i class="bi bi-funnel text-primary me-2"></i>Phễu chuyển đổi phản ánh</h3>
            </div>
            <div class="card-body d-flex flex-column justify-content-between py-4">
                @{
                    int countNew = ViewBag.CountNew ?? 5;
                    int countAssigned = ViewBag.CountAssigned ?? 10;
                    int countProcessing = ViewBag.CountProcessing ?? 15;
                    int countClosed = ViewBag.CountClosed ?? 45;
                    int total = countNew + countAssigned + countProcessing + countClosed;
                    if (total == 0) total = 100;
                    int pctNew = (countNew * 100) / total;
                    int pctAssigned = ((countNew + countAssigned) * 100) / total;
                    int pctProcessing = ((countNew + countAssigned + countProcessing) * 100) / total;
                    int pctClosed = 100;
                }
                <!-- Funnel Visual Steps -->
                <div class="space-y-3">
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="font-weight-bold">1. Tiếp nhận (Mới)</span>
                            <span class="text-muted">@countNew phản ánh</span>
                        </div>
                        <div class="progress progress-md" style="height: 18px;">
                            <div class="progress-bar bg-blue" style="width: 100%">100%</div>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="font-weight-bold">2. Đã phân công cán bộ</span>
                            <span class="text-muted">@countAssigned phản ánh</span>
                        </div>
                        <div class="progress progress-md" style="height: 18px;">
                            <div class="progress-bar bg-indigo" style="width: 85%">85%</div>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="font-weight-bold">3. Đang xử lý</span>
                            <span class="text-muted">@countProcessing phản ánh</span>
                        </div>
                        <div class="progress progress-md" style="height: 18px;">
                            <div class="progress-bar bg-yellow" style="width: 68%">68%</div>
                        </div>
                    </div>
                    <div>
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="font-weight-bold">4. Giải quyết & Đóng</span>
                            <span class="text-muted">@countClosed phản ánh</span>
                        </div>
                        <div class="progress progress-md" style="height: 18px;">
                            <div class="progress-bar bg-green" style="width: 58%">58%</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cohort Analysis & Word Cloud -->
    <div class="col-lg-6">
        <div class="row row-cards" style="height: 350px;">
            <!-- Cohort Repeat Rate -->
            <div class="col-12" style="height: 130px;">
                <div class="card h-100">
                    <div class="card-body d-flex align-items-center justify-content-between">
                        <div>
                            <div class="text-muted small uppercase font-weight-bold">Tỷ lệ công dân gửi tiếp lần 2 (Cohort)</div>
                            <div class="display-5 font-weight-bold mt-1 text-primary">@ViewBag.CohortRepeatRate%</div>
                            <div class="text-xs text-muted mt-1">Đo lường mức độ tin cậy và gắn kết lâu dài của người dân</div>
                        </div>
                        <div class="avatar avatar-md bg-blue-lt text-blue"><i class="bi bi-people-fill fs-2"></i></div>
                    </div>
                </div>
            </div>
            
            <!-- Word Cloud Card -->
            <div class="col-12" style="height: 200px;">
                <div class="card h-100">
                    <div class="card-header py-1.5 bg-light">
                        <h3 class="card-title font-weight-bold"><i class="bi bi-cloud text-primary me-2"></i>Đám mây từ khóa nổi cộm (Word Cloud)</h3>
                    </div>
                    <div class="card-body d-flex flex-wrap align-items-center justify-content-center gap-3">
                        @foreach (var word in ViewBag.WordCloudWords)
                        {
                            var fontSize = 10 + (word.weight * 2.2);
                            var color = word.weight > 8 ? "text-danger font-weight-bold" : (word.weight > 6 ? "text-primary" : "text-muted");
                            <span class="@color" style="font-size: @(fontSize)px;">@word.text</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Row 2: Hourly distribution -->
<div class="row row-cards mb-4">
    <div class="col-lg-8">
        <div class="card" style="height: 350px;">
            <div class="card-header py-2 bg-light">
                <h3 class="card-title font-weight-bold"><i class="bi bi-clock text-primary me-2"></i>Tần suất phản ánh theo giờ trong ngày</h3>
            </div>
            <div class="card-body">
                <div style="height: 270px; width: 100%;">
                    <canvas id="hourlyChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Bảng xếp hạng cán bộ xuất sắc -->
    <div class="col-lg-4">
        <div class="card" style="height: 350px;">
            <div class="card-header py-2 bg-light">
                <h3 class="card-title font-weight-bold"><i class="bi bi-trophy text-yellow me-2"></i>Cán bộ xuất sắc của tháng</h3>
            </div>
            <div class="card-body p-0 overflow-y-auto">
                <div class="list-group list-group-flush">
                    @foreach (var official in ViewBag.OfficialsList)
                    {
                        <div class="list-group-item d-flex align-items-center py-2.5">
                            <span class="avatar avatar-sm bg-blue-lt text-blue rounded-circle me-3">@official.FullName.Substring(0, 1)</span>
                            <div class="flex-fill">
                                <div class="font-weight-bold">@official.FullName</div>
                                <div class="text-muted small">Tỷ lệ đúng hạn: <span class="text-green font-weight-bold">98.5%</span></div>
                            </div>
                            <div class="text-right">
                                <span class="badge bg-green-lt">+15 Giải quyết</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Hourly distribution bar chart
            const hourlyCtx = document.getElementById('hourlyChart').getContext('2d');
            const hourlyCounts = @Html.Raw(Json.Serialize(ViewBag.HourlyCounts));
            const hours = Array.from({length: 24}, (_, i) => i + "h");

            new Chart(hourlyCtx, {
                type: 'bar',
                data: {
                    labels: hours,
                    datasets: [{
                        label: 'Số phản ánh tiếp nhận',
                        data: hourlyCounts,
                        backgroundColor: '#206bc4',
                        borderRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#eef0f3' } },
                        x: { grid: { display: false } }
                    }
                }
            });
        });
    </script>
}
