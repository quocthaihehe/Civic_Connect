@model IEnumerable<CivicConnect.Web.Models.Entities.Issue>
@using CivicConnect.Web.Models.Enums
@{
    Layout = "_AdminTablerLayout";
    ViewData["Title"] = "Tổng quan điều hành";
}

<style>
    .card {
        border: 1px solid #CCCCCC !important;
        border-radius: 8px !important;
        box-shadow: none !important;
    }
    .card-header {
        border-bottom: 1px solid #e2e8f0;
    }
</style>

<!-- Page header -->
<div class="page-header d-print-none mb-2 mt-1">
    <div class="row align-items-center">
        <div class="col">
            <h2 class="page-title text-2xl font-bold">Tổng quan điều hành</h2>
            <div class="text-muted small mt-1">Hệ thống thông tin chỉ đạo và giám sát phản ánh hiện trường</div>
        </div>
    </div>
</div>

<!-- Row 1: KPI Stats Cards -->
<div class="row row-cards mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card card-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <span class="bg-blue text-white avatar"><i class="bi bi-file-earmark-text"></i></span>
                    </div>
                    <div class="col">
                        <div class="font-weight-bold text-lg">@ViewBag.NewToday phản ánh</div>
                        <div class="text-muted small">
                            Mới nhận hôm nay
                            <span class="@(ViewBag.CompareYesterdayPct >= 0 ? "text-green" : "text-red") d-inline-flex align-items-center">
                                (@(ViewBag.CompareYesterdayPct >= 0 ? "+" : "")@ViewBag.CompareYesterdayPct%)
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card card-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <span class="bg-yellow text-white avatar"><i class="bi bi-arrow-repeat"></i></span>
                    </div>
                    <div class="col">
                        <div class="font-weight-bold text-lg">@ViewBag.ProcessingCount phản ánh</div>
                        <div class="text-muted small">Đang xử lý (nhiều nhất ở @ViewBag.TopUnitName)</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card card-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <span class="bg-red text-white avatar"><i class="bi bi-clock-history"></i></span>
                    </div>
                    <div class="col">
                        <div class="font-weight-bold text-lg text-danger">@ViewBag.OverdueCount phản ánh</div>
                        <div class="text-muted small">Quá hạn chưa giải quyết</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card card-sm">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <span class="bg-green text-white avatar"><i class="bi bi-star"></i></span>
                    </div>
                    <div class="col">
                        <div class="font-weight-bold text-lg">@ViewBag.AvgSatisfaction / 5.0</div>
                        <div class="text-muted small">Hài lòng TB tuần qua</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Row 2: Charts and Widgets -->
<div class="row row-cards mb-4 align-items-stretch">
    <!-- Cột Trái: Trend Line + Heatmap -->
    <div class="col-lg-8 d-flex flex-column">
        <div class="card flex-grow-1">
            <div class="card-header border-0 py-2">
                <ul class="nav nav-tabs card-header-tabs" data-bs-toggle="tabs">
                    <li class="nav-item">
                        <a href="#tabs-trend" class="nav-link active font-weight-bold" data-bs-toggle="tab"><i class="bi bi-graph-up text-primary me-2"></i>Xu hướng 30 ngày</a>
                    </li>
                    <li class="nav-item">
                        <a href="#tabs-heatmap" class="nav-link font-weight-bold" data-bs-toggle="tab"><i class="bi bi-map text-danger me-2"></i>Bản đồ điểm nóng</a>
                    </li>
                </ul>
            </div>
            <div class="card-body d-flex flex-column">
                <div class="tab-content flex-grow-1 d-flex flex-column">
                    <div class="tab-pane active show flex-grow-1" id="tabs-trend">
                        <div class="position-relative w-100 h-100" style="min-height: 420px;">
                            <canvas id="trendChart"></canvas>
                        </div>
                    </div>
                    <div class="tab-pane flex-grow-1" id="tabs-heatmap">
                        <div id="heatmapContainer" class="w-100 h-100" style="min-height: 420px; z-index: 1;"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cột Phải: Online Staff, Gauge, Pie -->
    <div class="col-lg-4 d-flex flex-column gap-3">
        <!-- Online Staff -->
        <div class="card" style="height: 250px;">
            <div class="card-header bg-transparent border-0 py-2">
                <h3 class="card-title font-weight-bold mb-0" style="font-size: 0.95rem;"><i class="bi bi-person-badge text-primary me-2"></i>Người dùng trực tuyến</h3>
            </div>
            <div class="card-body overflow-y-auto py-2">
                <div class="space-y-2">
                    @foreach (var staff in ViewBag.OnlineStaff)
                    {
                        <div class="row align-items-center g-2">
                            <div class="col-auto">
                                <span class="avatar avatar-sm bg-green-lt text-green rounded-circle">@staff.FullName.Substring(0, 1)</span>
                            </div>
                            <div class="col">
                                <div class="font-weight-bold text-truncate" style="font-size: 0.85rem;">@staff.FullName</div>
                            </div>
                            <div class="col-auto">
                                <span class="badge badge-empty" title="Đang online" style="background-color: #16a34a !important;"></span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Gauge & Pie -->
        <div class="card flex-grow-1">
            <div class="card-body p-3 d-flex flex-column justify-content-around">
                <!-- Gauge -->
                <div class="text-center mb-2">
                    <div class="text-muted small font-weight-bold mb-1">TỶ LỆ GIẢI QUYẾT ĐÚNG HẠN</div>
                    <div class="position-relative mx-auto d-flex align-items-center justify-content-center" style="width: 140px; height: 140px;">
                        <canvas id="slaGaugeCanvas"></canvas>
                        <div class="position-absolute text-center" style="top: 55px;">
                            <span class="font-weight-bold" style="font-size: 1.5rem;">@ViewBag.SlaComplianceRate%</span>
                        </div>
                    </div>
                </div>
                <hr class="my-2" />
                <!-- Pie -->
                <div class="text-center mt-2">
                    <div class="text-muted small font-weight-bold mb-2">CƠ CẤU DANH MỤC</div>
                    <div class="mx-auto" style="height: 160px; width: 100%;">
                        <canvas id="categoryChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Row 3: Action Table -->
<div class="row row-cards">
    <!-- Critical Issues Table -->
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-transparent border-0 py-3 d-flex justify-content-between align-items-center">
                <h3 class="card-title font-weight-bold"><i class="bi bi-lightning text-danger me-2"></i>Phản ánh cần hành động ngay</h3>
                <span class="badge bg-orange text-white px-2 py-1">Hạn xử lý khẩn cấp</span>
            </div>
            <div class="table-responsive" style="max-height: 400px;">
                <table class="table table-vcenter table-hover mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Tiêu đề</th>
                            <th>Độ khẩn</th>
                            <th>Đơn vị</th>
                            <th>Hạn xử lý</th>
                            <th class="w-1">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">Không có phản ánh khẩn cấp nào cần hành động ngay</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var issue in Model)
                            {
                                var isOverdue = issue.DueDate < DateTime.UtcNow;
                                <tr class="@(isOverdue ? "bg-red-lt" : "")">
                                    <td>#@issue.Id</td>
                                    <td>
                                        <a href="/Admin/Issues/Details/@issue.Id" class="font-weight-bold text-body text-decoration-none">@issue.Title</a>
                                        <div class="text-muted small">@issue.Address</div>
                                    </td>
                                    <td>
                                        <span class="badge @(issue.Priority == IssuePriority.Critical ? "bg-red" : "bg-orange") text-white">
                                            @issue.Priority
                                        </span>
                                    </td>
                                    <td>@(issue.AssignedUnit?.Name ?? "Chưa phân công")</td>
                                    <td class="@(isOverdue ? "text-danger font-weight-bold" : "")">
                                        @issue.DueDate?.ToString("dd/MM/yyyy HH:mm")
                                        @if (isOverdue)
                                        {
                                            <span class="d-block small text-danger font-weight-bold">(Quá hạn)</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-list flex-nowrap">
                                            <a href="/Admin/Issues/Details/@issue.Id" class="btn btn-outline-primary btn-sm">Chỉ đạo</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Thiết lập font chữ mặc định chuẩn Tiếng Việt cho toàn bộ biểu đồ
            Chart.defaults.font.family = "'Inter', 'Segoe UI', sans-serif";
            Chart.defaults.color = '#334155';
            
            // Re-render map when tab becomes active
            $('a[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                if (e.target.hash === '#tabs-heatmap') {
                    map.invalidateSize();
                }
            });
            
            // Trend Line Chart
            const trendCtx = document.getElementById('trendChart').getContext('2d');
            const trendLabels = @Html.Raw(Json.Serialize(ViewBag.TrendLabels));
            const trendValues = @Html.Raw(Json.Serialize(ViewBag.TrendValues));
            
            new Chart(trendCtx, {
                type: 'line',
                data: {
                    labels: trendLabels.length > 0 ? trendLabels : ['D1', 'D2', 'D3', 'D4', 'D5'],
                    datasets: [{
                        label: 'Số phản ánh tiếp nhận',
                        data: trendValues.length > 0 ? trendValues : [2, 5, 8, 4, 10],
                        borderColor: '#206bc4',
                        backgroundColor: 'rgba(32, 107, 196, 0.05)',
                        fill: true,
                        tension: 0.3,
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { color: '#eef0f3' } },
                        x: { grid: { display: false } }
                    }
                }
            });

            // SLA Gauge Chart
            const gaugeCtx = document.getElementById('slaGaugeCanvas').getContext('2d');
            const compliance = @ViewBag.SlaComplianceRate;
            new Chart(gaugeCtx, {
                type: 'doughnut',
                data: {
                    datasets: [{
                        data: [compliance, 100 - compliance],
                        backgroundColor: ['#2fb344', '#eef0f3'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '80%',
                    rotation: -90,
                    circumference: 180,
                    plugins: { legend: { display: false }, tooltip: { enabled: false } }
                }
            });

            // Categories Chart
            const catCtx = document.getElementById('categoryChart').getContext('2d');
            const catKeys = [];
            const catVals = [];
            @foreach (var entry in ViewBag.CatData)
            {
                var catName = entry.Key switch
                {
                    IssueCategory.Traffic => "Giao thông",
                    IssueCategory.Environment => "Môi trường",
                    IssueCategory.Security => "An ninh",
                    IssueCategory.Infrastructure => "Hạ tầng",
                    IssueCategory.Administration => "Hành chính",
                    _ => "Khác"
                };
                <text>
                    catKeys.push(@Html.Raw(Json.Serialize(catName)));
                    catVals.push(@entry.Value);
                </text>
            }

            new Chart(catCtx, {
                type: 'pie',
                data: {
                    labels: catKeys.length > 0 ? catKeys : ['Giao thông', 'Môi trường', 'An ninh', 'Khác'],
                    datasets: [{
                        data: catVals.length > 0 ? catVals : [12, 15, 6, 4],
                        backgroundColor: ['#206bc4', '#2fb344', '#d63939', '#f76707', '#ae3ec9', '#17a2b8']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { 
                        legend: { 
                            position: 'right', 
                            labels: { 
                                boxWidth: 12, 
                                font: { size: 12, family: "'Inter', sans-serif" } 
                            } 
                        },
                        tooltip: {
                            titleFont: { family: "'Inter', sans-serif" },
                            bodyFont: { family: "'Inter', sans-serif" }
                        }
                    }
                }
            });

            // Leaflet map setup for heatmap spots
            var map = L.map('heatmapContainer').setView([10.7769, 106.7009], 13);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            const hotSpots = @Html.Raw(Json.Serialize(ViewBag.HotSpots));
            hotSpots.forEach(function (spot) {
                L.circle([spot.lat, spot.lng], {
                    color: '#d63939',
                    fillColor: '#d63939',
                    fillOpacity: 0.5,
                    radius: 120
                }).addTo(map).bindPopup(spot.title);
            });

            // Update map size when tab is shown
            $('a[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
                if (e.target.hash === '#tabs-heatmap') {
                    setTimeout(function() {
                        map.invalidateSize();
                    }, 10);
                }
            });
        });
    </script>
}
