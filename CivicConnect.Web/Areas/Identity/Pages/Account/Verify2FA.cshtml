@page
@model Verify2FAModel
@{
    Layout = null;
    ViewData["Title"] = "Xác thực hai lớp (2FA)";
    var systemOtp = TempData["2FA_OtpCode"]?.ToString();
    TempData.Keep("2FA_OtpCode");
    TempData.Keep("2FA_UserId");
    TempData.Keep("2FA_ReturnUrl");
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login-modern.css" asp-append-version="true" />
    
    <style>
        .letter-spacing-md { letter-spacing: 4px; }
        .soft-login-card { padding: 2rem !important; }
        .qr-placeholder { background: rgba(16, 185, 129, 0.1); border-radius: 12px; padding: 20px; display: inline-block; }
    </style>
</head>
<body class="login-body-custom">
    <div class="login-wrapper">
        <div class="bg-blob blob-1"></div>
        <div class="bg-blob blob-2"></div>
        <div class="bg-blob blob-3"></div>
        <div class="bg-blob blob-4"></div>

        <div class="soft-login-card">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-circle" style="width: 70px; height: 70px; background: var(--primary-500); box-shadow: 0 4px 12px rgba(27, 77, 62, 0.15);">
                    <i class="bi bi-shield-lock-fill text-white" style="font-size: 2.2rem;"></i>
                </div>
                <h3 class="fw-bold">Xác thực 2FA</h3>
                <p class="card-subtitle-custom">
                    Tài khoản của bạn đang sử dụng xác thực qua
                    <strong class="text-primary">@Model.TwoFactorType</strong>.
                </p>
                @if (Model.TwoFactorType != "Authenticator")
                {
                    <div class="badge bg-secondary text-wrap py-2 px-3 mt-1" style="font-size: 0.8rem;">
                        Gửi đến: @Model.MaskedContact
                    </div>
                }
                else
                {
                    <div class="mt-4 mb-3 text-center">
                        <div id="qrCode" class="qr-placeholder mb-3 d-inline-block p-2 bg-white" style="border: 1px solid #e2e8f0;"></div>
                    </div>
                }
            </div>

            <form asp-page="./Verify2FA" asp-route-returnUrl="@Model.ReturnUrl" method="post" id="loginForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size: 0.85rem; background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.2); color: #b91c1c;" role="alert"></div>

                <div class="form-group-modern mb-4">
                    <label asp-for="Input.OtpCode" class="form-label-modern" style="text-align: center; display: block;">Nhập mã xác thực 6 số:</label>
                    <div class="input-group-modern">
                        <span class="input-icon-left"><i class="bi bi-key-fill"></i></span>
                        <input asp-for="Input.OtpCode" class="form-control-modern text-center fw-bold fs-4 letter-spacing-md" placeholder="000000" maxlength="6" required autocomplete="one-time-code" autofocus />
                    </div>
                    <span asp-validation-for="Input.OtpCode" class="text-danger d-block text-center mt-1" style="font-size: 0.75rem;"></span>
                </div>

                <button type="submit" class="btn-submit-modern mb-3"><i class="bi bi-unlock-fill me-1"></i> Xác Nhận</button>
                
                <div class="text-center">
                    <a asp-page="./Login" class="text-link-bright text-decoration-none" style="font-size: 0.8rem;">
                        <i class="bi bi-arrow-left"></i> Quay lại trang Đăng nhập
                    </a>
                </div>
            </form>

            @if (Model.TwoFactorType != "Authenticator" && !string.IsNullOrEmpty(systemOtp))
            {
                <div class="mt-4 pt-3" style="border-top: 1px solid rgba(0,0,0,0.05);">
                    <div class="alert py-2 mb-0 text-center" style="font-size: 0.75rem; background: rgba(59, 130, 246, 0.08); border: 1px dashed rgba(59, 130, 246, 0.3); color: #1e3a8a;">
                        <strong>Môi trường phát triển:</strong> OTP là <code class="text-danger fw-bold fs-6 letter-spacing-md">@systemOtp</code>
                    </div>
                </div>
            }
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    
    @if (Model.TwoFactorType == "Authenticator" && !string.IsNullOrEmpty(Model.AuthenticatorUri))
    {
        <script type="text/javascript">
            new QRCode(document.getElementById("qrCode"), {
                text: "@Html.Raw(Model.AuthenticatorUri)",
                width: 150,
                height: 150,
                colorDark : "#111827",
                colorLight : "#ffffff",
                correctLevel : QRCode.CorrectLevel.M
            });
        </script>
    }
</body>
</html>
