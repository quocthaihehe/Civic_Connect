@page
@model ResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Đặt lại mật khẩu - CivicConnect";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login-modern.css" asp-append-version="true" />
</head>
<body class="login-body-custom">

    <div class="login-wrapper">
        <div class="bg-blob blob-1"></div>
        <div class="bg-blob blob-2"></div>
        <div class="bg-blob blob-3"></div>
        <div class="bg-blob blob-4"></div>

        <div class="soft-login-card">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-circle" style="width: 88px; height: 88px; background: var(--primary-500); box-shadow: 0 4px 12px rgba(27, 77, 62, 0.15);">
                    <i class="bi bi-key-fill text-white" style="font-size: 2.5rem;"></i>
                </div>
                <h3 class="fw-bold">Đặt lại mật khẩu</h3>
                @if (TempData["ResetContact"] != null)
                {
                    <p class="text-success small fw-semibold mb-0" style="font-size: 0.85rem;">
                        <i class="bi bi-check-circle-fill me-1"></i> Mã OTP đã gửi tới: @TempData["ResetContact"]
                    </p>
                }
                else
                {
                    <p class="card-subtitle-custom">Nhập mã OTP và mật khẩu mới của bạn</p>
                }
            </div>

            <form asp-page="./ResetPassword" method="post" id="resetForm">
                <div asp-validation-summary="All" class="alert alert-danger py-2" style="font-size: 0.85rem; background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.2); color: #b91c1c;" role="alert"></div>

                <!-- OTP Code Field -->
                <div class="form-group-modern">
                    <label asp-for="Input.OtpCode" class="form-label-modern">Mã xác thực OTP (6 chữ số)</label>
                    <div class="input-group-modern">
                        <span class="input-icon-left"><i class="bi bi-shield-check"></i></span>
                        <input asp-for="Input.OtpCode" class="form-control-modern text-center fw-bold" placeholder="••••••" maxlength="6" autocomplete="off" required style="letter-spacing: 4px; font-size: 1.1rem;" />
                    </div>
                    <span asp-validation-for="Input.OtpCode" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <!-- New Password Field -->
                <div class="form-group-modern">
                    <label asp-for="Input.NewPassword" class="form-label-modern">Mật khẩu mới (Tối thiểu 8 ký tự)</label>
                    <div class="input-group-modern">
                        <span class="input-icon-left"><i class="bi bi-lock"></i></span>
                        <input asp-for="Input.NewPassword" id="password-new" class="form-control-modern" type="password" placeholder="••••••••" required />
                        <button type="button" class="btn-toggle-password" onclick="togglePassword('password-new', 'toggleIcon1')">
                            <i class="bi bi-eye" id="toggleIcon1"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.NewPassword" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <!-- Confirm Password Field -->
                <div class="form-group-modern">
                    <label asp-for="Input.ConfirmPassword" class="form-label-modern">Xác nhận mật khẩu mới</label>
                    <div class="input-group-modern">
                        <span class="input-icon-left"><i class="bi bi-lock-fill"></i></span>
                        <input asp-for="Input.ConfirmPassword" id="password-confirm" class="form-control-modern" type="password" placeholder="••••••••" required />
                        <button type="button" class="btn-toggle-password" onclick="togglePassword('password-confirm', 'toggleIcon2')">
                            <i class="bi bi-eye" id="toggleIcon2"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <button type="submit" class="btn-submit-modern mt-2">Cập Nhật Mật Khẩu</button>
            </form>

            <div class="text-center mt-4" style="font-size: 0.85rem;">
                <span class="text-muted">Quay lại trang </span>
                <a asp-page="./Login" class="text-link-bright">Đăng nhập</a>
            </div>
        </div>
    </div>

    <!-- JQuery and Bootstrap Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                input.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        }
    </script>
</body>
</html>
