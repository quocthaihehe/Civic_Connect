@page
@model ProfileModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    var successMsg = TempData["SuccessMessage"]?.ToString();
}

<div class="row justify-content-center py-3">
    <div class="col-lg-10">
        @if (!string.IsNullOrEmpty(successMsg))
        {
            <div class="alert alert-success alert-dismissible fade show rounded-3 mb-3 py-2" role="alert" style="font-size: 0.9rem;">
                <i class="bi bi-check-circle-fill me-2"></i> @successMsg
                <button type="button" class="btn-close btn-close-sm" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form asp-page="./Profile" method="post">
            <input type="hidden" asp-for="Input.AvatarUrl" id="avatarUrlInput" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 rounded-3 mb-3" style="font-size: 0.85rem;" role="alert"></div>

            <div class="glass-card p-0 overflow-hidden" style="border-radius: var(--radius-lg);">
                <div class="row g-0">
                    <!-- Cột trái: Avatar -->
                    <div class="col-md-3 d-flex flex-column align-items-center justify-content-center py-4 px-3 position-relative"
                         style="border-right: 1px solid var(--gray-200); background-image: url('/images/nền user.png'); background-size: cover; background-position: center;">
                        <!-- Gradient fade ở dưới để làm nổi chữ mà không làm mờ cả ảnh -->
                        <div class="position-absolute bottom-0 start-0 w-100 h-50" style="background: linear-gradient(to top, rgba(255,255,255,0.95) 0%, rgba(255,255,255,0) 100%);"></div>
                        <div class="position-relative mb-2" style="z-index: 1;">
                            <img src="@(Model.Input.AvatarUrl ?? "/images/default-avatar.png")"
                                 onerror="this.onerror=null; this.src='/images/default-avatar.png';"
                                 class="rounded-circle border border-3"
                                 style="width: 100px; height: 100px; object-fit: cover; border-color: var(--gray-200) !important;"
                                 id="avatar-preview" />
                            <label for="avatarFileInput"
                                   class="position-absolute bottom-0 end-0 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                                   style="width: 30px; height: 30px; cursor: pointer; border: 2px solid white;"
                                   id="avatarLabel">
                                <i class="bi bi-camera-fill" style="font-size: 0.75rem;" id="avatarIcon"></i>
                                <div class="spinner-border spinner-border-sm text-white d-none" id="avatarSpinner" role="status"></div>
                            </label>
                            <input type="file" id="avatarFileInput" class="d-none" accept="image/*" />
                        </div>
                        <h6 class="fw-bold mb-0 mt-1 position-relative" style="font-size: 0.95rem; z-index: 1;">@Model.Input.FullName</h6>
                        <small class="text-muted position-relative d-block" style="font-size: 0.75rem; z-index: 1;" id="avatarStatus">Công dân</small>
                    </div>

                    <!-- Cột phải: Form thông tin -->
                    <div class="col-md-9 p-4">
                        <h5 class="fw-bold mb-3 text-primary" style="font-size: 1rem;">
                            <i class="bi bi-person-gear me-1"></i> Thông tin cá nhân
                        </h5>

                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label asp-for="Input.FullName" class="form-label fw-semibold" style="font-size: 0.8rem;">Họ và tên</label>
                                <input asp-for="Input.FullName" class="form-control form-control-sm rounded-2" placeholder="Nguyễn Văn A" required />
                                <span asp-validation-for="Input.FullName" class="text-danger" style="font-size: 0.7rem;"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="Input.CitizenId" class="form-label fw-semibold" style="font-size: 0.8rem;">CCCD/CMND</label>
                                <input asp-for="Input.CitizenId" class="form-control form-control-sm rounded-2" placeholder="001099123456" />
                                <span asp-validation-for="Input.CitizenId" class="text-danger" style="font-size: 0.7rem;"></span>
                            </div>
                            <div class="col-sm-6">
                                <label asp-for="Input.PhoneNumber" class="form-label fw-semibold" style="font-size: 0.8rem;">Số điện thoại</label>
                                <input asp-for="Input.PhoneNumber" class="form-control form-control-sm rounded-2" placeholder="0901234567" required />
                                <span asp-validation-for="Input.PhoneNumber" class="text-danger" style="font-size: 0.7rem;"></span>
                            </div>
                        </div>

                        <hr class="my-3" style="border-color: var(--gray-200);" />

                        <h6 class="fw-bold mb-3" style="font-size: 0.9rem; color: var(--gray-700);">
                            <i class="bi bi-geo-alt me-1 text-success"></i> Khu vực đăng ký
                        </h6>

                        <div class="row g-3">
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold" style="font-size: 0.8rem;">Tỉnh/Thành phố</label>
                                <select asp-for="Input.ProvinceCode" id="province-select" class="form-select form-select-sm rounded-2" required>
                                    <option value="">Chọn Tỉnh/TP</option>
                                    <option value="79" selected="@(Model.Input.ProvinceCode == "79")">TP. Hồ Chí Minh</option>
                                </select>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold" style="font-size: 0.8rem;">Quận/Huyện</label>
                                <select asp-for="Input.DistrictCode" id="district-select" class="form-select form-select-sm rounded-2" required>
                                    <option value="">Chọn Quận/Huyện</option>
                                </select>
                            </div>
                            <div class="col-sm-4">
                                <label class="form-label fw-semibold" style="font-size: 0.8rem;">Phường/Xã</label>
                                <select asp-for="Input.WardCode" id="ward-select" class="form-select form-select-sm rounded-2" required>
                                    <option value="">Chọn Phường/Xã</option>
                                </select>
                            </div>
                        </div>
                        <span asp-validation-for="Input.WardCode" class="text-danger" style="font-size: 0.7rem;"></span>

                        <div class="mt-3 pt-3 d-flex justify-content-end gap-2" style="border-top: 1px solid var(--gray-200);">
                            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-sm btn-outline-secondary rounded-2 px-3">Hủy Bỏ</a>
                            <button type="submit" class="btn btn-sm btn-primary rounded-2 px-4">Lưu Thay Đổi</button>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // === CLOUDINARY CLIENT-SIDE UPLOAD ===
            const CLOUD_NAME = 'dljilgbhv';
            const UPLOAD_PRESET = 'civic_db';

            $('#avatarFileInput').change(async function() {
                const file = this.files[0];
                if (!file) return;

                if (file.size > 5 * 1024 * 1024) {
                    alert('Ảnh không được vượt quá 5MB');
                    $(this).val('');
                    return;
                }

                // Hiển thị preview ngay
                const reader = new FileReader();
                reader.onload = function(e) {
                    $('#avatar-preview').attr('src', e.target.result);
                }
                reader.readAsDataURL(file);

                // Hiển thị trạng thái đang upload
                $('#avatarIcon').addClass('d-none');
                $('#avatarSpinner').removeClass('d-none');
                $('#avatarStatus').text('Đang tải ảnh lên...').css('color', 'var(--primary-500)');

                try {
                    const formData = new FormData();
                    formData.append('file', file);
                    formData.append('upload_preset', UPLOAD_PRESET);

                    const response = await fetch(`https://api.cloudinary.com/v1_1/${CLOUD_NAME}/image/upload`, {
                        method: 'POST',
                        body: formData
                    });

                    const data = await response.json();

                    if (data.secure_url) {
                        $('#avatarUrlInput').val(data.secure_url);
                        $('#avatar-preview').attr('src', data.secure_url);
                        $('#avatarStatus').text('✓ Ảnh đã sẵn sàng').css('color', 'var(--accent-500)');
                    } else {
                        throw new Error(data.error?.message || 'Upload thất bại');
                    }
                } catch (err) {
                    console.error('Upload error:', err);
                    $('#avatarStatus').text('✗ Lỗi: ' + err.message).css('color', 'var(--danger-500)');
                } finally {
                    $('#avatarIcon').removeClass('d-none');
                    $('#avatarSpinner').addClass('d-none');
                }
            });

            // === CASCADING DROPDOWN ===
            const districts = {
                "79": [
                    { code: "760", name: "Quận 1" },
                    { code: "770", name: "Quận 3" },
                    { code: "774", name: "Quận Bình Thạnh" }
                ]
            };

            const wards = {
                "760": [
                    { code: "26734", name: "Phường Bến Nghé" },
                    { code: "26737", name: "Phường Bến Thành" },
                    { code: "26731", name: "Phường Đa Kao" }
                ],
                "770": [
                    { code: "26797", name: "Phường Võ Thị Sáu" },
                    { code: "26809", name: "Phường 12" }
                ],
                "774": [
                    { code: "27157", name: "Phường 19" },
                    { code: "27159", name: "Phường 22" }
                ]
            };

            const selectedProvince = "@Model.Input.ProvinceCode";
            const selectedDistrict = "@Model.Input.DistrictCode";
            const selectedWard = "@Model.Input.WardCode";

            if (selectedProvince && districts[selectedProvince]) {
                districts[selectedProvince].forEach(d => {
                    const isSel = d.code === selectedDistrict ? "selected" : "";
                    $('#district-select').append(`<option value="${d.code}" ${isSel}>${d.name}</option>`);
                });
            }

            if (selectedDistrict && wards[selectedDistrict]) {
                wards[selectedDistrict].forEach(w => {
                    const isSel = w.code === selectedWard ? "selected" : "";
                    $('#ward-select').append(`<option value="${w.code}" ${isSel}>${w.name}</option>`);
                });
            }

            $('#province-select').change(function() {
                const provId = $(this).val();
                $('#district-select').empty().append('<option value="">Chọn Quận/Huyện</option>');
                $('#ward-select').empty().append('<option value="">Chọn Phường/Xã</option>');
                if (districts[provId]) {
                    districts[provId].forEach(d => {
                        $('#district-select').append(`<option value="${d.code}">${d.name}</option>`);
                    });
                }
            });

            $('#district-select').change(function() {
                const distId = $(this).val();
                $('#ward-select').empty().append('<option value="">Chọn Phường/Xã</option>');
                if (wards[distId]) {
                    wards[distId].forEach(w => {
                        $('#ward-select').append(`<option value="${w.code}">${w.name}</option>`);
                    });
                }
            });
        });
    </script>
}
