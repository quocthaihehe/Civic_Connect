@page
@model LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập - CivicConnect";
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login-modern.css" asp-append-version="true" />
</head>
<body class="login-body-custom">

    <div class="login-wrapper">
        <!-- Background Ambient Floating Blobs for extra color overlays -->
        <div class="bg-blob blob-1"></div>
        <div class="bg-blob blob-2"></div>
        <div class="bg-blob blob-3"></div>
        <div class="bg-blob blob-4"></div>

        <!-- Centered Soft UI Login Card (Enlarged, Opaque Watercolor Background) -->
        <div class="soft-login-card">
            <div class="text-center mb-4">
                <!-- Circular Buildings Logo matching the system branding -->
                <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-circle" style="width: 88px; height: 88px; background: var(--primary-500); box-shadow: 0 4px 12px rgba(27, 77, 62, 0.15);">
                    <i class="bi bi-buildings-fill text-white" style="font-size: 2.5rem;"></i>
                </div>
                <h3 class="fw-bold">Đăng nhập</h3>
                <p class="card-subtitle-custom">Cổng thông tin phản ánh và chính quyền đô thị</p>
            </div>

            <form asp-page="./Login" asp-route-returnUrl="@returnUrl" method="post" id="loginForm">
                @if (TempData["StatusMessage"] != null)
                {
                    <div class="alert alert-success py-2 mb-3" style="font-size: 0.85rem; background: rgba(16, 185, 129, 0.08); border: 1px solid rgba(16, 185, 129, 0.2); color: #047857;" role="alert">
                        <i class="bi bi-check-circle-fill me-1"></i> @TempData["StatusMessage"]
                    </div>
                }
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size: 0.85rem; background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.2); color: #b91c1c;" role="alert"></div>

                <div class="form-group-modern">
                    <label asp-for="Input.Email" class="form-label-modern"></label>
                    <div class="input-group-modern">
                        <span class="input-icon-left"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Input.Email" id="email-input" class="form-control-modern" placeholder="nguyenvana@gmail.com" type="email" required autocomplete="username" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="form-group-modern">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Input.Password" class="form-label-modern mb-0"></label>
                        <a asp-page="./ForgotPassword" class="text-link-bright text-decoration-none" style="font-size: 0.75rem;">Quên mật khẩu?</a>
                    </div>
                    <div class="input-group-modern">
                        <span class="input-icon-left"><i class="bi bi-lock"></i></span>
                        <input asp-for="Input.Password" id="password-input" class="form-control-modern" type="password" placeholder="••••••••" required autocomplete="current-password" />
                        <button type="button" class="btn-toggle-password" id="togglePasswordBtn" onclick="togglePasswordVisibility()">
                            <i class="bi bi-eye" id="passwordToggleIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-4 form-check-modern">
                    <input asp-for="Input.RememberMe" class="form-check-input-modern" />
                    <label asp-for="Input.RememberMe" class="form-check-label" style="font-size: 0.85rem; cursor: pointer; color: var(--gray-700);"></label>
                </div>

                <button type="submit" class="btn-submit-modern">Đăng Nhập</button>
            </form>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="text-center my-3 text-muted position-relative d-flex align-items-center justify-content-center">
                    <hr class="w-100" style="border-color: #e2e8f0;" />
                    <span class="position-absolute px-3" style="font-size: 0.8rem; color: #94a3b8; background-color: #ffffff;">Hoặc đăng nhập bằng</span>
                </div>
                <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="w-100 mt-2">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn btn-outline-danger w-100 fw-bold py-2.5 d-flex align-items-center justify-content-center gap-2" name="provider" value="@provider.Name" title="Đăng nhập bằng tài khoản @provider.DisplayName" style="border-radius: 12px; font-size: 0.95rem; border-color: #fca5a5; color: #dc2626; background: #fff5f5; transition: all 0.2s;">
                            <i class="bi bi-google"></i> Đăng nhập bằng Google
                        </button>
                    }
                </form>
            }

            <div class="text-center mt-4" style="font-size: 0.85rem;">
                <span class="text-muted">Chưa có tài khoản? </span>
                <a asp-page="./Register" class="text-link-bright">Đăng ký ngay</a>
            </div>
        </div>
    </div>

    @if (Model.Requires2FAChoice)
    {
        <div class="modal-backdrop-custom" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.4); backdrop-filter: blur(8px); z-index: 9999; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.3s ease;">
            <div class="soft-login-card position-relative" style="max-width: 400px; width: 90%; margin: 0; padding: 2.5rem 2rem !important; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); animation: slideUp 0.4s ease;">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-circle" style="width: 70px; height: 70px; background: var(--primary-500); box-shadow: 0 4px 12px rgba(27, 77, 62, 0.15);">
                        <i class="bi bi-shield-lock-fill text-white" style="font-size: 2.2rem;"></i>
                    </div>
                    <h4 class="fw-bold">Chọn phương thức 2FA</h4>
                    <p class="text-muted" style="font-size: 0.85rem;">Vui lòng chọn kênh nhận mã xác thực để tiếp tục đăng nhập.</p>
                </div>
                
                <div class="d-grid gap-3">
                    <a href="/Identity/Account/Verify2FA?returnUrl=@Model.TempReturnUrl&method=Telegram" class="btn auth-method-btn btn-telegram d-flex align-items-center p-3 rounded-3 text-start">
                        <i class="bi bi-telegram fs-3 me-3 text-primary icon-color"></i>
                        <div>
                            <div class="fw-bold title-text">Qua Telegram</div>
                            <div class="subtitle-text">Nhận mã OTP qua Bot Telegram</div>
                        </div>
                    </a>
                    
                    <a href="/Identity/Account/Verify2FA?returnUrl=@Model.TempReturnUrl&method=Authenticator" class="btn auth-method-btn btn-authenticator d-flex align-items-center p-3 rounded-3 text-start">
                        <i class="bi bi-qr-code-scan fs-3 me-3 text-success icon-color"></i>
                        <div>
                            <div class="fw-bold title-text">Google Authenticator</div>
                            <div class="subtitle-text">Sử dụng mã hiển thị trên App</div>
                        </div>
                    </a>
                </div>

                <div class="text-center mt-4">
                    <a href="/Identity/Account/Login" class="text-muted text-decoration-none" style="font-size: 0.8rem;"><i class="bi bi-arrow-left"></i> Quay lại</a>
                </div>
            </div>
        </div>

        <style>
            .auth-method-btn {
                background: #ffffff;
                border: 1px solid #e2e8f0;
                transition: all 0.2s ease-in-out;
                color: var(--gray-800) !important;
            }
            .auth-method-btn .subtitle-text {
                font-size: 0.75rem;
                color: var(--gray-500);
                transition: color 0.2s;
            }
            
            /* Telegram Hover */
            .auth-method-btn.btn-telegram:hover {
                border-color: #0d6efd;
                background: rgba(13, 110, 253, 0.05);
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(13, 110, 253, 0.1);
            }
            .auth-method-btn.btn-telegram:hover .title-text { color: #0d6efd; }
            
            /* Authenticator Hover */
            .auth-method-btn.btn-authenticator:hover {
                border-color: #198754;
                background: rgba(25, 135, 84, 0.05);
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(25, 135, 84, 0.1);
            }
            .auth-method-btn.btn-authenticator:hover .title-text { color: #198754; }

            @@keyframes fadeIn {
                from { opacity: 0; }
                to { opacity: 1; }
            }
            @@keyframes slideUp {
                from { opacity: 0; transform: translateY(20px); }
                to { opacity: 1; transform: translateY(0); }
            }
        </style>
    }

    <!-- JQuery and Bootstrap Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <!-- Interactive JS Page Logic -->
    <script>
        function togglePasswordVisibility() {
            const passwordInput = document.getElementById('password-input');
            const toggleIcon = document.getElementById('passwordToggleIcon');
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('bi-eye');
                toggleIcon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('bi-eye-slash');
                toggleIcon.classList.add('bi-eye');
            }
        }
    </script>
</body>
</html>
