@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
}

<div class="row justify-content-center align-items-center py-5">
    <div class="col-md-6 col-lg-4">
        <div class="glass-card p-4 p-md-5">
            <div class="text-center mb-4">
                <i class="bi bi-shield-lock text-primary fs-1"></i>
                <h3 class="fw-bold mt-2">Đăng nhập</h3>
                <p class="text-muted" style="font-size: 0.85rem;">Kết nối công dân và chính quyền đô thị</p>
            </div>

            <form asp-page="./Login" asp-route-returnUrl="@returnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size: 0.85rem;" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-semibold" style="font-size: 0.85rem;"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Input.Email" class="form-control border-start-0 ps-0" placeholder="nguyenvana@gmail.com" type="email" required />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Input.Password" class="form-label fw-semibold mb-0" style="font-size: 0.85rem;"></label>
                        <a href="#" class="text-primary text-decoration-none" style="font-size: 0.75rem;">Quên mật khẩu?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-lock"></i></span>
                        <input asp-for="Input.Password" class="form-control border-start-0 ps-0" type="password" placeholder="••••••••" required />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="Input.RememberMe" class="form-check-input" />
                    <label asp-for="Input.RememberMe" class="form-check-label text-muted" style="font-size: 0.85rem;"></label>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill py-2">Đăng Nhập</button>
                </div>
            </form>

            <div class="text-center mt-4" style="font-size: 0.85rem;">
                <span class="text-muted">Chưa có tài khoản? </span>
                <a asp-page="./Register" class="text-primary fw-semibold text-decoration-none">Đăng ký ngay</a>
            </div>
            
            <div class="mt-4 border-top pt-3" style="border-top: 1px solid var(--border-glass) !important;">
                <span class="text-muted d-block text-center mb-2" style="font-size: 0.75rem;">Thông tin tài khoản kiểm thử hệ thống:</span>
                <div class="d-flex flex-column gap-2" style="font-size: 0.75rem;">
                    <div class="p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-glass);">
                        <strong>Công dân:</strong> <code>citizen@gmail.com</code><br/>
                        <span class="text-muted" style="font-size: 0.7rem;">Hành động: Gửi phản ánh, upvote, bình luận.</span>
                    </div>
                    <div class="p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-glass);">
                        <strong>Cán bộ Phường Bến Nghé:</strong> <code>canbo.phuong@gmail.com</code><br/>
                        <span class="text-muted" style="font-size: 0.7rem;">Quy trình tiếp nhận, xử lý, giải quyết và chuyển cấp.</span>
                    </div>
                    <div class="p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-glass);">
                        <strong>Cán bộ Quận 1:</strong> <code>canbo.quan@gmail.com</code><br/>
                        <span class="text-muted" style="font-size: 0.7rem;">Phụ trách các phản ánh chuyển cấp từ Phường.</span>
                    </div>
                    <div class="p-2 rounded-3" style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-glass);">
                        <strong>Quản trị viên:</strong> <code>admin@gmail.com</code><br/>
                        <span class="text-muted" style="font-size: 0.7rem;">Quản lý tài khoản (Khoá/Mở khoá) và Cơ quan liên kết.</span>
                    </div>
                    <div class="text-center text-secondary mt-1" style="font-size: 0.75rem;">
                        Mật khẩu đăng nhập chung: <strong class="text-white">Admin@123456</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
