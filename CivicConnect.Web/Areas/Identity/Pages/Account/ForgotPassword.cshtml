@page
@model ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Quên mật khẩu - CivicConnect";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/png" href="~/images/favicon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5 CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login-modern.css" asp-append-version="true" />
    <style>
        .method-selector {
            display: flex;
            background: rgba(0, 0, 0, 0.04);
            border-radius: 8px;
            padding: 4px;
            margin-bottom: 20px;
        }
        .method-btn {
            flex: 1;
            text-align: center;
            padding: 8px 12px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--gray-600);
            transition: all 0.2s;
        }
        .method-btn.active {
            background: white;
            color: var(--primary-500);
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
        }
    </style>
</head>
<body class="login-body-custom">

    <div class="login-wrapper">
        <div class="bg-blob blob-1"></div>
        <div class="bg-blob blob-2"></div>
        <div class="bg-blob blob-3"></div>
        <div class="bg-blob blob-4"></div>

        <div class="soft-login-card">
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center mb-3 rounded-circle" style="width: 88px; height: 88px; background: var(--primary-500); box-shadow: 0 4px 12px rgba(27, 77, 62, 0.15);">
                    <i class="bi bi-shield-lock-fill text-white" style="font-size: 2.5rem;"></i>
                </div>
                <h3 class="fw-bold">Quên mật khẩu?</h3>
                <p class="card-subtitle-custom">Chọn phương thức khôi phục để nhận mã xác thực OTP</p>
            </div>

            <form asp-page="./ForgotPassword" method="post" id="forgotForm">
                <div asp-validation-summary="All" class="alert alert-danger py-2" style="font-size: 0.85rem; background: rgba(239, 68, 68, 0.08); border: 1px solid rgba(239, 68, 68, 0.2); color: #b91c1c;" role="alert"></div>

                <!-- Hidden Input for Recovery Method -->
                <input type="hidden" asp-for="Input.RecoveryMethod" id="recovery-method-input" value="Email" />

                <!-- Method Selector Tabs -->
                <div class="method-selector">
                    <div class="method-btn active" data-method="Email" onclick="selectMethod('Email')">
                        <i class="bi bi-envelope me-1"></i> Qua Gmail
                    </div>
                    <div class="method-btn" data-method="Phone" onclick="selectMethod('Phone')">
                        <i class="bi bi-phone me-1"></i> Số điện thoại
                    </div>
                </div>

                <!-- Dynamic Contact Input -->
                <div class="form-group-modern">
                    <label id="contact-label" class="form-label-modern">Địa chỉ Gmail đăng ký</label>
                    <div class="input-group-modern">
                        <span class="input-icon-left" id="contact-icon"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Input.Contact" id="contact-input" class="form-control-modern" placeholder="nguyenvana@gmail.com" type="email" required />
                    </div>
                    <span asp-validation-for="Input.Contact" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <button type="submit" class="btn-submit-modern mt-2">Gửi Mã Xác Thực OTP</button>
            </form>

            <div class="text-center mt-4" style="font-size: 0.85rem;">
                <span class="text-muted">Quay lại trang </span>
                <a asp-page="./Login" class="text-link-bright">Đăng nhập</a>
            </div>
        </div>
    </div>

    <!-- JQuery and Bootstrap Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        function selectMethod(method) {
            // Update active state of tab buttons
            $('.method-btn').removeClass('active');
            $(`.method-btn[data-method="${method}"]`).addClass('active');

            // Update hidden input
            $('#recovery-method-input').val(method);

            // Update label, icon, placeholder, and type
            if (method === 'Email') {
                $('#contact-label').text('Địa chỉ Gmail đăng ký');
                $('#contact-icon').html('<i class="bi bi-envelope"></i>');
                $('#contact-input').attr('placeholder', 'nguyenvana@gmail.com');
                $('#contact-input').attr('type', 'email');
            } else {
                $('#contact-label').text('Số điện thoại đăng ký');
                $('#contact-icon').html('<i class="bi bi-phone"></i>');
                $('#contact-input').attr('placeholder', '09xxxxxxxx');
                $('#contact-input').attr('type', 'tel');
            }
        }
    </script>
</body>
</html>
