@{
    ViewData["Title"] = "Tổng quan khu vực";
}

<div class="page-header d-print-none">
    <div class="container-xl">
        <div class="row g-2 align-items-center">
            <div class="col">
                <div class="page-pretitle">
                    Báo cáo @ViewBag.TerritoryName
                </div>
                <h2 class="page-title">
                    Tổng quan tình hình Sự cố / Phản ánh
                </h2>
            </div>
            <div class="col-auto ms-auto d-print-none">
                <div class="btn-list">
                    <a href="/Officer/Issues" class="btn btn-primary d-none d-sm-inline-block">
                        <i class="bi bi-list-task me-2"></i> Xử lý phản ánh
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="page-body">
    <div class="container-xl">
        <div class="row row-deck row-cards">
            
            <!-- Cards (Stats) -->
            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="subheader">Tổng số phản ánh</div>
                        </div>
                        <div class="h1 mb-3">@ViewBag.TotalIssues</div>
                        <div class="d-flex mb-2">
                            <div>Trong tháng này</div>
                            <div class="ms-auto">
                                <span class="text-green d-inline-flex align-items-center lh-1">
                                    +@ViewBag.IssuesThisMonth <i class="bi bi-graph-up-arrow ms-1"></i>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="subheader text-danger">Đang chờ tiếp nhận</div>
                        </div>
                        <div class="h1 mb-3">@ViewBag.PendingIssues</div>
                        <div class="d-flex mb-2">
                            <div>Cần phân công / xử lý</div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-danger" style="width: @(ViewBag.TotalIssues > 0 ? (ViewBag.PendingIssues * 100 / ViewBag.TotalIssues) : 0)%"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="subheader text-warning">Đang xử lý</div>
                        </div>
                        <div class="h1 mb-3">@ViewBag.ProcessingIssues</div>
                        <div class="d-flex mb-2">
                            <div>Đã giao cho cán bộ thụ lý</div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-warning" style="width: @(ViewBag.TotalIssues > 0 ? (ViewBag.ProcessingIssues * 100 / ViewBag.TotalIssues) : 0)%"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="subheader text-success">Đã giải quyết</div>
                        </div>
                        <div class="h1 mb-3">@ViewBag.ResolvedIssues</div>
                        <div class="d-flex mb-2">
                            <div>Hoàn thành</div>
                        </div>
                        <div class="progress progress-sm">
                            <div class="progress-bar bg-success" style="width: @(ViewBag.TotalIssues > 0 ? (ViewBag.ResolvedIssues * 100 / ViewBag.TotalIssues) : 0)%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Charts & Lists -->
            <div class="col-lg-8">
                <div class="card h-100">
                    <div class="card-header">
                        <h3 class="card-title">Phân bố Sự cố theo lĩnh vực</h3>
                    </div>
                    <div class="card-body">
                        <canvas id="categoryChart" height="100"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header">
                        <h3 class="card-title">Cần xử lý gấp</h3>
                    </div>
                    <div class="list-group list-group-flush list-group-hoverable">
                        @foreach(var item in ViewBag.RecentPending)
                        {
                            <a href="/Officer/Issues/Details/@item.Id" class="list-group-item list-group-item-action d-flex align-items-center">
                                <span class="avatar bg-danger-lt me-3"><i class="bi bi-exclamation-circle"></i></span>
                                <div class="text-truncate">
                                    <div class="text-body d-block text-truncate">@item.Title</div>
                                    <div class="text-muted fs-sm text-truncate mt-n1">@item.Address</div>
                                </div>
                            </a>
                        }
                        @if(((IEnumerable<dynamic>)ViewBag.RecentPending).Count() == 0)
                        {
                            <div class="list-group-item text-center text-muted">Tuyệt vời, không có sự cố nào tồn đọng.</div>
                        }
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('categoryChart').getContext('2d');
        const categories = @Json.Serialize(ViewBag.Categories);
        const counts = @Json.Serialize(ViewBag.CategoryCounts);
        
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: categories,
                datasets: [{
                    label: 'Số lượng phản ánh',
                    data: counts,
                    backgroundColor: '#0dcaf0',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    </script>
}
