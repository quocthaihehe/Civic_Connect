@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Bảng Vàng Danh Dự";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Helper tính toán huy hiệu dựa trên CitizenPoints
    string GetBadgeLevel(int points)
    {
        if (points >= 1000) return "Bạch Kim";
        if (points >= 500) return "Vàng";
        if (points >= 200) return "Bạc";
        if (points >= 50) return "Đồng";
        return "Tân Binh";
    }

    string GetBadgeColorClass(int points)
    {
        if (points >= 1000) return "bg-dark text-white"; // Bạch Kim
        if (points >= 500) return "bg-warning text-white"; // Vàng
        if (points >= 200) return "bg-secondary text-white"; // Bạc
        if (points >= 50) return "bg-orange text-white"; // Đồng
        return "bg-cyan-lt"; // Tân Binh
    }
}

<div class="container-xl mt-4">
    <!-- Header Hero Section -->
    <div class="card bg-primary text-primary-fg mb-4">
        <div class="card-stamp">
            <div class="card-stamp-icon bg-white text-primary">
                <i class="bi bi-trophy-fill"></i>
            </div>
        </div>
        <div class="card-body">
            <h2 class="card-title text-white fs-1"><i class="bi bi-star-fill text-warning me-2"></i> Bảng Vàng Vinh Danh Công Dân</h2>
            <p class="text-white text-opacity-75 fs-3 w-75">
                Tôn vinh những cá nhân có đóng góp xuất sắc nhất cho cộng đồng thông qua việc gửi phản ánh, tham gia thảo luận và các hoạt động tích cực khác trên CivicConnect.
            </p>
        </div>
    </div>

    <div class="row row-cards">
        <!-- Top 3 Podium -->
        @if (Model != null && Model.Count() >= 3)
        {
            var top1 = Model.ElementAt(0);
            var top2 = Model.ElementAt(1);
            var top3 = Model.ElementAt(2);

            <div class="col-12 mb-4 d-none d-md-block">
                <div class="row align-items-end justify-content-center text-center">
                    
                    <!-- Top 2 -->
                    <div class="col-3">
                        <div class="card bg-silver-lt border-0 shadow-sm" style="transform: translateY(20px);">
                            <div class="card-body">
                                <div class="avatar avatar-xl bg-secondary text-white mb-3 shadow">
                                    <i class="bi bi-person"></i>
                                </div>
                                <h3 class="m-0 mb-1">@top2.FullName</h3>
                                <div class="text-muted mb-2 fs-sm">@top2.UserName</div>
                                <div class="h2 text-secondary fw-bold">@top2.CitizenPoints pts</div>
                                <span class="badge @GetBadgeColorClass(top2.CitizenPoints)">@GetBadgeLevel(top2.CitizenPoints)</span>
                                <div class="mt-3 fw-bold fs-1 text-secondary">#2</div>
                            </div>
                        </div>
                    </div>

                    <!-- Top 1 -->
                    <div class="col-3 mx-2">
                        <div class="card bg-warning-lt border-warning shadow border-3 z-index-1">
                            <div class="card-body py-5">
                                <div class="ribbon ribbon-top bg-warning">
                                    <i class="bi bi-star-fill"></i>
                                </div>
                                <div class="avatar avatar-xl bg-warning text-white mb-3 shadow-lg" style="width: 5rem; height: 5rem;">
                                    <i class="bi bi-person" style="font-size: 2.5rem;"></i>
                                </div>
                                <h2 class="m-0 mb-1 text-warning">@top1.FullName</h2>
                                <div class="text-muted mb-2 fs-sm">@top1.UserName</div>
                                <div class="h1 text-warning fw-bolder mb-2">@top1.CitizenPoints pts</div>
                                <span class="badge @GetBadgeColorClass(top1.CitizenPoints) px-3 py-2 fs-5">@GetBadgeLevel(top1.CitizenPoints)</span>
                                <div class="mt-3 fw-bolder fs-1 text-warning">#1 TOP</div>
                            </div>
                        </div>
                    </div>

                    <!-- Top 3 -->
                    <div class="col-3">
                        <div class="card bg-orange-lt border-0 shadow-sm" style="transform: translateY(40px);">
                            <div class="card-body">
                                <div class="avatar avatar-xl bg-orange text-white mb-3 shadow">
                                    <i class="bi bi-person"></i>
                                </div>
                                <h3 class="m-0 mb-1">@top3.FullName</h3>
                                <div class="text-muted mb-2 fs-sm">@top3.UserName</div>
                                <div class="h2 text-orange fw-bold">@top3.CitizenPoints pts</div>
                                <span class="badge @GetBadgeColorClass(top3.CitizenPoints)">@GetBadgeLevel(top3.CitizenPoints)</span>
                                <div class="mt-3 fw-bold fs-1 text-orange">#3</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Bảng xếp hạng chi tiết -->
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Top Công dân nổi bật</h3>
                </div>
                <div class="table-responsive">
                    <table class="table table-vcenter card-table table-striped">
                        <thead>
                            <tr>
                                <th class="w-1 text-center">Xếp hạng</th>
                                <th>Công dân</th>
                                <th>Huy hiệu</th>
                                <th>Điểm Cống hiến (CitizenPoints)</th>
                                <th>Độ uy tín (TrustScore)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null)
                            {
                                int rank = 1;
                                foreach (var citizen in Model)
                                {
                                    <tr class="@(rank <= 3 ? "fw-bold" : "")">
                                        <td class="text-center text-muted">
                                            @if (rank == 1) { <span class="text-warning fs-2"><i class="bi bi-trophy-fill"></i></span> }
                                            else if (rank == 2) { <span class="text-secondary fs-3"><i class="bi bi-award-fill"></i></span> }
                                            else if (rank == 3) { <span class="text-orange fs-3"><i class="bi bi-award-fill"></i></span> }
                                            else { <span class="fs-4">@rank</span> }
                                        </td>
                                        <td>
                                            <div class="d-flex py-1 align-items-center">
                                                <span class="avatar me-3 bg-blue-lt"><i class="bi bi-person"></i></span>
                                                <div class="flex-fill">
                                                    <div class="font-weight-medium fs-4">@citizen.FullName</div>
                                                    <div class="text-muted fs-sm">@citizen.UserName</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge @GetBadgeColorClass(citizen.CitizenPoints)">@GetBadgeLevel(citizen.CitizenPoints)</span>
                                        </td>
                                        <td class="text-success fs-3">
                                            +@citizen.CitizenPoints <span class="fs-sm text-muted">pts</span>
                                        </td>
                                        <td class="text-primary fs-3">
                                            @citizen.TrustScore <span class="fs-sm text-muted">pts</span>
                                        </td>
                                    </tr>
                                    rank++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
