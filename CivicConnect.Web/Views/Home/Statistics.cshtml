@model CivicConnect.Web.Models.Home.StatisticsViewModel
@{
    ViewData["Title"] = "Thống kê công khai";
}

@section Styles {
    <style>
        .stat-card {
            border: none;
            border-radius: 1rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
            background: var(--bg-card, #ffffff);
            overflow: hidden;
            position: relative;
        }
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }
        .stat-icon {
            font-size: 2.5rem;
            opacity: 0.2;
            position: absolute;
            right: 1.5rem;
            top: 1.5rem;
        }
        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary, #111827);
        }
        .stat-label {
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-secondary, #6b7280);
            font-weight: 600;
        }
        .chart-container {
            position: relative;
            height: 400px;
            width: 100%;
        }
        .bg-gradient-primary {
            background: linear-gradient(135deg, #4f46e5 0%, #3b82f6 100%);
            color: white !important;
        }
        .bg-gradient-success {
            background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
            color: white !important;
        }
        .bg-gradient-warning {
            background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
            color: white !important;
        }
        [data-theme="dark"] .stat-card {
            background: var(--bg-surface, #1f2937);
        }
        [data-theme="dark"] .stat-value {
            color: var(--text-primary-dark, #f9fafb);
        }
    </style>
}

<div class="container py-5">
    <div class="row mb-5 text-center">
        <div class="col-12">
            <h1 class="display-5 fw-bold mb-3" style="color: var(--primary-color);">Dashboard Thống Kê</h1>
            <p class="lead text-muted">Tổng quan số liệu phản ánh từ người dân trên toàn hệ thống.</p>
        </div>
    </div>

    <!-- Overview Cards -->
    <div class="row g-4 mb-5">
        <!-- Total Issues -->
        <div class="col-md-4">
            <div class="stat-card p-4 h-100">
                <i class="bi bi-file-earmark-text stat-icon text-primary"></i>
                <div class="stat-label mb-2">Tổng số phản ánh</div>
                <div class="stat-value">@Model.TotalIssues.ToString("N0")</div>
                <div class="mt-3 text-muted small">
                    Toàn bộ phản ánh đã được tiếp nhận
                </div>
            </div>
        </div>

        <!-- Resolved Percentage -->
        <div class="col-md-4">
            <div class="stat-card p-4 h-100">
                <i class="bi bi-check-circle stat-icon text-success"></i>
                <div class="stat-label mb-2">Tỷ lệ giải quyết</div>
                <div class="stat-value text-success">@Model.ResolvedPercentage.ToString("0.0")%</div>
                <div class="mt-3 text-muted small">
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: @Math.Round(Model.ResolvedPercentage)%;" aria-valuenow="@Math.Round(Model.ResolvedPercentage)" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Average Processing Time -->
        <div class="col-md-4">
            <div class="stat-card p-4 h-100">
                <i class="bi bi-clock-history stat-icon text-warning"></i>
                <div class="stat-label mb-2">Thời gian xử lý TB</div>
                <div class="stat-value text-warning">@Model.AverageProcessingHours.ToString("0.0") <span style="font-size: 1rem; font-weight: 500;">giờ</span></div>
                <div class="mt-3 text-muted small">
                    Tính trên các phản ánh đã giải quyết
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row mb-5">
        <div class="col-12">
            <div class="card stat-card p-4">
                <h4 class="mb-4">Phân bố phản ánh theo lĩnh vực</h4>
                <div class="chart-container">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const ctx = document.getElementById('categoryChart').getContext('2d');
            
            // Lấy dữ liệu từ Model
            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.IssuesByCategory.Keys));
            const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.IssuesByCategory.Values));
            
            // Xử lý màu sắc
            const backgroundColors = [
                'rgba(59, 130, 246, 0.7)', // blue
                'rgba(16, 185, 129, 0.7)', // emerald
                'rgba(245, 158, 11, 0.7)', // amber
                'rgba(239, 68, 68, 0.7)',  // red
                'rgba(139, 92, 246, 0.7)', // violet
                'rgba(107, 114, 128, 0.7)' // gray
            ];
            
            const borderColors = [
                'rgb(59, 130, 246)',
                'rgb(16, 185, 129)',
                'rgb(245, 158, 11)',
                'rgb(239, 68, 68)',
                'rgb(139, 92, 246)',
                'rgb(107, 114, 128)'
            ];

            const categoryChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Số lượng phản ánh',
                        data: data,
                        backgroundColor: backgroundColors.slice(0, data.length),
                        borderColor: borderColors.slice(0, data.length),
                        borderWidth: 1,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        },
                        tooltip: {
                            backgroundColor: 'rgba(17, 24, 39, 0.9)',
                            titleFont: { size: 14, family: "'Inter', sans-serif" },
                            bodyFont: { size: 14, family: "'Inter', sans-serif" },
                            padding: 12,
                            cornerRadius: 8
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(156, 163, 175, 0.1)',
                                drawBorder: false
                            },
                            ticks: {
                                precision: 0,
                                font: { family: "'Inter', sans-serif" }
                            }
                        },
                        x: {
                            grid: {
                                display: false
                            },
                            ticks: {
                                font: { family: "'Inter', sans-serif" }
                            }
                        }
                    }
                }
            });
            
            // Xử lý thay đổi theme (Dark mode / Light mode) nếu ứng dụng có hỗ trợ
            const observer = new MutationObserver(function(mutations) {
                mutations.forEach(function(mutation) {
                    if (mutation.attributeName === "data-theme") {
                        const theme = document.documentElement.getAttribute('data-theme');
                        const isDark = theme === 'dark';
                        
                        // Update chart colors
                        const textColor = isDark ? '#9ca3af' : '#4b5563';
                        const gridColor = isDark ? 'rgba(75, 85, 99, 0.2)' : 'rgba(156, 163, 175, 0.1)';
                        
                        categoryChart.options.scales.x.ticks.color = textColor;
                        categoryChart.options.scales.y.ticks.color = textColor;
                        categoryChart.options.scales.y.grid.color = gridColor;
                        
                        categoryChart.update();
                    }
                });
            });
            
            observer.observe(document.documentElement, { attributes: true });
            
            // Khởi tạo màu ban đầu theo theme
            const isDarkInit = document.documentElement.getAttribute('data-theme') === 'dark';
            if (isDarkInit) {
                const textColor = '#9ca3af';
                const gridColor = 'rgba(75, 85, 99, 0.2)';
                categoryChart.options.scales.x.ticks.color = textColor;
                categoryChart.options.scales.y.ticks.color = textColor;
                categoryChart.options.scales.y.grid.color = gridColor;
                categoryChart.update();
            }
        });
    </script>
}
