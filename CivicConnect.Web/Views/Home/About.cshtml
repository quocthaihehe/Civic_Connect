@{
    ViewData["Title"] = "Giới thiệu nền tảng Civic Connect";
    ViewData["IsFullWidth"] = true;
}

<style>
    /* Full page wrapper background */
    .about-page-wrapper {
        background: url('/images/nền Giới thiệu.png') no-repeat top center;
        background-size: cover;
        background-attachment: fixed;
        min-height: calc(100vh - 70px); /* adjust for header */
        margin: 0;
        padding: 1rem;
    }
    
    .about-card {
        background-color: #FDFBF7;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        border: 1px solid rgba(0,0,0,0.03);
        height: 100%;
    }
    .about-title {
        color: #133B2F;
        font-family: 'EB Garamond', serif;
        font-weight: bold;
        margin-bottom: 25px;
        font-size: 1.3rem;
    }
    .feature-icon-box {
        width: 44px; height: 44px;
        border-radius: 50%;
        background-color: rgba(19, 59, 47, 0.08);
        display: flex; align-items: center; justify-content: center;
        color: #133B2F; font-size: 1.2rem;
        margin: 0 auto 10px auto;
    }
    .stat-number {
        font-size: 1.4rem;
        font-weight: bold;
        color: #133B2F;
        margin-bottom: 5px;
    }
    .step-arrow {
        color: #ccc;
        font-size: 1rem;
        margin-top: 12px;
        flex-shrink: 0;
    }
    .step-item {
        flex: 1;
        min-width: 0;
    }
    .step-item p {
        font-size: 0.65rem;
        line-height: 1.3;
        margin-top: 4px;
    }
    .step-item h6 {
        font-size: 0.75rem;
        margin-bottom: 0;
        white-space: normal;
    }
    
    @@media (min-width: 768px) {
        .about-page-wrapper {
            padding: 1rem 2rem 3rem 2rem;
        }
    }
    @@media (min-width: 1200px) {
        .about-page-wrapper {
            padding: 1rem 4rem 4rem 4rem;
        }
    }
</style>

<div class="about-page-wrapper">
    <!-- Hero Section -->
    <div class="row mb-4 position-relative mx-0" style="min-height: 400px; border-radius: 24px; background-color: #FDFBF7; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.03);">
        <div class="position-absolute top-0 end-0 h-100" style="width: 65%; background: url('/images/nền vinh danh.png') no-repeat right bottom; background-size: cover; -webkit-mask-image: linear-gradient(to right, transparent 0%, black 50%); mask-image: linear-gradient(to right, transparent 0%, black 50%); opacity: 0.95; pointer-events: none;"></div>
        
        <div class="col-lg-6 position-relative z-index-1 d-flex flex-column justify-content-center p-4 p-md-5">
            <h1 class="display-4 fw-bold mb-3" style="color: #133B2F; font-family: 'EB Garamond', serif;">Civic Connect</h1>
            <h5 class="mb-4" style="color: #1E5C4A; font-family: 'EB Garamond', serif; font-style: italic;">Đồng hành cùng bạn xây dựng đô thị văn minh, hiện đại và nhân văn.</h5>
            <p class="mb-4 text-muted" style="line-height: 1.6; font-size: 1.05rem; max-width: 95%;">
                Civic Connect là cầu nối vững chắc giữa người dân và chính quyền địa phương, hướng tới xây dựng một đô thị thông minh, minh bạch và phát triển bền vững.
            </p>
            <div class="d-flex flex-wrap gap-3 mt-2">
                <div class="d-flex align-items-center gap-2 me-3">
                    <i class="bi bi-shield-check fs-5" style="color: #133B2F;"></i>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">Minh bạch</div>
                        <div class="small text-muted" style="font-size: 0.75rem;">Thông tin công khai,<br>rõ ràng, dễ tiếp cận</div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2 me-3">
                    <i class="bi bi-lightning-charge fs-5" style="color: #133B2F;"></i>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">Nhanh chóng</div>
                        <div class="small text-muted" style="font-size: 0.75rem;">Xử lý kịp thời,<br>tiện lợi mọi lúc</div>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-people fs-5" style="color: #133B2F;"></i>
                    <div>
                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">Vì cộng đồng</div>
                        <div class="small text-muted" style="font-size: 0.75rem;">Chung tay xây dựng<br>môi trường tốt đẹp hơn</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 1 -->
    <div class="row g-3 mb-3 mx-0">
        <div class="col-lg-6">
            <div class="about-card">
                <h4 class="about-title">Giá trị cốt lõi của chúng tôi <i class="bi bi-flower1 ms-1" style="color: #8bb174; font-size: 1rem;"></i></h4>
                <div class="row text-center mt-3 pt-1">
                    <div class="col-3 px-1">
                        <div class="feature-icon-box"><i class="bi bi-shield-check text-success"></i></div>
                        <h6 class="fw-bold" style="font-size: 0.75rem;">Minh bạch & Trách nhiệm</h6>
                        <p class="text-muted d-none d-sm-block" style="font-size: 0.65rem; line-height: 1.3;">Mọi phản ánh đều được theo dõi công khai tiến độ xử lý.</p>
                    </div>
                    <div class="col-3 px-1">
                        <div class="feature-icon-box"><i class="bi bi-lightning-charge text-warning"></i></div>
                        <h6 class="fw-bold" style="font-size: 0.75rem;">Nhanh chóng & Hiệu quả</h6>
                        <p class="text-muted d-none d-sm-block" style="font-size: 0.65rem; line-height: 1.3;">Quy trình số hóa giúp giảm thiểu tối đa thời gian chờ đợi.</p>
                    </div>
                    <div class="col-3 px-1">
                        <div class="feature-icon-box"><i class="bi bi-people text-primary"></i></div>
                        <h6 class="fw-bold" style="font-size: 0.75rem;">Vì cộng đồng</h6>
                        <p class="text-muted d-none d-sm-block" style="font-size: 0.65rem; line-height: 1.3;">Tất cả vì mục tiêu xây dựng môi trường sống chất lượng cao hơn.</p>
                    </div>
                    <div class="col-3 px-1">
                        <div class="feature-icon-box" style="color: #6b8e23;"><i class="bi bi-flower2"></i></div>
                        <h6 class="fw-bold" style="font-size: 0.75rem;">Bền vững & Nhân văn</h6>
                        <p class="text-muted d-none d-sm-block" style="font-size: 0.65rem; line-height: 1.3;">Hướng tới sự phát triển hài hòa giữa con người và thiên nhiên.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="about-card">
                <h4 class="about-title">Civic Connect trong những con số</h4>
                <div class="row text-center mt-3 pt-1">
                    <div class="col-3 px-1">
                        <div class="feature-icon-box"><i class="bi bi-people-fill text-success"></i></div>
                        <div class="stat-number">12.4K+</div>
                        <h6 class="fw-bold mb-1" style="font-size: 0.75rem;">Người dân tin tưởng</h6>
                        <p class="text-muted d-none d-sm-block" style="font-size: 0.65rem;">Thành viên cộng đồng</p>
                    </div>
                    <div class="col-3 px-1">
                        <div class="feature-icon-box"><i class="bi bi-chat-left-text-fill text-success"></i></div>
                        <div class="stat-number">38.6K+</div>
                        <h6 class="fw-bold mb-1" style="font-size: 0.75rem;">Phản ánh đã gửi</h6>
                        <p class="text-muted d-none d-sm-block" style="font-size: 0.65rem;">Tiếng nói từ cộng đồng</p>
                    </div>
                    <div class="col-3 px-1">
                        <div class="feature-icon-box"><i class="bi bi-check-circle-fill text-success"></i></div>
                        <div class="stat-number">28.9K+</div>
                        <h6 class="fw-bold mb-1" style="font-size: 0.75rem;">Vấn đề đã xử lý</h6>
                        <p class="text-muted d-none d-sm-block" style="font-size: 0.65rem;">Minh bạch & hiệu quả</p>
                    </div>
                    <div class="col-3 px-1">
                        <div class="feature-icon-box"><i class="bi bi-emoji-smile-fill text-success"></i></div>
                        <div class="stat-number">95%</div>
                        <h6 class="fw-bold mb-1" style="font-size: 0.75rem;">Mức độ hài lòng</h6>
                        <p class="text-muted d-none d-sm-block" style="font-size: 0.65rem;">Từ người dân</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2 -->
    <div class="row g-3 mx-0">
        <!-- How it works -->
        <div class="col-lg-5">
            <div class="about-card">
                <h4 class="about-title mb-2">Civic Connect hoạt động như thế nào?</h4>
                <div class="d-flex flex-nowrap justify-content-between align-items-start mt-4 text-center w-100">
                    <div class="step-item px-1">
                        <div class="feature-icon-box" style="background-color: #E2EFE9; color: #1E5C4A;"><i class="bi bi-pencil-square"></i></div>
                        <h6 class="fw-bold">1. Gửi phản ánh</h6>
                        <p class="text-muted d-none d-sm-block">Người dân dễ dàng gửi ý kiến, sự cố, kiến nghị mọi lúc, mọi nơi.</p>
                    </div>
                    <div class="step-arrow mx-1 d-none d-md-block"><i class="bi bi-arrow-right"></i></div>
                    
                    <div class="step-item px-1">
                        <div class="feature-icon-box" style="background-color: #E1EDF8; color: #1A56DB;"><i class="bi bi-clipboard-check"></i></div>
                        <h6 class="fw-bold">2. Tiếp nhận & xử lý</h6>
                        <p class="text-muted d-none d-sm-block">Cơ quan chức năng tiếp nhận, phân loại và xử lý nhanh chóng.</p>
                    </div>
                    <div class="step-arrow mx-1 d-none d-md-block"><i class="bi bi-arrow-right"></i></div>
                    
                    <div class="step-item px-1">
                        <div class="feature-icon-box" style="background-color: #FFF3CD; color: #997404;"><i class="bi bi-bell-fill"></i></div>
                        <h6 class="fw-bold">3. Theo dõi tiến độ</h6>
                        <p class="text-muted d-none d-sm-block">Cập nhật công khai tiến độ xử lý để người dân theo dõi.</p>
                    </div>
                    <div class="step-arrow mx-1 d-none d-md-block"><i class="bi bi-arrow-right"></i></div>
                    
                    <div class="step-item px-1">
                        <div class="feature-icon-box" style="background-color: #D1E7DD; color: #0F5132;"><i class="bi bi-check-circle-fill"></i></div>
                        <h6 class="fw-bold">4. Hoàn thành & đánh giá</h6>
                        <p class="text-muted d-none d-sm-block">Thông báo kết quả và lấy ý kiến đánh giá mức độ hài lòng.</p>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Impacts -->
        <div class="col-lg-4">
            <div class="about-card position-relative overflow-hidden">
                <div class="position-absolute bottom-0 end-0 w-100" style="height: 140px; background: url('/images/nền vinh danh.png') no-repeat right bottom; background-size: cover; opacity: 0.25; pointer-events: none;"></div>
                <h4 class="about-title position-relative z-index-1">Tác động tích cực đến cộng đồng</h4>
                <ul class="list-unstyled mt-3 position-relative z-index-1 d-flex flex-column gap-3 mb-4">
                    <li class="d-flex align-items-center gap-2">
                        <i class="bi bi-flower1" style="color: #8bb174; font-size: 1.1rem;"></i> <span style="font-size: 0.8rem; font-weight: 500;">Nâng cao chất lượng phục vụ của chính quyền</span>
                    </li>
                    <li class="d-flex align-items-center gap-2">
                        <i class="bi bi-flower1" style="color: #8bb174; font-size: 1.1rem;"></i> <span style="font-size: 0.8rem; font-weight: 500;">Tăng cường sự tham gia của người dân</span>
                    </li>
                    <li class="d-flex align-items-center gap-2">
                        <i class="bi bi-flower1" style="color: #8bb174; font-size: 1.1rem;"></i> <span style="font-size: 0.8rem; font-weight: 500;">Xây dựng môi trường sống xanh - sạch - đẹp</span>
                    </li>
                    <li class="d-flex align-items-center gap-2">
                        <i class="bi bi-flower1" style="color: #8bb174; font-size: 1.1rem;"></i> <span style="font-size: 0.8rem; font-weight: 500;">Góp phần phát triển đô thị thông minh, bền vững</span>
                    </li>
                </ul>
            </div>
        </div>
        
        <!-- CTA -->
        <div class="col-lg-3">
            <div class="about-card text-center d-flex flex-column justify-content-center position-relative overflow-hidden" style="background-color: #F6F3E6;">
                <div class="position-absolute top-0 end-0 w-100 h-100" style="background: url('/images/nền kem.jpg') no-repeat center; background-size: cover; opacity: 0.4; pointer-events: none;"></div>
                <div class="position-relative z-index-1">
                    <h4 class="fw-bold mb-3" style="color: #133B2F; line-height: 1.3;">Cùng nhau tạo nên <br><span style="font-family: 'EB Garamond', serif; font-style: italic; font-size: 1.3rem;">những thay đổi tích cực!</span></h4>
                    <p class="text-muted mb-4 px-1" style="font-size: 0.75rem; line-height: 1.5;">Mỗi ý kiến đóng góp của bạn là một viên gạch xây nên thành phố tốt đẹp hơn mỗi ngày.</p>
                    <a href="/Issues/Create" class="btn rounded-pill px-3 py-2 w-100 shadow-sm transition-hover" style="background-color: #1E5C4A; color: white; font-weight: 500; font-size: 0.9rem;">
                        <i class="bi bi-send-fill me-1"></i> Gửi phản ánh ngay
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
