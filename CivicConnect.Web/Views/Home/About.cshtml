@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="about-page container py-5 fade-in-up">
    <!-- Hero Header -->
    <div class="text-center mb-5">
        <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill mb-3" style="font-size: 0.85rem; font-weight: 600; letter-spacing: 0.5px;">VỀ CIVIC CONNECT</span>
        <h1 class="font-serif fw-bold display-5 mb-3" style="color: #1B4D3E; font-family: Georgia, serif;">Hệ Thống Kết Nối Đô Thị Thông Minh</h1>
        <p class="text-muted mx-auto fs-5" style="max-width: 800px; line-height: 1.6;">
            Civic Connect là giải pháp cầu nối trực tuyến hiện đại giữa người dân và chính quyền địa phương, hỗ trợ tiếp nhận và giải quyết nhanh chóng các phản ánh đô thị để kiến tạo môi trường sống văn minh, an toàn và sạch đẹp.
        </p>
    </div>

    <!-- Core Values Section -->
    <div class="row g-4 mb-5 pt-3">
        <div class="col-md-4">
            <div class="card border-0 bg-white rounded-4 p-4 shadow-sm h-100 text-center transition-hover" style="border-radius: 1rem !important; box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;">
                <div class="d-inline-flex align-items-center justify-content-center bg-primary-subtle text-primary rounded-circle mb-4" style="width: 60px; height: 60px; background-color: #e8f0fe !important;">
                    <i class="bi bi-shield-check fs-3" style="color: #0d6efd;"></i>
                </div>
                <h4 class="fw-bold mb-3" style="color: #1B4D3E;">Công Khai & Minh Bạch</h4>
                <p class="text-muted small mb-0" style="line-height: 1.6;">
                    Mọi ý kiến phản ánh về các vấn đề dân sinh như giao thông, môi trường, hạ tầng hay an ninh trật tự đều được cập nhật công khai. Người dân có thể dễ dàng giám sát toàn bộ quy trình giải quyết trực tuyến.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 bg-white rounded-4 p-4 shadow-sm h-100 text-center transition-hover" style="border-radius: 1rem !important; box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;">
                <div class="d-inline-flex align-items-center justify-content-center bg-warning-subtle rounded-circle mb-4" style="width: 60px; height: 60px; background-color: #fef5d1 !important;">
                    <i class="bi bi-lightning-charge fs-3" style="color: #b08f26;"></i>
                </div>
                <h4 class="fw-bold mb-3" style="color: #1B4D3E;">Tiếp Nhận Tức Thì</h4>
                <p class="text-muted small mb-0" style="line-height: 1.6;">
                    Hệ thống số hóa tự động phân phối thông tin phản ánh đến đúng cơ quan quản lý phụ trách (Phường/Xã, Quận/Huyện, Sở ngành) dựa trên phân loại danh mục giúp đẩy nhanh tốc độ tiếp nhận và phản hồi.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 bg-white rounded-4 p-4 shadow-sm h-100 text-center transition-hover" style="border-radius: 1rem !important; box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;">
                <div class="d-inline-flex align-items-center justify-content-center bg-success-subtle text-success rounded-circle mb-4" style="width: 60px; height: 60px; background-color: #e6f4ea !important;">
                    <i class="bi bi-people fs-3" style="color: #137333;"></i>
                </div>
                <h4 class="fw-bold mb-3" style="color: #1B4D3E;">Chung Tay Kiến Tạo</h4>
                <p class="text-muted small mb-0" style="line-height: 1.6;">
                    Phát huy sức mạnh cộng đồng thông qua các tính năng tương tác trực quan như bình luận, biểu quyết ủng hộ phản ánh và gửi phản hồi đánh giá trực tiếp về mức độ hài lòng đối với chất lượng xử lý của cơ quan chức năng.
                </p>
            </div>
        </div>
    </div>

    <!-- Banner Details -->
    <div class="row align-items-center g-5 mb-4 py-4">
        <div class="col-lg-6">
            <img src="https://images.unsplash.com/photo-1573164713988-8665fc963095?q=80&w=1200&auto=format&fit=crop" class="img-fluid rounded-4 shadow-sm" alt="Cộng đồng thông minh" style="border-radius: 1rem !important;" />
        </div>
        <div class="col-lg-6">
            <h2 class="font-serif fw-bold mb-4" style="color: #1B4D3E; font-family: Georgia, serif;">Sứ mệnh & Định hướng phát triển</h2>
            <p class="text-muted mb-4" style="line-height: 1.7;">
                Civic Connect định hình cách thức tương tác thế hệ mới giữa nhân dân và chính quyền đô thị. Bằng việc áp dụng tối đa chuyển đổi số, dự án tháo gỡ những rào cản hành chính phức tạp trước đây, đưa tiếng nói của người dân tới gần hơn với các cấp lãnh đạo quản lý một cách trực tiếp, minh bạch và chân thực nhất.
            </p>
            
            <div class="d-flex flex-column gap-4">
                <div class="d-flex align-items-start gap-3">
                    <div class="text-success mt-1"><i class="bi bi-check-circle-fill fs-5" style="color: #137333;"></i></div>
                    <div>
                        <h6 class="fw-bold mb-1" style="color: #1B4D3E;">Đơn giản hóa phản ánh đô thị</h6>
                        <p class="text-muted small mb-0" style="line-height: 1.6;">Thay vì phải soạn văn bản giấy và nộp trực tiếp tại phường, người dân chỉ cần chụp ảnh hiện trạng và gửi trực tiếp qua ứng dụng trong vòng 1 phút.</p>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-3">
                    <div class="text-success mt-1"><i class="bi bi-check-circle-fill fs-5" style="color: #137333;"></i></div>
                    <div>
                        <h6 class="fw-bold mb-1" style="color: #1B4D3E;">Giám sát lộ trình giải quyết thời gian thực</h6>
                        <p class="text-muted small mb-0" style="line-height: 1.6;">Toàn bộ tiến độ phân công thụ lý phản ánh, trạng thái thực tế xử lý tại hiện trường được đồng bộ cập nhật và thông báo tức thời tới công dân.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
