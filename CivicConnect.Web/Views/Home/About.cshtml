@{
    ViewData["Title"] = "Giới thiệu nền tảng Civic Connect";
}

<div class="container-fluid bg-light py-5">
    <div class="container">
        <div class="row align-items-center justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="display-4 fw-bold text-primary mb-4" style="font-family: var(--font-display, serif);">Civic Connect</h1>
                <p class="lead text-muted mb-4">Cầu nối vững chắc giữa người dân và chính quyền địa phương, hướng tới xây dựng một đô thị thông minh, minh bạch và phát triển bền vững.</p>
                <img src="/images/about-hero.svg" alt="Civic Connect Hero" class="img-fluid rounded-4 shadow-lg mb-5" onerror="this.src='https://via.placeholder.com/800x400?text=About+Civic+Connect'" style="max-height: 400px; object-fit: cover; width: 100%;" />
            </div>
        </div>
    </div>
</div>

<div class="container py-5 my-4">
    <div class="row g-5">
        <div class="col-md-6">
            <h2 class="fw-bold mb-4" style="color: var(--primary-800);">Tầm nhìn của chúng tôi</h2>
            <p class="fs-5 text-muted lh-lg">Chúng tôi tin tưởng vào một xã hội nơi tiếng nói của mọi người dân đều được lắng nghe và tôn trọng. <strong>Civic Connect</strong> ra đời với sứ mệnh xóa nhòa khoảng cách giữa cơ quan quản lý và người dân, tạo ra một không gian tương tác trực tuyến nhanh chóng, an toàn và hiệu quả nhất.</p>
            <p class="text-muted lh-lg">Thông qua sức mạnh của công nghệ, hệ thống giúp chính quyền phản hồi kịp thời các vấn đề bức xúc của xã hội, từ giao thông, môi trường đến cơ sở hạ tầng, đồng thời cung cấp kênh thông tin minh bạch nhất.</p>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, var(--primary-50) 0%, white 100%);">
                <div class="card-body p-5">
                    <h4 class="fw-bold mb-4 text-primary">Giá trị cốt lõi</h4>
                    <ul class="list-unstyled mb-0 gap-3 d-flex flex-column">
                        <li class="d-flex align-items-start">
                            <i class="bi bi-shield-check text-primary fs-4 me-3 mt-1"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Minh bạch & Trách nhiệm</h6>
                                <p class="text-muted mb-0 small">Mọi phản ánh đều được theo dõi công khai tiến độ xử lý.</p>
                            </div>
                        </li>
                        <li class="d-flex align-items-start">
                            <i class="bi bi-lightning-charge text-warning fs-4 me-3 mt-1"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Nhanh chóng & Hiệu quả</h6>
                                <p class="text-muted mb-0 small">Quy trình số hóa giúp giảm thiểu tối đa thời gian chờ đợi.</p>
                            </div>
                        </li>
                        <li class="d-flex align-items-start">
                            <i class="bi bi-people text-success fs-4 me-3 mt-1"></i>
                            <div>
                                <h6 class="fw-bold mb-1">Vì cộng đồng</h6>
                                <p class="text-muted mb-0 small">Tất cả vì mục tiêu xây dựng môi trường sống chất lượng cao hơn.</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid py-5" style="background-color: var(--primary-900); color: white;">
    <div class="container text-center py-4">
        <h3 class="fw-bold mb-4" style="font-family: var(--font-display);">Tham gia xây dựng thành phố cùng chúng tôi</h3>
        <p class="mb-5 opacity-75">Chỉ mất vài phút để gửi đi một ý kiến đóng góp làm thay đổi diện mạo khu phố của bạn.</p>
        <a href="/Issues/Create" class="btn btn-light btn-lg rounded-pill px-5 fw-bold text-primary shadow-sm hover-scale">Gửi phản ánh ngay</a>
    </div>
</div>
