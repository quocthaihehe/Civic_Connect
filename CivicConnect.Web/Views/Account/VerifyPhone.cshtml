@model CivicConnect.Web.Models.Account.VerifyPhoneViewModel
@{
    ViewData["Title"] = "Xác minh SĐT";
    var systemOtp = TempData["SMS_OTP"]?.ToString();
    // Keep it alive in case form errors
    TempData.Keep("SMS_OTP");
    TempData.Keep("VerifyEmail");
}

<div class="row justify-content-center align-items-center py-5">
    <div class="col-md-6 col-lg-4">
        <div class="glass-card p-4 p-md-5">
            <div class="text-center mb-4">
                <i class="bi bi-shield-fill-check text-primary fs-1"></i>
                <h3 class="fw-bold mt-2">Xác minh SĐT</h3>
                <p class="text-muted" style="font-size: 0.85rem;">Một mã xác thực OTP đã được gửi đến số điện thoại đăng ký.</p>
            </div>

            <form asp-action="VerifyPhone" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size: 0.85rem;" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="OtpCode" class="form-label fw-semibold" style="font-size: 0.85rem;"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-key"></i></span>
                        <input asp-for="OtpCode" class="form-control border-start-0 ps-0 text-center fw-bold fs-5" placeholder="000000" maxlength="6" required />
                    </div>
                    <span asp-validation-for="OtpCode" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="d-grid gap-2 mb-3">
                    <button type="submit" class="btn btn-primary rounded-pill py-2">Xác Nhận</button>
                </div>
                
                <div class="text-center">
                    <button type="button" class="btn btn-link text-decoration-none text-muted p-0" style="font-size: 0.8rem;" disabled id="resend-btn">
                        Gửi lại mã (sau <span id="countdown">60</span>s)
                    </button>
                </div>
            </form>

            <div class="mt-4 border-top pt-3" style="border-top: 1px solid var(--border-glass) !important;">
                <div class="alert alert-info py-2 mb-0" style="font-size: 0.75rem;">
                    <strong>Môi trường phát triển:</strong><br/>
                    - Mã OTP hệ thống gửi: <code class="text-danger">@systemOtp</code><br/>
                    - Hoặc nhập OTP mặc định: <code>123456</code>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            let seconds = 60;
            const timer = setInterval(() => {
                seconds--;
                $('#countdown').text(seconds);
                if (seconds <= 0) {
                    clearInterval(timer);
                    $('#resend-btn').removeAttr('disabled').text('Gửi lại mã OTP');
                }
            }, 1000);
        });
    </script>
}
