@model CivicConnect.Web.Models.Account.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center align-items-center py-5">
    <div class="col-md-7 col-lg-5">
        <div class="glass-card p-4 p-md-5">
            <div class="text-center mb-4">
                <i class="bi bi-shield-check text-primary fs-1"></i>
                <h3 class="fw-bold mt-2">Tạo tài khoản mới</h3>
                <p class="text-muted" style="font-size: 0.85rem;">Kết nối trực tiếp với chính quyền địa bàn cư trú</p>
            </div>

            <form asp-action="Register" method="post" class="needs-validation">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2" style="font-size: 0.85rem;" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="FullName" class="form-label fw-semibold" style="font-size: 0.85rem;"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-person"></i></span>
                        <input asp-for="FullName" class="form-control border-start-0 ps-0" placeholder="Nguyễn Văn A" required />
                    </div>
                    <span asp-validation-for="FullName" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold" style="font-size: 0.85rem;"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="nguyenvana@gmail.com" type="email" required />
                    </div>
                    <span asp-validation-for="Email" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="PhoneNumber" class="form-label fw-semibold" style="font-size: 0.85rem;"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-telephone"></i></span>
                        <input asp-for="PhoneNumber" class="form-control border-start-0 ps-0" placeholder="0901234567" required />
                    </div>
                    <span asp-validation-for="PhoneNumber" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold" style="font-size: 0.85rem;">Khu vực cư trú</label>
                    <div class="row g-2">
                        <div class="col-4">
                            <select asp-for="ProvinceCode" id="province-select" class="form-select select-sm" style="font-size: 0.85rem;" required>
                                <option value="">Tỉnh/TP</option>
                                <option value="79">TP. Hồ Chí Minh</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <select asp-for="DistrictCode" id="district-select" class="form-select select-sm" style="font-size: 0.85rem;" required>
                                <option value="">Quận/Huyện</option>
                            </select>
                        </div>
                        <div class="col-4">
                            <select asp-for="WardCode" id="ward-select" class="form-select select-sm" style="font-size: 0.85rem;" required>
                                <option value="">Phường/Xã</option>
                            </select>
                        </div>
                    </div>
                    <span asp-validation-for="WardCode" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold" style="font-size: 0.85rem;"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control border-start-0 ps-0" type="password" placeholder="••••••••" required />
                    </div>
                    <span asp-validation-for="Password" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold" style="font-size: 0.85rem;"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted"><i class="bi bi-lock-fill"></i></span>
                        <input asp-for="ConfirmPassword" class="form-control border-start-0 ps-0" type="password" placeholder="••••••••" required />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger" style="font-size: 0.75rem;"></span>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary rounded-pill py-2">Đăng Ký</button>
                </div>
            </form>

            <div class="text-center mt-4" style="font-size: 0.85rem;">
                <span class="text-muted">Đã có tài khoản? </span>
                <a asp-action="Login" class="text-primary fw-semibold text-decoration-none">Đăng nhập ngay</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function() {
            // Danh sách dữ liệu mẫu cho Phường/Quận hành chính Việt Nam
            const districts = {
                "79": [
                    { code: "760", name: "Quận 1" },
                    { code: "770", name: "Quận 3" },
                    { code: "774", name: "Quận Bình Thạnh" }
                ]
            };

            const wards = {
                "760": [
                    { code: "26734", name: "Phường Bến Nghé" },
                    { code: "26737", name: "Phường Bến Thành" },
                    { code: "26731", name: "Phường Đa Kao" }
                ],
                "770": [
                    { code: "26797", name: "Phường Võ Thị Sáu" },
                    { code: "26809", name: "Phường 12" }
                ],
                "774": [
                    { code: "27157", name: "Phường 19" },
                    { code: "27159", name: "Phường 22" }
                ]
            };

            // Sự thay đổi dropdown Province
            $('#province-select').change(function() {
                const provId = $(this).val();
                const distSelect = $('#district-select');
                const wardSelect = $('#ward-select');

                distSelect.empty().append('<option value="">Quận/Huyện</option>');
                wardSelect.empty().append('<option value="">Phường/Xã</option>');

                if (districts[provId]) {
                    districts[provId].forEach(d => {
                        distSelect.append(`<option value="${d.code}">${d.name}</option>`);
                    });
                }
            });

            // Sự thay đổi dropdown District
            $('#district-select').change(function() {
                const distId = $(this).val();
                const wardSelect = $('#ward-select');

                wardSelect.empty().append('<option value="">Phường/Xã</option>');

                if (wards[distId]) {
                    wards[distId].forEach(w => {
                        wardSelect.append(`<option value="${w.code}">${w.name}</option>`);
                    });
                }
            });
        });
    </script>
}
