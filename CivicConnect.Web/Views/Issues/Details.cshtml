@model CivicConnect.Web.Models.Entities.Issue
@using CivicConnect.Web.Models.Enums
@using Microsoft.AspNetCore.Identity
@using CivicConnect.Web.Models.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = Model.Title;
    var currentUserId = UserManager.GetUserId(User);
}

<style>
    .issue-carousel-wrapper {
        border-radius: var(--radius-lg);
        overflow: hidden;
        background: rgba(0, 0, 0, 0.05);
        height: 350px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    
    .issue-carousel-img {
        object-fit: contain;
        max-height: 100%;
        width: 100%;
    }

    .comment-box-wrapper {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border-glass);
        border-radius: var(--radius-md);
        padding: 15px;
    }

    .comment-bubble {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-glass) !important;
        border-radius: 12px;
        padding: 16px;
        transition: transform 0.2s;
    }
    .comment-bubble:hover {
        transform: translateX(4px);
        background: rgba(255, 255, 255, 0.08);
    }
</style>

<div class="row g-4 mt-2">
    <!-- Left Column: Issue Content, Images & Comments -->
    <div class="col-lg-7">
        <div class="d-flex flex-column gap-3">
            
            <!-- Issue Details Card -->
            <div class="glass-card p-4">
                
                <!-- Header Info -->
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
                    <span class="badge @GetStatusClass(Model.Status) rounded-pill px-3 py-2 shadow-sm" style="font-size: 0.9rem;">
                        @GetStatusName(Model.Status)
                    </span>
                    <span class="text-muted" style="font-size: 0.85rem;">
                        <i class="bi bi-clock me-1"></i> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                    </span>
                </div>

                <h2 class="fw-bold mb-3 text-dark" style="line-height: 1.4;">
                    @Model.Title
                    @if (Model.IsVerified)
                    {
                        <span class="text-primary ms-2" title="Đã xác thực thực tế"><i class="bi bi-patch-check-fill"></i></span>
                    }
                </h2>

                <div class="d-flex flex-wrap align-items-center gap-3 mb-4 pb-4 border-bottom border-secondary border-opacity-25 text-muted" style="font-size: 0.9rem;">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-primary bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                            <i class="bi bi-person-fill text-primary" style="font-size: 0.85rem;"></i>
                        </div>
                        <span class="text-dark fw-medium">@(Model.IsAnonymous ? "Ẩn danh" : Model.Author?.FullName ?? "Công dân")</span>
                    </div>
                    <span>•</span>
                    <span><i class="bi bi-tag-fill text-primary me-1"></i> @GetCategoryName(Model.Category)</span>
                    <span>•</span>
                    <span><i class="bi bi-eye-fill me-1"></i> @Model.ViewCount lượt xem</span>
                </div>

                <!-- Images Carousel -->
                @if (Model.Images != null && Model.Images.Any())
                {
                    <div class="issue-carousel-wrapper mb-4">
                        <div id="imagesCarousel" class="carousel slide w-100 h-100" data-bs-ride="carousel">
                            <div class="carousel-inner h-100">
                                @{ var first = true; }
                                @foreach (var img in Model.Images.OrderBy(i => i.OrderIndex))
                                {
                                    <div class="carousel-item h-100 @(first ? "active" : "")">
                                        <img src="@img.Url" class="d-block issue-carousel-img" />
                                    </div>
                                    first = false;
                                }
                            </div>
                            @if (Model.Images.Count > 1)
                            {
                                <button class="carousel-control-prev" type="button" data-bs-target="#imagesCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true" style="filter: drop-shadow(0 0 4px #000);"></span>
                                    <span class="visually-hidden">Previous</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#imagesCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true" style="filter: drop-shadow(0 0 4px #000);"></span>
                                    <span class="visually-hidden">Next</span>
                                </button>
                            }
                        </div>
                    </div>
                }

                <!-- Content Description -->
                <div class="mb-5">
                    <h5 class="fw-bold mb-3 text-dark d-flex align-items-center gap-2">
                        <i class="bi bi-card-text text-primary"></i> Nội dung chi tiết
                    </h5>
                    <div class="text-secondary" style="line-height: 1.8; white-space: pre-line; font-size: 1.05rem;">
                        @Model.Description
                    </div>
                </div>

                <!-- Address Box -->
                <div class="p-3 rounded-3 mb-4" style="background: rgba(var(--bs-primary-rgb), 0.05); border: 1px dashed rgba(var(--bs-primary-rgb), 0.3);">
                    <h6 class="fw-bold mb-2 text-dark"><i class="bi bi-geo-alt-fill text-danger me-2"></i> Địa điểm sự việc</h6>
                    <p class="text-secondary mb-1">@Model.Address</p>
                    <div class="text-muted" style="font-size: 0.85rem;">
                        <span class="badge bg-secondary bg-opacity-25 text-dark me-2">P/X: @Model.WardName</span>
                        <span class="badge bg-secondary bg-opacity-25 text-dark">Q/H: @Model.DistrictName</span>
                    </div>
                </div>

                <!-- Action Bar (Vote) -->
                <div class="d-flex flex-wrap justify-content-between align-items-center mt-4 pt-3 border-top border-secondary border-opacity-25">
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-outline-primary rounded-pill vote-btn px-4 py-2 d-flex align-items-center gap-2" data-id="@Model.Id" data-type="1">
                            <i class="bi bi-hand-thumbs-up-fill"></i>
                            <span>Đồng tình (<strong id="upvotes-count">@Model.Votes.Count(v => v.Type == VoteType.Up)</strong>)</span>
                        </button>
                        <button class="btn btn-outline-danger rounded-pill vote-btn px-4 py-2 d-flex align-items-center gap-2" data-id="@Model.Id" data-type="-1">
                            <i class="bi bi-hand-thumbs-down-fill"></i>
                            <span>Không đồng tình (<strong id="downvotes-count">@Model.Votes.Count(v => v.Type == VoteType.Down)</strong>)</span>
                        </button>
                    </div>
                    <div class="text-muted fs-5 mt-3 mt-md-0">
                        <i class="bi bi-chat-dots-fill text-primary me-1"></i> 
                        <strong id="comments-counter" class="text-dark">@Model.Comments.Count</strong> bình luận
                    </div>
                </div>
            </div>

            <div class="glass-card p-4 mt-2">
                <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-chat-square-quote-fill text-primary me-2"></i> Thảo luận</h5>
                
                <!-- New Comment Form -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="comment-box-wrapper mb-5 shadow-sm">
                        <div class="d-flex gap-3">
                            <img src="@(UserManager.GetUserAsync(User).Result?.AvatarUrl ?? "/images/default-avatar.png")" 
                                 onerror="this.onerror=null; this.src='/images/default-avatar.png';" 
                                 class="rounded-circle shadow-sm mt-1 border border-2 border-primary border-opacity-25" 
                                 style="width: 45px; height: 45px; object-fit: cover;" />
                            
                            <div class="w-100">
                                <textarea id="new-comment-content" class="form-control bg-light text-dark border-0 px-3 py-2 shadow-sm" 
                                          rows="2" placeholder="Chia sẻ góc nhìn của bạn về vấn đề này..."
                                          style="resize: none; border-radius: 8px;"></textarea>
                                
                                <div class="d-flex justify-content-end align-items-center mt-3 pt-2">
                                    <button class="btn btn-primary rounded-pill px-4" id="submit-comment-btn" data-id="@Model.Id">
                                        <i class="bi bi-send-fill me-1"></i> Gửi bình luận
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="glass-card p-4 text-center mb-5" style="border-style: dashed;">
                        <i class="bi bi-person-lock fs-1 text-muted mb-2 d-block"></i>
                        <p class="mb-3 text-secondary">Bạn cần đăng nhập để tham gia thảo luận cùng cộng đồng.</p>
                        <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Issues/Details/@Model.Id" class="btn btn-primary rounded-pill px-4">
                            Đăng nhập ngay
                        </a>
                    </div>
                }

                <!-- Comments List -->
                <div class="d-flex flex-column gap-3" id="comments-list-container">
                    @if (Model.Comments == null || !Model.Comments.Any())
                    {
                        <div class="text-center text-muted py-5" id="comments-empty-state">
                            <img src="/images/default-avatar.png" class="opacity-25 mb-3" style="width: 64px;" />
                            <p class="mb-0">Chưa có bình luận nào. Hãy là người đầu tiên chia sẻ ý kiến!</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var comment in Model.Comments.Where(c => c.ParentCommentId == null).OrderByDescending(c => c.CreatedAt))
                        {
                            <div class="comment-bubble shadow-sm">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@(comment.Author?.AvatarUrl ?? "/images/default-avatar.png")" 
                                             onerror="this.onerror=null; this.src='/images/default-avatar.png';" 
                                             class="rounded-circle border" style="width: 40px; height: 40px; object-fit: cover;" />
                                        
                                        <div>
                                            <div class="fw-bold @(comment.IsOfficialResponse ? "text-warning" : "text-white")" style="font-size: 0.95rem;">
                                                @comment.Author?.FullName
                                                @if (comment.IsOfficialResponse)
                                                {
                                                    <span class="badge bg-primary ms-2"><i class="bi bi-check-circle-fill me-1"></i> Cán bộ</span>
                                                }
                                            </div>
                                            <div class="text-muted" style="font-size: 0.75rem;">@comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                                        </div>
                                    </div>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <form asp-area="Admin" asp-controller="Admin" asp-action="DeleteComment" method="post" class="m-0" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bình luận này không?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@comment.Id" />
                                            <input type="hidden" name="issueId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-link text-danger p-0 border-0 bg-transparent" title="Xóa bình luận">
                                                <i class="bi bi-trash fs-5"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                                <div class="text-secondary mt-2 ms-5 ps-2" style="font-size: 0.95rem; line-height: 1.6;">@comment.Content</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Map Coordinates & Timeline Status History -->
    <div class="col-lg-5">
        <div class="d-flex flex-column gap-3 position-sticky" style="top: 80px;">
            
            <!-- Mini Map Card -->
            <div class="glass-card p-4">
                <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-map-fill text-primary me-2"></i> Bản đồ sự cố</h5>
                <div class="rounded-3 position-relative shadow-sm" style="height: 250px; border: 1px solid var(--border-glass); overflow: hidden; background-color: #f8f9fa;">
                    @{
                        // Tính toán bounding box cho OpenStreetMap iframe
                        var lonStr = Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var latStr = Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var lonMin = (Model.Longitude - 0.002).ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var latMin = (Model.Latitude - 0.002).ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var lonMax = (Model.Longitude + 0.002).ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var latMax = (Model.Latitude + 0.002).ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var mapUrl = $"https://www.openstreetmap.org/export/embed.html?bbox={lonMin}%2C{latMin}%2C{lonMax}%2C{latMax}&layer=mapnik&marker={latStr}%2C{lonStr}";
                    }
                    <iframe width="100%" height="100%" frameborder="0" scrolling="no" marginheight="0" marginwidth="0" src="@mapUrl" style="border: none; pointer-events: none;"></iframe>
                </div>
                <div class="mt-3 p-3 rounded-3 bg-dark bg-opacity-25 text-center">
                    <span class="text-muted d-block mb-1" style="font-size: 0.8rem;">TỌA ĐỘ</span>
                    <strong class="text-primary font-monospace" style="font-size: 0.9rem;">@Model.Latitude, @Model.Longitude</strong>
                </div>
            </div>

            <!-- Processing Timeline Audit History -->
            <div class="glass-card p-4">
                <h6 class="fw-bold mb-3 text-dark"><i class="bi bi-hourglass-split text-primary me-2"></i> Tiến độ xử lý</h6>
                
                <div class="timeline-flow mt-3">
                    @if (Model.StatusHistory != null && Model.StatusHistory.Any())
                    {
                        @foreach (var hist in Model.StatusHistory.OrderByDescending(h => h.ChangedAt))
                        {
                            <div class="timeline-step active position-relative ps-4 pb-4">
                                <!-- Line and dot are handled by .timeline-step css -->
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <strong class="text-white">@GetStatusName(hist.ToStatus)</strong>
                                    <span class="badge bg-secondary bg-opacity-25 text-muted fw-normal">@hist.ChangedAt.ToString("dd/MM HH:mm")</span>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(hist.Note))
                                {
                                    <div class="text-secondary mt-2 p-2 rounded-2" style="font-size: 0.85rem; line-height: 1.4; background: rgba(255,255,255,0.03);">
                                        @hist.Note
                                    </div>
                                }
                                
                                @if (!string.IsNullOrEmpty(hist.AttachmentUrl))
                                {
                                    <div class="mt-2">
                                        <a href="@hist.AttachmentUrl" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill py-1 px-3" style="font-size: 0.75rem;">
                                            <i class="bi bi-file-earmark-check me-1"></i> Văn bản đính kèm
                                        </a>
                                    </div>
                                }
                                
                                <div class="text-muted mt-2 d-flex align-items-center gap-1" style="font-size: 0.75rem;">
                                    <i class="bi bi-person-circle"></i> @(hist.ChangedBy?.FullName ?? "Hệ thống")
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-info-circle mb-2 d-block fs-4"></i>
                            <span style="font-size: 0.85rem;">Hệ thống đang tiếp nhận, chưa có cập nhật tiến độ.</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Satisfaction Rating Card -->
            @if (Model.Status == IssueStatus.Resolved)
            {
                <div class="glass-card p-4 mb-3" id="satisfaction-section">
                    <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-star-fill text-warning me-2"></i> Đánh Giá Mức Hài Lòng</h5>

                    @if (Model.SatisfactionRating.HasValue)
                    {
                        <!-- Already rated -->
                        <div class="text-center py-2">
                            <div class="star-display fs-2 mb-2">
                                @for (int s = 1; s <= 5; s++)
                                {
                                    <i class="bi @(s <= Model.SatisfactionRating.Value ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
                                }
                            </div>
                            <p class="text-success fw-semibold mb-1"><i class="bi bi-check-circle-fill me-1"></i> Bạn đã đánh giá @Model.SatisfactionRating.Value/5 sao</p>
                            @if (!string.IsNullOrEmpty(Model.SatisfactionComment))
                            {
                                <p class="text-muted" style="font-size:0.85rem;">"@Model.SatisfactionComment"</p>
                            }
                            <p class="text-muted" style="font-size:0.75rem;">Ngày đánh giá: @Model.RatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    }
                    else if (currentUserId == Model.AuthorId)
                    {
                        <!-- Rating form for author -->
                        <p class="text-secondary mb-3" style="font-size:0.85rem;">Phản ánh đã được giải quyết. Hãy cho biết mức độ hài lòng của bạn về quá trình xử lý:</p>
                        <div class="star-picker d-flex justify-content-center gap-2 fs-2 mb-3" id="star-picker">
                            @for (int s = 1; s <= 5; s++)
                            {
                                <i class="bi bi-star star-pick text-warning" style="cursor:pointer; transition: transform 0.15s;" data-value="@s" id="star-@s"></i>
                            }
                        </div>
                        <div id="selected-rating-label" class="text-center text-muted mb-3" style="font-size:0.85rem; min-height:1.2em;"></div>
                        <textarea id="rating-comment" class="form-control rounded-3 mb-3 text-dark bg-light border-0 px-3 py-2" rows="2" placeholder="Nhận xét thêm (tùy chọn)..."></textarea>
                        <button class="btn btn-warning w-100 rounded-pill fw-bold" id="submit-rating-btn" data-id="@Model.Id" disabled>
                            <i class="bi bi-send-fill me-1"></i> Gửi đánh giá
                        </button>
                    }
                    else
                    {
                        <p class="text-muted text-center" style="font-size:0.85rem;">Chỉ người gửi phản ánh mới có thể đánh giá.</p>
                    }
                </div>
            }
            
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // 1. AJAX Biểu quyết
            $('.vote-btn').on('click', function() {
                const issueId = $(this).data('id');
                const voteType = $(this).data('type');
                const btn = $(this);

                $.post(`/Issues/Vote`, { id: issueId, type: voteType }, function(res) {
                    if (res.success) {
                        $('#upvotes-count').text(res.upvotes);
                        $('#downvotes-count').text(res.downvotes);
                        
                        // Thêm hiệu ứng nhấp nháy cho nút
                        btn.addClass('btn-primary text-white').removeClass('btn-outline-primary btn-outline-danger');
                        setTimeout(() => {
                            if (voteType === 1) btn.removeClass('btn-primary text-white').addClass('btn-outline-primary');
                            if (voteType === -1) btn.removeClass('btn-primary text-white').addClass('btn-outline-danger');
                        }, 500);
                    }
                }).fail(function() {
                    alert("Có lỗi xảy ra hoặc bạn chưa đăng nhập.");
                });
            });

            // 2. AJAX Gửi bình luận
            $('#submit-comment-btn').on('click', function() {
                const issueId = $(this).data('id');
                const contentText = $('#new-comment-content').val().trim();
                const btn = $(this);

                if (contentText === "") {
                    alert("Vui lòng nhập nội dung bình luận.");
                    $('#new-comment-content').focus();
                    return;
                }

                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Đang gửi...');

                $.post(`/Issues/Comment`, { id: issueId, content: contentText }, function(res) {
                    if (res.success) {
                        // Xóa nội dung ô nhập
                        $('#new-comment-content').val('');
                        $('#comments-empty-state').remove();

                        // Tạo thẻ HTML cho bình luận mới
                        const officialBadge = res.isOfficial ? `<span class="badge bg-primary ms-2"><i class="bi bi-check-circle-fill me-1"></i> Cán bộ</span>` : '';
                        const textClass = res.isOfficial ? 'text-warning' : 'text-white';

                        const commentHtml = `
                            <div class="comment-bubble shadow-sm" style="animation: fadeIn 0.5s ease;">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="/images/default-avatar.png" class="rounded-circle border" style="width: 40px; height: 40px; object-fit: cover;" />
                                        <div>
                                            <div class="fw-bold ${textClass}" style="font-size: 0.95rem;">
                                                ${res.authorName} ${officialBadge}
                                            </div>
                                            <div class="text-muted" style="font-size: 0.75rem;">${res.createdAt}</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-secondary mt-2 ms-5 ps-2" style="font-size: 0.95rem; line-height: 1.6;">${res.content}</div>
                            </div>
                        `;
                        
                        $('#comments-list-container').prepend(commentHtml);

                        // Cập nhật số lượng bình luận
                        let count = parseInt($('#comments-counter').text()) || 0;
                        $('#comments-counter').text(count + 1);
                    }
                }).fail(function() {
                    alert("Gửi bình luận không thành công.");
                }).always(function() {
                    btn.prop('disabled', false).html('<i class="bi bi-send-fill me-1"></i> Gửi bình luận');
                });
            });

            // 3. Star Rating Widget
            let selectedRating = 0;
            const ratingLabels = ['', 'Rất không hài lòng', 'Không hài lòng', 'Bình thường', 'Hài lòng', 'Rất hài lòng ⭐'];

            $('.star-pick').on('mouseenter', function() {
                const val = parseInt($(this).data('value'));
                updateStars(val, false);
            }).on('mouseleave', function() {
                updateStars(selectedRating, false);
            }).on('click', function() {
                selectedRating = parseInt($(this).data('value'));
                updateStars(selectedRating, true);
                $('#selected-rating-label').text(ratingLabels[selectedRating]);
                $('#submit-rating-btn').prop('disabled', false);
            });

            function updateStars(val, fill) {
                $('.star-pick').each(function() {
                    const s = parseInt($(this).data('value'));
                    if (s <= val) {
                        $(this).removeClass('bi-star').addClass('bi-star-fill');
                        if (fill) $(this).css('transform', 'scale(1.2)');
                    } else {
                        $(this).removeClass('bi-star-fill').addClass('bi-star');
                        $(this).css('transform', 'scale(1)');
                    }
                });
            }

            $('#submit-rating-btn').on('click', function() {
                const issueId = $(this).data('id');
                const comment = $('#rating-comment').val().trim();
                const btn = $(this);
                btn.prop('disabled', true).html('<i class="bi bi-hourglass-split me-1"></i> Đang gửi...');

                $.post('/Issues/Rate', { id: issueId, rating: selectedRating, comment: comment }, function(res) {
                    if (res.success) {
                        const stars = Array.from({length: 5}, (_, i) =>
                            `<i class="bi ${i < selectedRating ? 'bi-star-fill text-warning' : 'bi-star text-muted'}"></i>`
                        ).join('');
                        $('#satisfaction-section').html(`
                            <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-star-fill text-warning me-2"></i> Đánh Giá Mức Hài Lòng</h5>
                            <div class="text-center py-2">
                                <div class="star-display fs-2 mb-2">${stars}</div>
                                <p class="text-success fw-semibold mb-1"><i class="bi bi-check-circle-fill me-1"></i> ${res.message}</p>
                                ${comment ? `<p class="text-muted" style="font-size:0.85rem;">"${comment}"</p>` : ''}
                            </div>
                        `);
                    }
                }).fail(function(xhr) {
                    alert(xhr.responseText || 'Đánh giá không thành công.');
                    btn.prop('disabled', false).html('<i class="bi bi-send-fill me-1"></i> Gửi đánh giá');
                });
            });
        });
    </script>
}

@functions {
    public string GetCategoryName(IssueCategory category) => category switch
    {
        IssueCategory.Traffic => "Giao thông",
        IssueCategory.Environment => "Môi trường",
        IssueCategory.Security => "An ninh trật tự",
        IssueCategory.Infrastructure => "Hạ tầng công cộng",
        IssueCategory.Administration => "Hành chính",
        _ => "Khác"
    };

    public string GetStatusName(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "Chờ tiếp nhận",
        IssueStatus.Assigned => "Đã phân công",
        IssueStatus.Processing => "Đang xử lý",
        IssueStatus.Resolved => "Đã giải quyết",
        IssueStatus.Rejected => "Từ chối",
        IssueStatus.Closed => "Đóng tự động",
        _ => "Không xác định"
    };

    public string GetStatusClass(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "bg-warning text-dark",
        IssueStatus.Assigned => "bg-info text-white",
        IssueStatus.Processing => "bg-primary text-white",
        IssueStatus.Resolved => "bg-success text-white",
        IssueStatus.Rejected => "bg-danger text-white",
        _ => "bg-secondary text-white"
    };
}
