@model CivicConnect.Web.Models.Entities.Issue
@using CivicConnect.Web.Models.Enums
@using Microsoft.AspNetCore.Identity
@using CivicConnect.Web.Models.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = Model.Title;
    var currentUserId = UserManager.GetUserId(User);

    // Dynamic absolute URL based on active domain
    var absoluteUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}{Context.Request.QueryString}";
    var encodedUrl = System.Net.WebUtility.UrlEncode(absoluteUrl);
}

@section Meta {
    <!-- Open Graph / Facebook / Zalo Meta Tags -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="@Model.Title" />
    <meta property="og:url" content="@absoluteUrl" />
    @{
        var rawDesc = Model.Description ?? "";
        // Remove HTML tags to prevent broken preview markup
        var cleanDesc = System.Text.RegularExpressions.Regex.Replace(rawDesc, "<.*?>", string.Empty);
        var truncatedDesc = cleanDesc.Length > 180 ? cleanDesc.Substring(0, 180) + "..." : cleanDesc;
    }
    <meta property="og:description" content="@truncatedDesc" />
    
    @if (Model.Images != null && Model.Images.Any())
    {
        // First image as preview thumbnail
        <meta property="og:image" content="@Model.Images.OrderBy(img => img.OrderIndex).First().Url" />
    }
    else
    {
        // Fallback site logo
        <meta property="og:image" content="@($"{Context.Request.Scheme}://{Context.Request.Host}/images/favicon.png")" />
    }
}

<style>
    .issue-carousel-wrapper {
        border-radius: var(--radius-lg);
        overflow: hidden;
        background: rgba(0, 0, 0, 0.05);
        height: 280px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    
    .issue-carousel-img {
        object-fit: contain;
        max-height: 100%;
        width: 100%;
    }

    .comment-box-wrapper {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border-glass);
        border-radius: var(--radius-md);
        padding: 12px;
    }

    .comment-bubble {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-glass) !important;
        border-radius: 12px;
        padding: 12px;
        transition: transform 0.2s;
    }
    .comment-bubble:hover {
        transform: translateX(4px);
        background: rgba(255, 255, 255, 0.08);
    }

    /* Timeline Stepper CSS */
    .timeline-flow {
        position: relative;
        padding-left: 10px;
    }
    .timeline-step {
        position: relative;
        border-left: 2px solid var(--border-glass);
        padding-bottom: 1.5rem;
    }
    .timeline-step:last-child {
        border-left: 2px solid transparent;
        padding-bottom: 0;
    }
    .timeline-step::before {
        content: '';
        position: absolute;
        left: -6px;
        top: 6px;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: var(--bs-primary);
        box-shadow: 0 0 0 3px rgba(var(--bs-primary-rgb), 0.2);
    }
    .timeline-step.active::before {
        background-color: var(--bs-success);
        box-shadow: 0 0 0 3px rgba(var(--bs-success-rgb), 0.2);
    }
    /* Premium Vote Buttons */
    .vote-btn-agree {
        background: linear-gradient(135deg, #0d6efd, #0a58ca);
        color: white;
        border: none;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 6px rgba(13, 110, 253, 0.2);
    }
    .vote-btn-agree:hover, .vote-btn-agree.vote-active {
        background: linear-gradient(135deg, #0a58ca, #084298);
        color: white;
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 6px 12px rgba(13, 110, 253, 0.4);
    }
    
    .vote-btn-disagree {
        background: linear-gradient(135deg, #dc3545, #b02a37);
        color: white;
        border: none;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 4px 6px rgba(220, 53, 69, 0.2);
    }
    .vote-btn-disagree:hover, .vote-btn-disagree.vote-active {
        background: linear-gradient(135deg, #b02a37, #842029);
        color: white;
        transform: translateY(-2px) scale(1.02);
        box-shadow: 0 6px 12px rgba(220, 53, 69, 0.4);
    }
</style>

<div class="row g-3 mt-0">
    <!-- Left Column: Issue Content, Images & Comments -->
    <div class="col-lg-7">
        <div class="d-flex flex-column gap-3">
            
            <!-- Issue Details Card -->
            <div class="glass-card p-3">
                
                <!-- Header Info -->
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
                    <div class="d-flex align-items-center gap-3">
                        <h4 class="fw-bold mb-0 text-dark" style="line-height: 1.4;">@Model.Title</h4>
                        <span class="badge @GetStatusClass(Model.Status) rounded-pill px-3 py-2 shadow-sm" style="font-size: 0.85rem;">
                            @GetStatusName(Model.Status)
                        </span>
                    </div>
                    <span class="text-muted" style="font-size: 0.85rem;">
                        <i class="bi bi-clock me-1"></i> @Model.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")
                    </span>
                </div>

                <div class="d-flex flex-wrap align-items-center gap-3 mb-3 pb-3 border-bottom border-secondary border-opacity-25 text-muted" style="font-size: 0.9rem;">
                    <div class="d-flex align-items-center gap-2">
                        <div class="bg-primary bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center" style="width: 28px; height: 28px;">
                            <i class="bi bi-person-fill text-primary" style="font-size: 0.85rem;"></i>
                        </div>
                        <span class="text-dark fw-medium">@(Model.IsAnonymous ? "Ẩn danh" : Model.Author?.FullName ?? "Công dân")</span>
                    </div>
                    <span>•</span>
                    <span><i class="bi bi-tag-fill text-primary me-1"></i> @GetCategoryName(Model.Category)</span>
                    <span>•</span>
                    <span><i class="bi bi-eye-fill me-1"></i> @Model.ViewCount lượt xem</span>
                </div>

                <!-- Images Carousel -->
                @if (Model.Images != null && Model.Images.Any())
                {
                    <div class="issue-carousel-wrapper mb-4">
                        <div id="imagesCarousel" class="carousel slide w-100 h-100" data-bs-ride="carousel">
                            <div class="carousel-inner h-100">
                                @{ var first = true; }
                                @foreach (var img in Model.Images.OrderBy(i => i.OrderIndex))
                                {
                                    <div class="carousel-item h-100 @(first ? "active" : "")">
                                        <img src="@img.Url" class="d-block issue-carousel-img" />
                                    </div>
                                    first = false;
                                }
                            </div>
                            @if (Model.Images.Count > 1)
                            {
                                <button class="carousel-control-prev" type="button" data-bs-target="#imagesCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true" style="filter: drop-shadow(0 0 4px #000);"></span>
                                    <span class="visually-hidden">Previous</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#imagesCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true" style="filter: drop-shadow(0 0 4px #000);"></span>
                                    <span class="visually-hidden">Next</span>
                                </button>
                            }
                        </div>
                    </div>
                }

                <!-- Content Description -->
                <div class="mb-3">
                    <h6 class="fw-bold mb-2 text-dark d-flex align-items-center gap-2">
                        <i class="bi bi-card-text text-primary"></i> Nội dung chi tiết
                    </h6>
                    <div class="text-secondary" style="line-height: 1.6; white-space: pre-line; font-size: 0.95rem;">
                        @Model.Description
                    </div>
                </div>

                <!-- Address Box -->
                <div class="p-3 rounded-3 mb-3" style="background: rgba(var(--bs-primary-rgb), 0.05); border: 1px dashed rgba(var(--bs-primary-rgb), 0.3);">
                    <h6 class="fw-bold mb-2 text-dark"><i class="bi bi-geo-alt-fill text-danger me-2"></i> Địa điểm sự việc</h6>
                    <p class="text-secondary mb-1">@Model.Address</p>
                    <div class="text-muted" style="font-size: 0.85rem;">
                        <span class="badge bg-secondary bg-opacity-25 text-dark me-2">P/X: @Model.WardName</span>
                        <span class="badge bg-secondary bg-opacity-25 text-dark">Q/H: @Model.DistrictName</span>
                    </div>
                </div>

                <!-- Action Bar (Vote & Share) -->
                <div class="d-flex flex-wrap justify-content-between align-items-center mt-3 pt-3 border-top border-secondary border-opacity-25">
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-sm rounded-pill vote-btn vote-btn-agree px-4 py-2 d-flex align-items-center gap-2 fw-medium" data-id="@Model.Id" data-type="1">
                            <i class="bi bi-hand-thumbs-up-fill fs-6"></i>
                            <span>Đồng tình (<strong id="upvotes-count">@Model.Votes.Count(v => v.Type == VoteType.Up)</strong>)</span>
                        </button>
                        <button class="btn btn-sm rounded-pill vote-btn vote-btn-disagree px-4 py-2 d-flex align-items-center gap-2 fw-medium" data-id="@Model.Id" data-type="-1">
                            <i class="bi bi-hand-thumbs-down-fill fs-6"></i>
                            <span>Không đồng tình (<strong id="downvotes-count">@Model.Votes.Count(v => v.Type == VoteType.Down)</strong>)</span>
                        </button>
                    </div>
                    <div class="d-flex align-items-center gap-3 mt-3 mt-md-0">
                        <div class="d-flex gap-2">
                            <a href="https://www.facebook.com/sharer/sharer.php?u=@encodedUrl" target="_blank" class="btn btn-sm btn-light text-primary rounded-circle shadow-sm border" style="width:32px; height:32px; display:flex; align-items:center; justify-content:center;" title="Chia sẻ Facebook">
                                <i class="bi bi-facebook fs-6"></i>
                            </a>
                            <a href="https://sp.zalo.me/plugins/share?link=@encodedUrl" target="_blank" class="btn btn-sm btn-light text-info rounded-circle shadow-sm border" style="width:32px; height:32px; display:flex; align-items:center; justify-content:center;" title="Chia sẻ Zalo">
                                <i class="bi bi-chat-fill fs-6"></i>
                            </a>
                        </div>
                        <div class="text-muted" style="font-size: 0.95rem;">
                            <i class="bi bi-chat-dots-fill text-primary me-1"></i> 
                            <strong id="comments-counter" class="text-dark">@Model.Comments.Count</strong> bình luận
                        </div>
                    </div>
                </div>
            </div>

            <!-- Rating Section for Author -->
            @if ((Model.Status == IssueStatus.Resolved || Model.Status == IssueStatus.Closed) && Model.AuthorId == currentUserId)
            {
                <div class="glass-card p-3 mt-2" id="rating-section">
                    <h6 class="fw-bold mb-2 text-dark"><i class="bi bi-star-fill text-warning me-2"></i> Đánh giá kết quả xử lý</h6>
                    @if (Model.Rating.HasValue)
                    {
                        <div class="p-3 rounded-3" style="background: rgba(var(--bs-success-rgb), 0.1); border: 1px solid rgba(var(--bs-success-rgb), 0.3);">
                            <div class="d-flex align-items-center mb-2">
                                <span class="fw-bold me-2">Bạn đã đánh giá:</span>
                                <div class="text-warning fs-5">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= Model.Rating.Value ? "bi-star-fill" : "bi-star")"></i>
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.RatingFeedback))
                            {
                                <p class="mb-0 text-secondary font-italic">"@Model.RatingFeedback"</p>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-3 rounded-3" style="background: rgba(var(--bs-warning-rgb), 0.1); border: 1px dashed rgba(var(--bs-warning-rgb), 0.5);">
                            <p class="mb-2 text-dark">Phản ánh này đã được giải quyết. Vui lòng đánh giá mức độ hài lòng của bạn.</p>
                            <div class="d-flex gap-2 text-warning fs-3 mb-3" id="star-rating" style="cursor: pointer;">
                                <i class="bi bi-star star-item" data-val="1"></i>
                                <i class="bi bi-star star-item" data-val="2"></i>
                                <i class="bi bi-star star-item" data-val="3"></i>
                                <i class="bi bi-star star-item" data-val="4"></i>
                                <i class="bi bi-star star-item" data-val="5"></i>
                            </div>
                            <textarea id="rating-feedback" class="form-control mb-3" rows="2" placeholder="Nhận xét thêm (Không bắt buộc)..."></textarea>
                            <button id="submit-rating-btn" class="btn btn-warning fw-bold text-dark w-100" data-id="@Model.Id">Gửi đánh giá</button>
                        </div>
                    }
                </div>
            }

            <div class="glass-card p-3 mt-2">
                <h6 class="fw-bold mb-3 text-dark"><i class="bi bi-chat-square-quote-fill text-primary me-2"></i> Thảo luận</h6>
                
                <!-- New Comment Form -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="comment-box-wrapper mb-3 shadow-sm">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <img src="@(UserManager.GetUserAsync(User).Result?.AvatarUrl ?? "/images/default-avatar.png")" 
                                     onerror="this.onerror=null; this.src='/images/default-avatar.png';" 
                                     class="rounded-circle shadow-sm border border-2 border-primary border-opacity-25" 
                                     style="width: 32px; height: 32px; object-fit: cover;" />
                                <strong class="text-dark" style="font-size: 0.95rem;">@(UserManager.GetUserAsync(User).Result?.FullName ?? "Bạn")</strong>
                            </div>
                            <button class="btn btn-sm btn-primary rounded-pill px-3" id="submit-comment-btn" data-id="@Model.Id">
                                <i class="bi bi-send-fill me-1"></i> Gửi bình luận
                            </button>
                        </div>
                        <div class="w-100">
                            <textarea id="new-comment-content" class="form-control bg-light text-dark border-0 px-3 py-2 shadow-sm" 
                                      rows="2" placeholder="Chia sẻ góc nhìn của bạn về vấn đề này..."
                                      style="resize: none; border-radius: 8px;"></textarea>
                        </div>
                    </div>
                }
                else
                {
                    <div class="glass-card p-3 text-center mb-3" style="border-style: dashed;">
                        <i class="bi bi-person-lock fs-3 text-muted mb-2 d-block"></i>
                        <p class="mb-2 text-secondary" style="font-size: 0.9rem;">Bạn cần đăng nhập để thảo luận.</p>
                        <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="/Issues/Details/@Model.Id" class="btn btn-sm btn-primary rounded-pill px-4">
                            Đăng nhập
                        </a>
                    </div>
                }

                <!-- Comments List -->
                <div class="d-flex flex-column gap-3" id="comments-list-container">
                    @if (Model.Comments == null || !Model.Comments.Any())
                    {
                        <div class="text-center text-muted py-5" id="comments-empty-state">
                            <img src="/images/default-avatar.png" class="opacity-25 mb-3" style="width: 64px;" />
                            <p class="mb-0">Chưa có bình luận nào. Hãy là người đầu tiên chia sẻ ý kiến!</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var comment in Model.Comments.Where(c => c.ParentCommentId == null).OrderByDescending(c => c.CreatedAt))
                        {
                            <div class="comment-bubble shadow-sm">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="@(comment.Author?.AvatarUrl ?? "/images/default-avatar.png")" 
                                             onerror="this.onerror=null; this.src='/images/default-avatar.png';" 
                                             class="rounded-circle border" style="width: 40px; height: 40px; object-fit: cover;" />
                                        
                                        <div>
                                            <div class="fw-bold @(comment.IsOfficialResponse ? "text-warning" : "text-dark")" style="font-size: 0.95rem;">
                                                @comment.Author?.FullName
                                                @if (comment.IsOfficialResponse)
                                                {
                                                    <span class="badge bg-primary ms-2"><i class="bi bi-check-circle-fill me-1"></i> Cán bộ</span>
                                                }
                                            </div>
                                            <div class="text-muted" style="font-size: 0.75rem;">@comment.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-secondary mt-2 ms-5 ps-2" style="font-size: 0.95rem; line-height: 1.6;">@comment.Content</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Map Coordinates & Timeline Status History -->
    <div class="col-lg-5">
        <div class="d-flex flex-column gap-3 position-sticky" style="top: 80px;">
            
            <!-- Mini Map Card -->
            <div class="glass-card p-3">
                <h6 class="fw-bold mb-2 text-dark"><i class="bi bi-map-fill text-primary me-2"></i> Bản đồ sự cố</h6>
                <div class="rounded-3 position-relative shadow-sm" style="height: 200px; border: 1px solid var(--border-glass); overflow: hidden; background-color: #f8f9fa;">
                    @{
                        // Tính toán bounding box cho OpenStreetMap iframe
                        var lonStr = Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var latStr = Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var lonMin = (Model.Longitude - 0.002).ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var latMin = (Model.Latitude - 0.002).ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var lonMax = (Model.Longitude + 0.002).ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var latMax = (Model.Latitude + 0.002).ToString(System.Globalization.CultureInfo.InvariantCulture);
                        var mapUrl = $"https://www.openstreetmap.org/export/embed.html?bbox={lonMin}%2C{latMin}%2C{lonMax}%2C{latMax}&layer=mapnik&marker={latStr}%2C{lonStr}";
                    }
                    <iframe width="100%" height="100%" frameborder="0" scrolling="no" marginheight="0" marginwidth="0" src="@mapUrl" style="border: none; pointer-events: none;"></iframe>
                </div>
                <div class="mt-2 p-2 rounded-3 bg-dark bg-opacity-25 text-center">
                    <span class="text-muted d-block mb-1" style="font-size: 0.75rem;">TỌA ĐỘ</span>
                    <strong class="text-primary font-monospace" style="font-size: 0.85rem;">@Model.Latitude, @Model.Longitude</strong>
                </div>
            </div>

            <!-- Processing Timeline Audit History -->
            <div class="glass-card p-3">
                <h6 class="fw-bold mb-3 text-dark"><i class="bi bi-hourglass-split text-primary me-2"></i> Tiến độ xử lý</h6>
                
                <div class="timeline-flow mt-3">
                    @if (Model.StatusHistory != null && Model.StatusHistory.Any())
                    {
                        @foreach (var hist in Model.StatusHistory.OrderByDescending(h => h.ChangedAt))
                        {
                            <div class="timeline-step active position-relative ps-4 pb-3">
                                <!-- Line and dot are handled by .timeline-step css -->
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <strong class="text-dark">@GetStatusName(hist.ToStatus)</strong>
                                    <span class="badge bg-secondary bg-opacity-25 text-muted fw-normal">@hist.ChangedAt.AddHours(7).ToString("dd/MM HH:mm")</span>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(hist.Note))
                                {
                                    <div class="text-secondary mt-2 p-2 rounded-2" style="font-size: 0.85rem; line-height: 1.4; background: rgba(255,255,255,0.03);">
                                        @hist.Note.Replace("Khá»Ÿi táº¡o pháº£n Ã¡nh má»›i.", "Khởi tạo phản ánh mới.").Replace("Di chuyển trạng thái thẻ trên bảng Kanban", "Đang phân công")
                                        <span class="text-muted ms-1" style="font-size: 0.8rem;">
                                            - <i class="bi bi-person-circle"></i> @(hist.ChangedBy?.FullName ?? "Hệ thống")
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted mt-2 d-flex align-items-center gap-1" style="font-size: 0.75rem;">
                                        <i class="bi bi-person-circle"></i> @(hist.ChangedBy?.FullName ?? "Hệ thống")
                                    </div>
                                }
                                
                                @if (!string.IsNullOrEmpty(hist.AttachmentUrl))
                                {
                                    <div class="mt-2">
                                        <a href="@hist.AttachmentUrl" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill py-1 px-3" style="font-size: 0.75rem;">
                                            <i class="bi bi-file-earmark-check me-1"></i> Văn bản đính kèm
                                        </a>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-info-circle mb-2 d-block fs-4"></i>
                            <span style="font-size: 0.85rem;">Hệ thống đang tiếp nhận, chưa có cập nhật tiến độ.</span>
                        </div>
                    }
                </div>
            </div>
            
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // 1. AJAX Biểu quyết
            $('.vote-btn').on('click', function() {
                const isAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");
                if (!isAuthenticated) {
                    window.location.href = `/Identity/Account/Login?ReturnUrl=${encodeURIComponent(window.location.pathname)}`;
                    return;
                }

                const issueId = $(this).data('id');
                const voteType = $(this).data('type');
                const btn = $(this);

                $.post(`/Issues/Vote`, { id: issueId, type: voteType }, function(res) {
                    if (res.success) {
                        $('#upvotes-count').text(res.upvotes);
                        $('#downvotes-count').text(res.downvotes);
                        
                        // Thêm hiệu ứng nhấp nháy cho nút siêu nhanh
                        btn.addClass('vote-active');
                        setTimeout(() => {
                            btn.removeClass('vote-active');
                        }, 150);
                    }
                }).fail(function() {
                    alert("Có lỗi xảy ra hoặc bạn chưa đăng nhập.");
                });
            });

            // 2. AJAX Gửi bình luận
            $('#submit-comment-btn').on('click', function() {
                const issueId = $(this).data('id');
                const contentText = $('#new-comment-content').val().trim();
                const btn = $(this);

                if (contentText === "") {
                    alert("Vui lòng nhập nội dung bình luận.");
                    $('#new-comment-content').focus();
                    return;
                }

                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-1"></span> Đang gửi...');

                $.post(`/Issues/Comment`, { id: issueId, content: contentText }, function(res) {
                    if (res.success) {
                        // Xóa nội dung ô nhập
                        $('#new-comment-content').val('');
                        $('#comments-empty-state').remove();

                        // Tạo thẻ HTML cho bình luận mới
                        const officialBadge = res.isOfficial ? `<span class="badge bg-primary ms-2"><i class="bi bi-check-circle-fill me-1"></i> Cán bộ</span>` : '';
                        const textClass = res.isOfficial ? 'text-warning' : 'text-dark';

                        const commentHtml = `
                            <div class="comment-bubble shadow-sm" style="animation: fadeIn 0.5s ease;">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="${res.authorAvatar}" onerror="this.onerror=null; this.src='/images/default-avatar.png';" class="rounded-circle border" style="width: 40px; height: 40px; object-fit: cover;" />
                                        <div>
                                            <div class="fw-bold ${textClass}" style="font-size: 0.95rem;">
                                                ${res.authorName} ${officialBadge}
                                            </div>
                                            <div class="text-muted" style="font-size: 0.75rem;">${res.createdAt}</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-secondary mt-2 ms-5 ps-2" style="font-size: 0.95rem; line-height: 1.6;">${res.content}</div>
                            </div>
                        `;
                        
                        $('#comments-list-container').prepend(commentHtml);

                        // Cập nhật số lượng bình luận
                        let count = parseInt($('#comments-counter').text()) || 0;
                        $('#comments-counter').text(count + 1);
                    }
                }).fail(function() {
                    alert("Gửi bình luận không thành công.");
                }).always(function() {
                    btn.prop('disabled', false).html('<i class="bi bi-send-fill me-1"></i> Gửi bình luận');
                });
            });
            // 3. Rating Logic
            let selectedRating = 0;
            $('.star-item').on('mouseover', function() {
                const val = $(this).data('val');
                $('.star-item').each(function() {
                    if ($(this).data('val') <= val) {
                        $(this).removeClass('bi-star').addClass('bi-star-fill');
                    } else {
                        $(this).removeClass('bi-star-fill').addClass('bi-star');
                    }
                });
            }).on('mouseout', function() {
                $('.star-item').each(function() {
                    if ($(this).data('val') <= selectedRating) {
                        $(this).removeClass('bi-star').addClass('bi-star-fill');
                    } else {
                        $(this).removeClass('bi-star-fill').addClass('bi-star');
                    }
                });
            }).on('click', function() {
                selectedRating = $(this).data('val');
            });

            $('#submit-rating-btn').on('click', function() {
                if (selectedRating === 0) {
                    alert('Vui lòng chọn số sao đánh giá!');
                    return;
                }
                const btn = $(this);
                const issueId = btn.data('id');
                const feedback = $('#rating-feedback').val();

                btn.prop('disabled', true).text('Đang gửi...');
                $.post('/Issues/Rate', { id: issueId, rating: selectedRating, feedback: feedback }, function(res) {
                    if (res.success) {
                        location.reload(); // Reload trang để hiện kết quả đã đánh giá
                    }
                }).fail(function(err) {
                    alert('Có lỗi xảy ra: ' + (err.responseText || 'Vui lòng thử lại sau.'));
                    btn.prop('disabled', false).text('Gửi đánh giá');
                });
            });
        });
    </script>
}

@functions {
    public string GetCategoryName(IssueCategory category) => category switch
    {
        IssueCategory.Traffic => "Giao thông",
        IssueCategory.Environment => "Môi trường",
        IssueCategory.Security => "An ninh trật tự",
        IssueCategory.Infrastructure => "Hạ tầng công cộng",
        IssueCategory.Administration => "Hành chính",
        _ => "Khác"
    };

    public string GetStatusName(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "Chờ tiếp nhận",
        IssueStatus.Assigned => "Đã phân công",
        IssueStatus.Processing => "Đang xử lý",
        IssueStatus.Resolved => "Đã giải quyết",
        IssueStatus.Rejected => "Từ chối",
        IssueStatus.Closed => "Đóng tự động",
        _ => "Không xác định"
    };

    public string GetStatusClass(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "bg-warning text-dark",
        IssueStatus.Assigned => "bg-info text-white",
        IssueStatus.Processing => "bg-primary text-white",
        IssueStatus.Resolved => "bg-success text-white",
        IssueStatus.Rejected => "bg-danger text-white",
        _ => "bg-secondary text-white"
    };
}
