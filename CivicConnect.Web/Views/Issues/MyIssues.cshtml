@model IEnumerable<CivicConnect.Core.Entities.Issue>
@using CivicConnect.Core.Enums
@{
    ViewData["Title"] = "Phản ánh của tôi";
}

<div class="d-flex flex-column gap-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h4 class="fw-bold mb-1 text-primary"><i class="bi bi-person-workspace me-2"></i> Phản ánh của tôi</h4>
            <p class="text-muted mb-0" style="font-size: 0.85rem;">Danh sách các ý kiến phản ánh do bạn đã gửi lên hệ thống.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill shadow-sm"><i class="bi bi-plus-lg me-1"></i> Gửi phản ánh mới</a>
    </div>

    @if (!Model.Any())
    {
        <div class="glass-card text-center py-5">
            <i class="bi bi-file-earmark-lock text-muted fs-1 d-block mb-3"></i>
            <h5 class="fw-semibold">Bạn chưa gửi phản ánh nào</h5>
            <p class="text-muted">Đóng góp ý kiến của bạn về các vấn đề giao thông, môi trường... để giúp cải thiện đô thị tốt đẹp hơn.</p>
            <a asp-action="Create" class="btn btn-primary rounded-pill mt-2">Bắt đầu gửi phản ánh</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var issue in Model)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="glass-card h-100 d-flex flex-column" style="overflow: hidden;">
                        <div class="position-relative" style="height: 160px; background-color: #cbd5e1;">
                            @if (issue.Images != null && issue.Images.Any())
                            {
                                <img src="@issue.Images.OrderBy(img => img.OrderIndex).First().Url" class="w-100 h-100" style="object-fit: cover;" />
                            }
                            else
                            {
                                <div class="w-100 h-100 d-flex flex-column align-items-center justify-content-center text-muted">
                                    <i class="bi bi-image fs-1 mb-1"></i>
                                    <span style="font-size: 0.85rem;">Không có hình ảnh</span>
                                </div>
                            }
                            <span class="position-absolute top-3 start-3 badge bg-white text-dark shadow-sm d-flex align-items-center gap-1 border" style="top: 10px; left: 10px; font-size: 0.75rem;">
                                <i class="bi @GetCategoryIcon(issue.Category) text-primary"></i> @GetCategoryName(issue.Category)
                            </span>
                        </div>

                        <div class="p-4 flex-grow-1 d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <h6 class="fw-bold text-dark text-truncate mb-0" style="max-width: 80%;"><a asp-action="Details" asp-route-id="@issue.Id" class="text-decoration-none text-dark">@issue.Title</a></h6>
                                <span class="badge @GetStatusClass(issue.Status) rounded-pill" style="font-size: 0.7rem; font-weight: 600;">@GetStatusName(issue.Status)</span>
                            </div>

                            <p class="text-secondary mb-3 flex-grow-1 text-clamp" style="font-size: 0.85rem; line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 2.8em;">
                                @issue.Description
                            </p>

                            <div class="d-flex align-items-center gap-2 mb-3 text-muted" style="font-size: 0.75rem;">
                                <i class="bi bi-geo-alt-fill text-danger"></i>
                                <span class="text-truncate" style="max-width: 250px;">@issue.Address</span>
                            </div>

                            <div class="border-top pt-3 mt-auto d-flex justify-content-between align-items-center" style="font-size: 0.8rem;">
                                <span class="text-muted"><i class="bi bi-hand-thumbs-up-fill text-primary me-1"></i> @issue.Votes.Count(v => v.Type == VoteType.Up) đồng ý</span>
                                <span class="text-muted">Gửi ngày @issue.CreatedAt.ToString("dd/MM/yyyy")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@functions {
    public string GetCategoryName(IssueCategory category) => category switch
    {
        IssueCategory.Traffic => "Giao thông",
        IssueCategory.Environment => "Môi trường",
        IssueCategory.Security => "An ninh trật tự",
        IssueCategory.Infrastructure => "Hạ tầng công cộng",
        IssueCategory.Administration => "Hành chính",
        _ => "Khác"
    };

    public string GetCategoryIcon(IssueCategory category) => category switch
    {
        IssueCategory.Traffic => "bi-car-front-fill",
        IssueCategory.Environment => "bi-tree-fill",
        IssueCategory.Security => "bi-shield-fill-exclamation",
        IssueCategory.Infrastructure => "bi-cone-striped",
        IssueCategory.Administration => "bi-file-earmark-person",
        _ => "bi-question-circle-fill"
    };

    public string GetStatusName(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "Chờ tiếp nhận",
        IssueStatus.Assigned => "Đã phân công",
        IssueStatus.Processing => "Đang xử lý",
        IssueStatus.Resolved => "Đã giải quyết",
        IssueStatus.Rejected => "Từ chối",
        IssueStatus.Closed => "Đóng tự động",
        _ => "Không xác định"
    };

    public string GetStatusClass(IssueStatus status) => status switch
    {
        IssueStatus.Pending => "bg-warning text-dark",
        IssueStatus.Assigned => "bg-info text-white",
        IssueStatus.Processing => "bg-primary text-white",
        IssueStatus.Resolved => "bg-success text-white",
        IssueStatus.Rejected => "bg-danger text-white",
        _ => "bg-secondary text-white"
    };
}
