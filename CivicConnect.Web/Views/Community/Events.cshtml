@model IEnumerable<CivicConnect.Web.Models.Entities.CommunityEvent>
@{
    ViewData["Title"] = "Sự kiện Cộng đồng";
    var userRegistrations = ViewBag.UserRegistrations as List<int> ?? new List<int>();
    var isOfficialOrAdmin = User.IsInRole("Admin") || User.IsInRole("OfficialWard") || User.IsInRole("OfficialDistrict") || User.IsInRole("OfficialProvince") || User.IsInRole("DepartmentStaff");
}

<div class="row mb-4 align-items-center">
    <div class="col-lg-8">
        <h2 class="fw-bold mb-1 text-dark" style="font-family: var(--font-display); font-size: 2rem;">Lịch Sự kiện & Tình nguyện</h2>
        <p class="text-muted mb-0">Tham gia các hoạt động cộng đồng, chung tay xây dựng môi trường sống tốt đẹp hơn.</p>
    </div>
    @if (isOfficialOrAdmin)
    {
        <div class="col-lg-4 text-md-end mt-3 mt-lg-0">
            <button class="btn btn-primary rounded-pill px-4 shadow-sm fw-semibold" data-bs-toggle="modal" data-bs-target="#createEventModal">
                <i class="bi bi-plus-lg me-2"></i> Tạo sự kiện
            </button>
        </div>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success rounded-3 border-0 bg-success bg-opacity-10 text-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger rounded-3 border-0 bg-danger bg-opacity-10 text-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var ev in Model)
        {
            var isRegistered = userRegistrations.Contains(ev.Id);
            var isFull = ev.Registrations?.Count >= ev.MaxParticipants;
            var isPast = ev.StartTime < DateTime.UtcNow;
            
            <div class="col-md-6 col-lg-4">
                <div class="glass-card h-100 border-0 shadow-sm rounded-4 overflow-hidden bg-white hover-lift" style="border-radius: var(--radius-lg); transition: all 0.3s ease;">
                    @if (!string.IsNullOrEmpty(ev.ImageUrl))
                    {
                        <img src="@ev.ImageUrl" class="card-img-top" alt="Event Image" style="height: 180px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="card-img-top bg-light d-flex justify-content-center align-items-center" style="height: 180px;">
                            <i class="bi bi-calendar-event display-3 text-primary opacity-25"></i>
                        </div>
                    }
                    
                    <div class="card-body p-4 position-relative">
                        <div class="position-absolute top-0 end-0 bg-primary text-white text-center rounded-bottom px-3 py-2 shadow-sm" style="margin-right: 20px; transform: translateY(-100%);">
                            <h4 class="fw-bold mb-0">@ev.StartTime.ToString("dd")</h4>
                            <small>Thg @ev.StartTime.ToString("MM")</small>
                        </div>

                        <div class="mb-3 mt-2">
                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fw-semibold">
                                <i class="bi bi-clock me-1"></i> @ev.StartTime.ToString("HH:mm") - @ev.EndTime.ToString("HH:mm")
                            </span>
                        </div>
                        
                        <h5 class="fw-bold mb-2" style="font-family: var(--font-display); font-size: 1.25rem;">@ev.Title</h5>
                        <p class="text-secondary small mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5;">@ev.Description</p>
                        
                        <div class="d-flex align-items-center text-muted small mb-2">
                            <i class="bi bi-geo-alt-fill text-danger me-2"></i> @ev.Location
                        </div>
                        <div class="d-flex justify-content-between align-items-center text-muted small mb-4">
                            <span><i class="bi bi-person-badge-fill text-primary me-2"></i> @ev.Organizer</span>
                            <span class="fw-bold">@(ev.Registrations?.Count ?? 0) / @ev.MaxParticipants</span>
                        </div>

                        @if (isPast)
                        {
                            <button class="btn btn-secondary w-100 rounded-pill fw-bold py-2" disabled>Đã diễn ra</button>
                        }
                        else if (isRegistered)
                        {
                            <button class="btn btn-outline-success w-100 rounded-pill fw-bold py-2" disabled>
                                <i class="bi bi-check-circle-fill me-2"></i>Bạn đã đăng ký
                            </button>
                        }
                        else if (isFull)
                        {
                            <button class="btn btn-warning w-100 rounded-pill fw-bold text-dark py-2" disabled>
                                <i class="bi bi-x-circle me-2"></i>Đã đủ số lượng
                            </button>
                        }
                        else
                        {
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-action="RegisterEvent" method="post">
                                    <input type="hidden" name="eventId" value="@ev.Id" />
                                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold shadow-sm py-2">Đăng ký tham gia</button>
                                </form>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-outline-primary w-100 rounded-pill fw-bold shadow-sm py-2">
                                    <i class="bi bi-lock-fill me-2"></i>Đăng nhập để đăng ký
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-calendar-x display-1 text-muted opacity-25 mb-3 d-block"></i>
            <h5 class="text-muted">Chưa có sự kiện nào</h5>
        </div>
    }
</div>

@if (isOfficialOrAdmin)
{
    <!-- Modal Tạo sự kiện -->
    <div class="modal modal-blur fade" id="createEventModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content" style="border-radius: var(--radius-lg); border: none;">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold" style="font-family: var(--font-display); font-size: 1.25rem;">Tạo sự kiện cộng đồng mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="CreateEvent" method="post">
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">Tên sự kiện</label>
                            <input type="text" class="form-control rounded-3" name="title" required placeholder="VD: Ngày hội dọn rác bãi biển, Chiến dịch trồng cây...">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">Mô tả sự kiện</label>
                            <textarea class="form-control rounded-3" name="description" rows="4" required placeholder="Mô tả cụ thể hoạt động và mục tiêu sự kiện..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">Địa điểm</label>
                            <input type="text" class="form-control rounded-3" name="location" required placeholder="VD: Nhà văn hóa khu phố 2, Công viên Hoa Lư...">
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-dark">Thời gian bắt đầu</label>
                                <input type="datetime-local" class="form-control rounded-3" name="startTime" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-dark">Thời gian kết thúc</label>
                                <input type="datetime-local" class="form-control rounded-3" name="endTime" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-dark">Đơn vị tổ chức</label>
                                <input type="text" class="form-control rounded-3" name="organizer" value="Ủy ban Nhân dân Phường" placeholder="VD: Đoàn Thanh niên Phường...">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-dark">Số lượng giới hạn</label>
                                <input type="number" class="form-control rounded-3" name="maxParticipants" value="100" min="5" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-top p-3">
                        <button type="button" class="btn btn-link link-secondary me-auto text-decoration-none" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm py-2"><i class="bi bi-calendar-plus me-2"></i>Tạo sự kiện</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    .hover-lift {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .hover-lift:hover {
        transform: translateY(-5px) !important;
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08) !important;
    }
</style>
