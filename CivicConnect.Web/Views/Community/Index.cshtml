@using CivicConnect.Web.Models.Entities
@using CivicConnect.Web.Models.Enums
@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Mạng Xã Hội Cộng Đồng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var trendingTopics = ViewBag.TrendingTopics as IEnumerable<TrendingTopic>;
    var topCitizens = ViewBag.TopCitizens as IEnumerable<dynamic>;
    var currentTab = ViewBag.CurrentTab as string ?? "newest";
}

<div class="container-xl mt-4">
    <div class="row">
        <!-- Cột trái: Feed (Bài viết + Phản ánh) -->
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="page-title">
                    Bảng tin Cộng đồng
                </h2>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createPostModal">
                    <i class="bi bi-plus-lg me-2"></i> Tạo bài viết
                </button>
            </div>

            <!-- Tabs -->
            <ul class="nav nav-pills mb-4">
                <li class="nav-item">
                    <a class="nav-link @(currentTab == "newest" ? "active" : "")" href="?tab=newest">
                        <i class="bi bi-clock-history me-1"></i> Mới nhất
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(currentTab == "trending" ? "active text-danger bg-danger-lt" : "text-danger")" href="?tab=trending">
                        <i class="bi bi-fire me-1"></i> Được quan tâm
                    </a>
                </li>
            </ul>

            <!-- Feed List -->
            <div class="feed-list space-y">
                @if (!Model.Any())
                {
                    <div class="empty">
                        <div class="empty-icon"><i class="bi bi-inbox text-muted"></i></div>
                        <p class="empty-title">Chưa có bài viết nào</p>
                    </div>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        if (item.Type == "Post")
                        {
                            <!-- Post Card -->
                            <div class="card mb-3">
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="avatar bg-blue-lt me-3">
                                            <i class="bi bi-person"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold">@item.AuthorName</div>
                                            <div class="text-muted fs-sm">@(((DateTime)item.CreatedAt).ToString("dd/MM/yyyy HH:mm"))</div>
                                        </div>
                                        <div class="ms-auto text-muted">
                                            <i class="bi bi-chat-text"></i> Bài đăng
                                        </div>
                                    </div>
                                    <h3 class="card-title"><a href="/Community/PostDetail/@item.Id" class="text-reset">@item.Title</a></h3>
                                    <p class="text-muted">
                                        @if (((string)item.Content).Length > 150)
                                        {
                                            @(((string)item.Content).Substring(0, 150) + "...")
                                        }
                                        else
                                        {
                                            @item.Content
                                        }
                                    </p>
                                    @if (!string.IsNullOrEmpty((string)item.Tags))
                                    {
                                        <div class="mb-3">
                                            @foreach (var tag in ((string)item.Tags).Split(',', StringSplitOptions.RemoveEmptyEntries))
                                            {
                                                <span class="badge bg-secondary-lt me-1">#@tag.Trim()</span>
                                            }
                                        </div>
                                    }
                                    <div class="d-flex align-items-center mt-3">
                                        <button class="btn btn-action text-danger border-0 bg-transparent btn-like" data-post-id="@item.Id">
                                            <i class="bi bi-heart me-1"></i> <span class="like-count">@item.LikeCount</span>
                                        </button>
                                        <a href="/Community/PostDetail/@item.Id" class="btn btn-action text-muted border-0 bg-transparent ms-3">
                                            <i class="bi bi-chat me-1"></i> @item.CommentCount
                                        </a>
                                        @if (item.PopularityScore >= 20)
                                        {
                                            <span class="badge bg-danger-lt ms-auto"><i class="bi bi-fire me-1"></i> Đang hot</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        else if (item.Type == "Issue")
                        {
                            <!-- Issue Card -->
                            <div class="card mb-3 border-start border-4 border-warning">
                                <div class="card-body">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="avatar bg-warning-lt me-3">
                                            <i class="bi bi-exclamation-triangle"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold">@item.AuthorName</div>
                                            <div class="text-muted fs-sm">@(((DateTime)item.CreatedAt).ToString("dd/MM/yyyy HH:mm"))</div>
                                        </div>
                                        <div class="ms-auto">
                                            <span class="badge @(item.Status == IssueStatus.Resolved ? "bg-success" : "bg-warning")">
                                                @(item.Status == IssueStatus.Resolved ? "Đã giải quyết" : "Đang xử lý")
                                            </span>
                                        </div>
                                    </div>
                                    <h3 class="card-title"><a href="/Issues/Details/@item.Id" class="text-reset">@item.Title</a></h3>
                                    <p class="text-muted mb-2">
                                        <i class="bi bi-geo-alt me-1"></i> @item.Address
                                    </p>
                                    <p class="text-muted">
                                        @if (((string)item.Content).Length > 150)
                                        {
                                            @(((string)item.Content).Substring(0, 150) + "...")
                                        }
                                        else
                                        {
                                            @item.Content
                                        }
                                    </p>
                                    <div class="d-flex align-items-center mt-3">
                                        <a href="/Issues/Details/@item.Id" class="btn btn-action text-muted border-0 bg-transparent">
                                            <i class="bi bi-chat me-1"></i> @item.CommentCount
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        </div>

        <!-- Cột phải: Widgets -->
        <div class="col-lg-4">
            <!-- Đề xuất chức năng khác -->
            <div class="card mb-3">
                <div class="card-body">
                    <h3 class="card-title">Khám phá Cộng đồng</h3>
                    <div class="list-group list-group-flush list-group-hoverable">
                        <a href="@Url.Action("Polls")" class="list-group-item list-group-item-action d-flex align-items-center">
                            <span class="avatar bg-info-lt me-3"><i class="bi bi-bar-chart"></i></span>
                            <div>Thăm dò ý kiến</div>
                        </a>
                        <a href="@Url.Action("Petitions")" class="list-group-item list-group-item-action d-flex align-items-center">
                            <span class="avatar bg-teal-lt me-3"><i class="bi bi-pen"></i></span>
                            <div>Kiến nghị điện tử</div>
                        </a>
                        <a href="@Url.Action("Events")" class="list-group-item list-group-item-action d-flex align-items-center">
                            <span class="avatar bg-purple-lt me-3"><i class="bi bi-calendar-event"></i></span>
                            <div>Sự kiện sắp tới</div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Trending Topics -->
            <div class="card mb-3">
                <div class="card-header">
                    <h3 class="card-title text-danger"><i class="bi bi-fire me-2"></i> Chủ đề nổi bật</h3>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        @if (trendingTopics != null && trendingTopics.Any())
                        {
                            foreach (var topic in trendingTopics)
                            {
                                <a href="#" class="btn btn-outline-secondary btn-sm">
                                    #@topic.Tag <span class="badge bg-secondary-lt ms-2">@topic.PostCount</span>
                                </a>
                            }
                        }
                        else
                        {
                            <span class="text-muted">Chưa có chủ đề nổi bật</span>
                        }
                    </div>
                }
            </div>

            <!-- Bảng Vàng (Leaderboard) -->
            <div class="card mb-3">
                <div class="card-header border-0 pb-0">
                    <h3 class="card-title text-warning"><i class="bi bi-trophy-fill me-2"></i> Bảng vàng danh dự</h3>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @if (topCitizens != null && topCitizens.Any())
                        {
                            int rank = 1;
                            foreach (var citizen in topCitizens)
                            {
                                <div class="list-group-item d-flex align-items-center">
                                    <div class="me-3 fw-bold @(rank <= 3 ? "text-warning" : "text-muted")">
                                        #@rank
                                    </div>
                                    <div class="avatar bg-green-lt me-3">
                                        <i class="bi bi-person"></i>
                                    </div>
                                    <div class="flex-fill">
                                        <div class="fw-bold">@citizen.FullName</div>
                                        <div class="text-muted fs-sm">@citizen.UserName</div>
                                    </div>
                                    <div class="fw-bold text-success">
                                        @citizen.CitizenPoints <span class="fs-sm">điểm</span>
                                    </div>
                                </div>
                                rank++;
                            }
                        }
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 text-center">
                    <a href="/Leaderboard" class="text-muted">Xem tất cả →</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Tạo bài viết -->
<div class="modal modal-blur fade" id="createPostModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tạo bài viết mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="CreatePost" method="post">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Tiêu đề</label>
                        <input type="text" class="form-control" name="title" required placeholder="Nhập tiêu đề...">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nội dung</label>
                        <textarea class="form-control" name="content" rows="6" required placeholder="Bạn muốn chia sẻ điều gì?"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hashtags</label>
                        <input type="text" class="form-control" name="tags" placeholder="VD: giaothong, an_ninh (cách nhau bởi dấu phẩy)">
                    </div>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i> Bài viết của bạn sẽ được gửi tới Ban Quản Trị để phê duyệt trước khi hiển thị trên Bảng tin. Nếu được duyệt, bạn sẽ nhận được <strong>+10 điểm thưởng</strong>.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-link link-secondary me-auto" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-send me-2"></i> Gửi bài viết</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Xử lý nút Like bằng AJAX
            $('.btn-like').click(function (e) {
                e.preventDefault();
                var btn = $(this);
                var postId = btn.data('post-id');
                var icon = btn.find('i');
                
                $.post('/Community/LikePost', { postId: postId }, function (res) {
                    if (res.success) {
                        btn.find('.like-count').text(res.likes);
                        icon.removeClass('bi-heart').addClass('bi-heart-fill text-danger');
                        btn.addClass('bounce-anim');
                        setTimeout(() => btn.removeClass('bounce-anim'), 1000);
                    } else {
                        alert("Có lỗi xảy ra hoặc bạn chưa đăng nhập.");
                    }
                });
            });
        });
    </script>
    <style>
        .bounce-anim i {
            display: inline-block;
            animation: bounce 0.3s;
        }
        @@keyframes bounce {
            0% { transform: scale(1); }
            50% { transform: scale(1.4); }
            100% { transform: scale(1); }
        }
    </style>
}
