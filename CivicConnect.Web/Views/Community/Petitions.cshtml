@model IEnumerable<CivicConnect.Web.Models.Entities.Petition>
@{
    ViewData["Title"] = "Kiến nghị điện tử";
    var userSignatures = ViewBag.UserSignatures as List<int> ?? new List<int>();
    var isOfficial = User.IsInRole("OfficialWard") || User.IsInRole("OfficialDistrict") || User.IsInRole("OfficialProvince") || User.IsInRole("DepartmentStaff");
}

<div class="row mb-4 align-items-center">
    <div class="col-lg-8">
        <h2 class="fw-bold mb-1 text-dark" style="font-family: var(--font-display); font-size: 2rem;">Kiến nghị điện tử</h2>
        <p class="text-muted mb-0">Thu thập chữ ký trực tuyến để đề xuất các thay đổi chính sách từ cộng đồng.</p>
    </div>
    @if (User.Identity?.IsAuthenticated == true && !isOfficial)
    {
        <div class="col-lg-4 text-md-end mt-3 mt-lg-0">
            <button class="btn btn-danger rounded-pill px-4 shadow-sm fw-semibold" data-bs-toggle="modal" data-bs-target="#createPetitionModal">
                <i class="bi bi-plus-lg me-2"></i> Tạo kiến nghị mới
            </button>
        </div>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success rounded-3 border-0 bg-success bg-opacity-10 text-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger rounded-3 border-0 bg-danger bg-opacity-10 text-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var petition in Model)
        {
            var isSigned = userSignatures.Contains(petition.Id);
            var percentage = petition.TargetSignatures > 0 ? (int)Math.Min(100, Math.Round((double)petition.CurrentSignatures / petition.TargetSignatures * 100)) : 0;
            
            <div class="col-lg-6">
                <div class="glass-card h-100 border-0 shadow-sm p-4 bg-white hover-lift" style="border-radius: var(--radius-lg); transition: all 0.3s ease;">
                    <div class="card-body p-2">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-danger bg-opacity-10 text-danger rounded-pill px-3 py-1.5" style="font-size: 0.75rem;">Gửi: @petition.TargetAudience</span>
                            <span class="text-muted small fw-semibold"><i class="bi bi-clock me-1"></i>Hạn: @petition.EndDate.ToString("dd/MM/yyyy")</span>
                        </div>
                        <h4 class="fw-bold mt-3 mb-2" style="font-family: var(--font-display); font-size: 1.35rem;">@petition.Title</h4>
                        <p class="text-secondary mb-4" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; font-size: 0.95rem; line-height: 1.6;">@petition.Description</p>
                        
                        <div class="mb-4">
                            <div class="d-flex justify-content-between small fw-bold mb-2">
                                <span class="text-danger"><i class="bi bi-pen-fill me-1"></i>@petition.CurrentSignatures chữ ký</span>
                                <span class="text-muted">Mục tiêu: @petition.TargetSignatures</span>
                            </div>
                            <div class="progress rounded-pill" style="height: 10px;">
                                <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" role="progressbar" style="width: @percentage%;" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        </div>

                        @if (isSigned)
                        {
                            <button class="btn btn-outline-success w-100 rounded-pill fw-bold py-2" disabled>
                                <i class="bi bi-check2-circle me-2"></i>Đã ký tên ủng hộ
                            </button>
                        }
                        else if (petition.CurrentSignatures >= petition.TargetSignatures)
                        {
                            <button class="btn btn-secondary w-100 rounded-pill fw-bold py-2" disabled>
                                <i class="bi bi-flag-fill me-2"></i>Đã đạt mục tiêu chữ ký
                            </button>
                        }
                        else
                        {
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-action="SignPetition" method="post">
                                    <input type="hidden" name="petitionId" value="@petition.Id" />
                                    <button type="submit" class="btn btn-danger w-100 rounded-pill fw-bold shadow-sm py-2">
                                        <i class="bi bi-pen me-2"></i>Ký tên ủng hộ ngay
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-outline-danger w-100 rounded-pill fw-bold shadow-sm py-2">
                                    <i class="bi bi-lock-fill me-2"></i>Đăng nhập để ký tên
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-file-earmark-text display-1 text-muted opacity-25 mb-3 d-block"></i>
            <h5 class="text-muted">Chưa có kiến nghị nào</h5>
        </div>
    }
</div>

@if (User.Identity?.IsAuthenticated == true && !isOfficial)
{
    <!-- Modal Tạo kiến nghị -->
    <div class="modal modal-blur fade" id="createPetitionModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content" style="border-radius: var(--radius-lg); border: none;">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold" style="font-family: var(--font-display); font-size: 1.25rem;">Tạo kiến nghị mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="CreatePetition" method="post">
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">Tiêu đề kiến nghị</label>
                            <input type="text" class="form-control rounded-3" name="title" required placeholder="VD: Kiến nghị mở rộng công viên khu phố 4...">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">Nội dung chi tiết</label>
                            <textarea class="form-control rounded-3" name="description" rows="5" required placeholder="Mô tả cụ thể nguyện vọng và lý do kiến nghị..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">Cơ quan tiếp nhận</label>
                            <input type="text" class="form-control rounded-3" name="targetAudience" value="Ủy ban Nhân dân Quận" placeholder="VD: UBND Phường Bến Nghé, Sở Giao thông vận tải...">
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-dark">Mục tiêu chữ ký</label>
                                <input type="number" class="form-control rounded-3" name="targetSignatures" value="500" min="50" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold text-dark">Thời hạn thu thập (ngày)</label>
                                <input type="number" class="form-control rounded-3" name="durationDays" value="30" min="5" max="180" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-top p-3">
                        <button type="button" class="btn btn-link link-secondary me-auto text-decoration-none" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm"><i class="bi bi-send me-2"></i> Gửi kiến nghị</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    .hover-lift {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .hover-lift:hover {
        transform: translateY(-5px) !important;
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08) !important;
    }
</style>
