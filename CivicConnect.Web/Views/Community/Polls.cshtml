@model IEnumerable<CivicConnect.Web.Models.Entities.Poll>
@{
    ViewData["Title"] = "Thăm dò ý kiến";
    var userVotes = ViewBag.UserVotes as List<int> ?? new List<int>();
    var isOfficialOrAdmin = User.IsInRole("Admin") || User.IsInRole("OfficialWard") || User.IsInRole("OfficialDistrict") || User.IsInRole("OfficialProvince") || User.IsInRole("DepartmentStaff");
}

<div class="row mb-4 align-items-center">
    <div class="col-lg-8">
        <h2 class="fw-bold mb-1 text-dark" style="font-family: var(--font-display); font-size: 2rem;">Thăm dò ý kiến cộng đồng</h2>
        <p class="text-muted mb-0">Đóng góp ý kiến và biểu quyết các vấn đề quan trọng của địa phương.</p>
    </div>
    @if (isOfficialOrAdmin)
    {
        <div class="col-lg-4 text-md-end mt-3 mt-lg-0">
            <button class="btn btn-warning text-dark rounded-pill px-4 shadow-sm fw-semibold" data-bs-toggle="modal" data-bs-target="#createPollModal">
                <i class="bi bi-plus-lg me-2"></i> Tạo cuộc thăm dò
            </button>
        </div>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success rounded-3 border-0 bg-success bg-opacity-10 text-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger rounded-3 border-0 bg-danger bg-opacity-10 text-danger alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var poll in Model)
        {
            var totalVotes = poll.Options.Sum(o => o.VoteCount);
            var isVoted = userVotes.Contains(poll.Id);
            var isExpired = poll.EndDate < DateTime.UtcNow;
            
            <div class="col-md-6 col-lg-4">
                <div class="glass-card h-100 border-0 shadow-sm p-3 bg-white hover-lift" style="border-radius: var(--radius-lg); transition: all 0.3s ease;">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            @if (isExpired)
                            {
                                <span class="badge bg-secondary text-white rounded-pill px-3 py-1.5" style="font-size: 0.75rem;">Đã kết thúc</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark rounded-pill px-3 py-1.5" style="font-size: 0.75rem;">Đang diễn ra</span>
                            }
                            <span class="text-muted small"><i class="bi bi-people-fill me-1"></i>@totalVotes lượt bình chọn</span>
                        </div>
                        
                        <h5 class="fw-bold mb-2" style="font-family: var(--font-display); font-size: 1.25rem;">@poll.Question</h5>
                        <p class="text-secondary small mb-4">@poll.Description</p>
                        
                        @if (isVoted || isExpired)
                        {
                            <!-- Kết quả -->
                            <div class="d-flex flex-column gap-3 mb-3">
                                @foreach (var option in poll.Options)
                                {
                                    var percentage = totalVotes > 0 ? (int)Math.Round((double)option.VoteCount / totalVotes * 100) : 0;
                                    <div>
                                        <div class="d-flex justify-content-between small fw-semibold mb-1">
                                            <span class="text-dark">@option.Text</span>
                                            <span class="text-primary">@percentage%</span>
                                        </div>
                                        <div class="progress rounded-pill" style="height: 8px;">
                                            <div class="progress-bar bg-primary rounded-pill" role="progressbar" style="width: @percentage%;" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                            @if (isVoted)
                            {
                                <div class="text-success small fw-bold mt-3 text-center"><i class="bi bi-check-circle-fill me-1"></i>Bạn đã tham gia bình chọn</div>
                            }
                        }
                        else
                        {
                            <!-- Form bình chọn -->
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <form asp-action="VotePoll" method="post">
                                    <input type="hidden" name="pollId" value="@poll.Id" />
                                    <div class="d-flex flex-column gap-2 mb-4">
                                        @foreach (var option in poll.Options)
                                        {
                                            <label class="btn btn-outline-primary text-start rounded-3 py-2 px-3 fw-medium" style="font-size: 0.9rem;">
                                                <input type="radio" name="optionId" value="@option.Id" class="me-2" required>
                                                @option.Text
                                            </label>
                                        }
                                    </div>
                                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-semibold shadow-sm">Gửi bình chọn</button>
                                </form>
                            }
                            else
                            {
                                <div class="d-flex flex-column gap-2 mb-4">
                                    @foreach (var option in poll.Options)
                                    {
                                        <div class="border rounded-3 py-2 px-3 text-muted bg-light border-light opacity-75 small">
                                            @option.Text
                                        </div>
                                    }
                                </div>
                                <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-outline-primary w-100 rounded-pill fw-semibold shadow-sm">
                                    <i class="bi bi-lock-fill me-1"></i> Đăng nhập để bình chọn
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-bar-chart-fill display-1 text-muted opacity-25 mb-3 d-block"></i>
            <h5 class="text-muted">Chưa có cuộc khảo sát nào</h5>
        </div>
    }
</div>

@if (isOfficialOrAdmin)
{
    <!-- Modal Tạo cuộc thăm dò -->
    <div class="modal modal-blur fade" id="createPollModal" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered" role="document">
            <div class="modal-content" style="border-radius: var(--radius-lg); border: none;">
                <div class="modal-header border-bottom">
                    <h5 class="modal-title fw-bold" style="font-family: var(--font-display); font-size: 1.25rem;">Tạo cuộc khảo sát / Thăm dò mới</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="CreatePoll" method="post">
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">Câu hỏi khảo sát</label>
                            <input type="text" class="form-control rounded-3" name="question" required placeholder="VD: Bạn thấy tiến độ làm đường Nguyễn Hữu Thọ thế nào?">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">Mô tả chi tiết</label>
                            <textarea class="form-control rounded-3" name="description" rows="3" placeholder="Nhập thêm thông tin ngữ cảnh khảo sát..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">Thời hạn khảo sát (ngày)</label>
                            <input type="number" class="form-control rounded-3" name="durationDays" value="7" min="1" max="90" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold text-dark">Các phương án lựa chọn</label>
                            <div id="poll-options-container" class="d-flex flex-column gap-2">
                                <input type="text" class="form-control rounded-3" name="options" required placeholder="Phương án 1">
                                <input type="text" class="form-control rounded-3" name="options" required placeholder="Phương án 2">
                            </div>
                            <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill px-3 mt-2" onclick="addPollOptionField()">
                                <i class="bi bi-plus-circle me-1"></i> Thêm phương án
                            </button>
                        </div>
                    </div>
                    <div class="modal-footer border-top p-3">
                        <button type="button" class="btn btn-link link-secondary me-auto text-decoration-none" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-warning rounded-pill px-4 fw-bold text-dark shadow-sm">Tạo thăm dò</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function addPollOptionField() {
            var container = document.getElementById('poll-options-container');
            var count = container.getElementsByTagName('input').length + 1;
            var input = document.createElement('input');
            input.type = 'text';
            input.className = 'form-control rounded-3';
            input.name = 'options';
            input.placeholder = 'Phương án ' + count;
            container.appendChild(input);
        }
    </script>
}

<style>
    .hover-lift {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .hover-lift:hover {
        transform: translateY(-5px) !important;
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08) !important;
    }
</style>
