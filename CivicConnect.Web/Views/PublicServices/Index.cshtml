@{
    ViewData["Title"] = "Tiện ích hành chính";
}

<div class="row align-items-center mb-5">
    <div class="col-lg-6 mb-4 mb-lg-0 pe-lg-5">
        <div class="d-inline-flex align-items-center gap-2 px-3 py-2 rounded-pill bg-primary bg-opacity-10 text-primary fw-semibold mb-3">
            <i class="bi bi-bank"></i> Hành chính điện tử
        </div>
        <h1 class="display-4 fw-bold text-dark mb-4" style="font-family: var(--font-display);">
            Dịch vụ công <span class="text-primary">thông minh</span>
        </h1>
        <p class="lead text-secondary mb-4">
            Tra cứu thủ tục, tìm kiếm danh bạ cơ quan và đặt lịch tiếp dân một cách nhanh chóng, minh bạch ngay trên nền tảng CivicConnect.
        </p>
        <div class="d-flex flex-wrap gap-3">
            <a asp-action="Procedures" class="btn btn-primary rounded-pill px-4 py-2 fw-semibold hover-scale shadow-sm">
                <i class="bi bi-search me-2"></i> Tra cứu thủ tục
            </a>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="glass-card p-2 rounded-4 shadow border border-primary border-opacity-25" style="background: linear-gradient(135deg, rgba(255,255,255,0.9), rgba(240,248,255,0.9));">
            <img src="https://images.unsplash.com/photo-1573164713714-d95e436ab8d6?q=80&w=1000&auto=format&fit=crop" class="img-fluid rounded-4 w-100" style="height: 350px; object-fit: cover;" alt="Dịch vụ công" />
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="glass-card p-4 rounded-4 shadow-sm h-100 text-center transition-hover border-top border-4 border-primary">
            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                <i class="bi bi-file-earmark-text text-primary fs-1"></i>
            </div>
            <h4 class="fw-bold mb-2">Thủ tục hành chính</h4>
            <p class="text-muted mb-4">Cơ sở dữ liệu các thủ tục, quy trình nộp hồ sơ, mức phí, và tải biểu mẫu trực tuyến.</p>
            <a asp-action="Procedures" class="btn btn-outline-primary rounded-pill px-4">Tra cứu ngay</a>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="glass-card p-4 rounded-4 shadow-sm h-100 text-center transition-hover border-top border-4 border-info">
            <div class="bg-info bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                <i class="bi bi-telephone-inbound text-info fs-1"></i>
            </div>
            <h4 class="fw-bold mb-2">Danh bạ cơ quan</h4>
            <p class="text-muted mb-4">Tìm kiếm thông tin liên hệ, địa chỉ, giờ làm việc của các cơ quan, đơn vị trên địa bàn.</p>
            <a asp-action="Directory" class="btn btn-outline-info rounded-pill px-4">Xem danh bạ</a>
        </div>
    </div>

    <div class="col-md-4">
        <div class="glass-card p-4 rounded-4 shadow-sm h-100 text-center transition-hover border-top border-4 border-warning">
            <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 70px; height: 70px;">
                <i class="bi bi-calendar-check text-warning fs-1"></i>
            </div>
            <h4 class="fw-bold mb-2">Lịch tiếp dân</h4>
            <p class="text-muted mb-4">Tra cứu lịch làm việc của lãnh đạo phường/quận và đăng ký lịch hẹn trực tuyến.</p>
            <a asp-action="Directory" class="btn btn-outline-warning rounded-pill px-4">Xem lịch hẹn</a>
        </div>
    </div>
</div>
