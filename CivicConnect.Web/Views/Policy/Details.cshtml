@model CivicConnect.Web.Models.Entities.Policy
@{
    ViewData["Title"] = Model.Title;
    bool isOfficialDoc = !string.IsNullOrEmpty(Model.DocumentNumber);
    ViewData["IsFullWidth"] = true;
}

@Html.AntiForgeryToken()

<style>
    .policy-detail-container-wrapper {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 15px;
    }
    .pulse-dot {
        width: 8px;
        height: 8px;
        background-color: #198754;
        border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.7);
        animation: pulsing 1.2s infinite;
    }
    @@keyframes pulsing {
        0% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0.7);
        }
        70% {
            transform: scale(1);
            box-shadow: 0 0 0 5px rgba(25, 135, 84, 0);
        }
        100% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(25, 135, 84, 0);
        }
    }
    .policy-detail-container {
        display: grid;
        grid-template-columns: 2.2fr 1fr;
        gap: 28px;
        margin-top: 20px;
    }
    @@media (max-width: 991px) {
        .policy-detail-container {
            grid-template-columns: 1fr;
        }
    }
    .policy-main-content {
        background: var(--card-bg, #ffffff);
        border: 1px solid var(--border-color, #e5e7eb);
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
    .policy-sidebar-meta {
        background: var(--card-bg, #ffffff);
        border: 1px solid var(--border-color, #e5e7eb);
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        align-self: start;
    }
    .official-seal {
        border: 2px solid #198754;
        border-radius: 12px;
        padding: 16px;
        background-color: #f4faf6;
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        border-left-width: 6px;
    }
    .seal-icon {
        font-size: 2.25rem;
        color: #198754;
    }
    .seal-text h5 {
        font-weight: 800;
        margin-bottom: 2px;
        color: #0f5132;
        font-size: 1rem;
    }
    .seal-text p {
        margin: 0;
        font-size: 0.8rem;
        color: #198754;
        font-weight: 600;
    }
    .policy-tag-badge {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: bold;
        padding: 4px 10px;
        border-radius: 6px;
        margin-bottom: 16px;
        text-transform: uppercase;
    }
    .policy-tag-badge.tag-law {
        background-color: #cfe2ff;
        color: #084298;
        border: 1px solid #b6d4fe;
    }
    .policy-tag-badge.tag-policy {
        background-color: #e2d9f3;
        color: #563d7c;
        border: 1px solid #d2c4ec;
    }
    .policy-tag-badge.tag-notice {
        background-color: #fff3cd;
        color: #664d03;
        border: 1px solid #ffecb5;
    }
    .policy-tag-badge.tag-news {
        background-color: #cff4fc;
        color: #087990;
        border: 1px solid #b6effb;
    }
    .document-title {
        font-family: var(--font-display, inherit);
        font-size: 1.75rem;
        font-weight: 850;
        line-height: 1.4;
        color: var(--gray-800, #111827);
        margin-bottom: 20px;
    }
    .document-body {
        font-size: 1.05rem;
        line-height: 1.8;
        color: #374151;
        white-space: pre-line;
    }
    .meta-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .meta-item {
        border-bottom: 1px solid #f3f4f6;
        padding-bottom: 8px;
    }
    .meta-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }
    .meta-label {
        font-size: 0.8rem;
        color: #6b7280;
        font-weight: 600;
        margin-bottom: 2px;
        text-transform: uppercase;
        display: block;
    }
    .meta-value {
        font-size: 0.925rem;
        color: #1f2937;
        font-weight: 700;
        display: block;
    }
    .scroll-btn {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        color: white;
        border: none;
        outline: none;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        cursor: pointer;
        display: none;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        box-shadow: 0 6px 18px rgba(99,102,241,0.45);
        transition: all 0.2s ease;
        z-index: 1000;
    }
    .scroll-btn:hover {
        transform: translateY(-4px) scale(1.08);
        box-shadow: 0 10px 24px rgba(99,102,241,0.55);
    }
    .status-badge {
        background-color: #d1e7dd;
        color: #0f5132;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: bold;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }
    /* Tabs styles */
    .nav-tabs {
        border-bottom: 2px solid var(--border-color, #e5e7eb) !important;
        margin-bottom: 20px;
    }
    .nav-tabs .nav-link {
        border: none !important;
        color: #6b7280 !important;
        padding: 12px 20px !important;
        font-weight: 700 !important;
        font-size: 0.95rem;
        transition: all 0.25s ease;
        background: transparent !important;
    }
    .nav-tabs .nav-link.active {
        color: #0d6efd !important;
        border-bottom: 3px solid #0d6efd !important;
        border-radius: 0;
    }
    .nav-tabs .nav-link:hover:not(.active) {
        color: #1f2937 !important;
        border-bottom: 3px solid #d1d5db !important;
        border-radius: 0;
    }
    .iframe-container {
        position: relative;
        width: 100%;
        height: 750px;
        border: 1px solid var(--border-color, #e5e7eb);
        border-radius: 12px;
        overflow: hidden;
        background: #f9fafb;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
    }

    /* ===== AI Chatbot - Full Redesign ===== */
    .ai-chat-wrapper {
        background: linear-gradient(160deg, #0f172a, #1e1b4b);
        border-radius: 18px;
        overflow: hidden;
        border: 1px solid rgba(99,102,241,0.3);
        box-shadow: 0 8px 32px rgba(99,102,241,0.2);
        margin-top: 20px;
    }
    .ai-chat-header {
        background: linear-gradient(90deg, rgba(99,102,241,0.25), rgba(59,130,246,0.15));
        border-bottom: 1px solid rgba(255,255,255,0.08);
        padding: 14px 18px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .ai-chat-avatar {
        width: 36px; height: 36px;
        border-radius: 10px;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem;
        flex-shrink: 0;
        box-shadow: 0 4px 12px rgba(99,102,241,0.5);
    }
    .ai-chat-header-info { flex: 1; }
    .ai-chat-header-info h4 {
        font-size: 0.9rem;
        font-weight: 800;
        color: #e2e8f0;
        margin: 0;
        line-height: 1.2;
    }
    .ai-chat-header-info small {
        font-size: 0.68rem;
        color: #64748b;
    }
    .ai-status-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: #22c55e;
        flex-shrink: 0;
        box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
        animation: pulseDot 2s infinite;
    }
    @@keyframes pulseDot {
        0%, 100% { box-shadow: 0 0 0 3px rgba(34,197,94,0.2); }
        50% { box-shadow: 0 0 0 6px rgba(34,197,94,0.1); }
    }
    .ai-chat-body {
        height: 320px;
        overflow-y: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        scroll-behavior: smooth;
        background: rgba(0,0,0,0.15);
    }
    .ai-chat-body::-webkit-scrollbar { width: 5px; }
    .ai-chat-body::-webkit-scrollbar-track { background: transparent; }
    .ai-chat-body::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
    .ai-msg {
        align-self: flex-start;
        max-width: 88%;
        position: relative;
    }
    .ai-msg-bubble {
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.1);
        color: #cbd5e1;
        padding: 10px 14px;
        border-radius: 4px 14px 14px 14px;
        font-size: 0.875rem;
        line-height: 1.6;
        backdrop-filter: blur(4px);
    }
    .ai-msg-meta {
        font-size: 0.65rem;
        color: #475569;
        margin-top: 3px;
        padding-left: 2px;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .ai-msg-meta .model-tag {
        background: rgba(99,102,241,0.2);
        color: #818cf8;
        padding: 1px 5px;
        border-radius: 4px;
        font-size: 0.6rem;
        font-weight: 700;
    }
    .user-msg {
        align-self: flex-end;
        max-width: 85%;
    }
    .user-msg-bubble {
        background: linear-gradient(135deg, #4f46e5, #3b82f6);
        color: white;
        padding: 10px 14px;
        border-radius: 14px 4px 14px 14px;
        font-size: 0.875rem;
        line-height: 1.55;
        box-shadow: 0 4px 12px rgba(79,70,229,0.4);
    }
    .user-msg-meta {
        font-size: 0.65rem;
        color: #475569;
        margin-top: 3px;
        text-align: right;
        padding-right: 2px;
    }
    .ai-chat-suggestions {
        padding: 10px 16px;
        border-top: 1px solid rgba(255,255,255,0.05);
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        background: rgba(0,0,0,0.1);
    }
    .suggestion-btn {
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        color: #94a3b8;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 5px 11px;
        border-radius: 50px;
        cursor: pointer;
        transition: all 0.18s ease;
    }
    .suggestion-btn:hover {
        background: rgba(99,102,241,0.2) !important;
        color: #a5b4fc !important;
        border-color: rgba(99,102,241,0.4) !important;
    }
    .ai-chat-input-area {
        padding: 12px 16px 14px;
        border-top: 1px solid rgba(255,255,255,0.06);
        background: rgba(0,0,0,0.2);
    }
    .ai-input-row {
        display: flex;
        gap: 8px;
        align-items: center;
    }
    .ai-input-field {
        flex: 1;
        background: rgba(255,255,255,0.06);
        border: 1px solid rgba(255,255,255,0.12);
        color: #e2e8f0;
        border-radius: 12px;
        padding: 10px 14px;
        font-size: 0.875rem;
        outline: none;
        transition: border-color 0.18s;
    }
    .ai-input-field::placeholder { color: #475569; }
    .ai-input-field:focus {
        border-color: rgba(99,102,241,0.5);
        background: rgba(99,102,241,0.06);
    }
    .ai-send-btn {
        width: 40px; height: 40px;
        border-radius: 12px;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        border: none;
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.9rem;
        cursor: pointer;
        flex-shrink: 0;
        transition: all 0.18s;
        box-shadow: 0 4px 12px rgba(99,102,241,0.4);
    }
    .ai-send-btn:hover { transform: scale(1.08); box-shadow: 0 6px 18px rgba(99,102,241,0.55); }
    .ai-send-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
    .ai-char-hint {
        display: flex;
        justify-content: space-between;
        margin-top: 6px;
        font-size: 0.65rem;
        color: #374151;
    }
    .ai-char-hint .shortcut { color: #6366f1; font-weight: 600; }
    .ai-lock-state {
        padding: 24px 20px;
        text-align: center;
    }
    .ai-lock-icon {
        width: 48px; height: 48px;
        border-radius: 14px;
        background: rgba(255,255,255,0.06);
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 12px;
        font-size: 1.3rem;
        color: #64748b;
    }
    .ai-lock-text { color: #64748b; font-size: 0.82rem; line-height: 1.5; }
    .ai-lock-text a { color: #818cf8; font-weight: 700; text-decoration: none; }
    .ai-lock-text a:hover { text-decoration: underline; }

    /* ===== Selection floating button ===== */
    #ai-selection-btn {
        display: none;
        position: fixed;
        z-index: 9999;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        color: #fff;
        border: none;
        border-radius: 20px;
        padding: 0.38rem 0.85rem;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        align-items: center;
        gap: 0.35rem;
        box-shadow: 0 4px 16px rgba(99,102,241,0.45);
        white-space: nowrap;
        animation: popIn 0.18s ease;
        transform-origin: bottom center;
        pointer-events: auto;
    }
    #ai-selection-btn.visible { display: inline-flex; }
    #ai-selection-btn:hover { opacity: 0.9; transform: scale(1.04); }

    @@keyframes popIn {
        from { opacity: 0; transform: scale(0.82); }
        to   { opacity: 1; transform: scale(1); }
    }

    /* ===== Selection explain popover ===== */
    #ai-explain-popover {
        display: none;
        position: fixed;
        z-index: 9998;
        width: min(420px, 92vw);
        max-height: min(600px, 85vh);
        background: #fff;
        border: 1px solid rgba(99,102,241,0.2);
        border-radius: 16px;
        box-shadow: 0 12px 40px rgba(0,0,0,0.15);
        overflow: hidden;
        animation: slideDownPopover 0.25s ease;
        flex-direction: column;
    }
    #ai-explain-popover.visible { display: flex; }

    @@keyframes slideDownPopover {
        from { opacity: 0; transform: translate(-50%, -60%); }
        to   { opacity: 1; transform: translate(-50%, -50%); }
    }

    .ep-header {
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        padding: 0.7rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }
    .ep-header-title {
        color: #fff;
        font-size: 0.82rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }
    .ep-close {
        background: rgba(255,255,255,0.2);
        border: none;
        color: #fff;
        border-radius: 50%;
        width: 22px; height: 22px;
        font-size: 0.75rem;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.15s;
    }
    .ep-close:hover { background: rgba(255,255,255,0.35); }

    .ep-body {
        padding: 1rem;
        overflow-y: auto;
        flex: 1;
    }

    .ep-quote {
        background: #f5f3ff;
        border-left: 3px solid #8b5cf6;
        border-radius: 0 8px 8px 0;
        padding: 0.5rem 0.75rem;
        font-size: 0.8rem;
        color: #5b21b6;
        line-height: 1.5;
        margin-bottom: 0.85rem;
        max-height: 120px;
        overflow-y: auto;
        font-style: italic;
    }

    .ep-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: #6366f1;
        margin-bottom: 0.3rem;
    }

    .ep-text {
        font-size: 0.9rem;
        color: #1f2937;
        line-height: 1.65;
        margin-bottom: 0.75rem;
    }

    .ep-key-term {
        background: #fef3c7;
        border: 1px solid #fde68a;
        border-radius: 8px;
        padding: 0.4rem 0.7rem;
        font-size: 0.82rem;
        color: #92400e;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: flex-start;
        gap: 0.4rem;
    }

    .ep-practical {
        background: rgba(59,130,246,0.07);
        border-left: 3px solid #3b82f6;
        border-radius: 0 8px 8px 0;
        padding: 0.4rem 0.7rem;
        font-size: 0.85rem;
        color: #1e3a5f;
        line-height: 1.6;
    }

    .ep-skeleton-line {
        background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 6px;
        height: 13px;
        margin-bottom: 8px;
    }
    .ep-skeleton-line.s { width: 50%; }
    .ep-skeleton-line.m { width: 75%; }
    .ep-skeleton-line.l { width: 95%; }

    .ep-footer {
        padding: 0.45rem 1rem;
        background: #f9fafb;
        border-top: 1px solid #f0f0f0;
        font-size: 0.7rem;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 0.35rem;
        flex-shrink: 0;
    }

    /* Vùng nội dung cho phép bôi đen */
    .selectable-content { user-select: text; cursor: text; }
</style>

<div class="policy-detail-container-wrapper py-3">
<div class="section-block fade-in-up">
    <!-- Nút quay lại -->
    <div class="mb-4">
        <a href="/Policy" class="btn btn-secondary text-decoration-none fw-semibold small">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="policy-detail-container">
        <!-- Phần nội dung chính -->
        <div class="policy-main-content">
            <!-- Dấu chứng thực (Nếu là văn bản chính thức) -->
            @if (isOfficialDoc)
            {
                <div class="official-seal">
                    <span class="seal-icon"><i class="bi bi-patch-check-fill"></i></span>
                    <div class="seal-text">
                        <h5>VĂN BẢN ĐÃ ĐƯỢC CHỨNG THỰC</h5>
                        <p><i class="bi bi-check-circle-fill"></i> Dữ liệu minh bạch từ Cổng Thông Tin Điện Tử Chính Phủ Việt Nam</p>
                    </div>
                </div>
            }

            <span class="policy-tag-badge @Model.TagClass">@Model.Tag</span>
            <h1 class="document-title">@Model.Title</h1>

            @if (!string.IsNullOrEmpty(Model.SourceUrl))
            {
                <ul class="nav nav-tabs" id="docTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="iframe-tab" data-bs-toggle="tab" data-bs-target="#iframe-panel" type="button" role="tab" aria-controls="iframe-panel" aria-selected="true">
                            <i class="bi bi-globe me-1"></i> Nội dung bài báo gốc
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary-panel" type="button" role="tab" aria-controls="summary-panel" aria-selected="false">
                            <i class="bi bi-file-text-fill me-1"></i> Tóm tắt & Giải thích
                        </button>
                    </li>
                </ul>
                <div class="tab-content" id="docTabsContent">
                    <div class="tab-pane fade show active" id="iframe-panel" role="tabpanel" aria-labelledby="iframe-tab">
                        <div class="iframe-container mt-3">
                            <div class="iframe-loading" id="iframe-load-spinner" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: #6b7280; z-index: 1;">
                                <div class="spinner-border text-primary mb-2" role="status"></div>
                                <div>Đang kết nối và tải trang gốc...</div>
                            </div>
                            <iframe src="/Policy/Proxy?url=@Uri.EscapeDataString(Model.SourceUrl)" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; z-index: 2; background: transparent;" onload="document.getElementById('iframe-load-spinner').style.display='none';"></iframe>
                        </div>
                        <div class="mt-2 d-flex justify-content-between align-items-center">
                            <span class="small text-muted"><i class="bi bi-info-circle"></i> Trang web được tải an toàn qua iframe. Nếu bị chặn, hãy bấm nút bên phải.</span>
                            <a href="@Model.SourceUrl" target="_blank" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-box-arrow-up-right"></i> Mở trang gốc trong tab mới
                            </a>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="summary-panel" role="tabpanel" aria-labelledby="summary-tab">
                        <div class="document-body mt-3 selectable-content" id="policy-content">
                            @if (Model.Id == 0)
                            {
                                <p class="lead text-secondary">@Model.Excerpt</p>
                                <hr />
                            }
                            @Html.Raw(Model.Content)
                        </div>
                        <div class="mt-4 pt-4 border-top">
                            <button onclick="$('#iframe-tab').click();" class="btn btn-primary fw-bold me-2">
                                <i class="bi bi-eye-fill"></i> Xem trực tiếp trang gốc tại đây
                            </button>
                            <a href="@Model.SourceUrl" target="_blank" class="btn btn-outline-secondary">
                                <i class="bi bi-box-arrow-up-right"></i> Mở trong tab mới
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="document-body selectable-content" id="policy-content">
                    @Html.Raw(Model.Content)
                </div>
            }
        </div>

        <!-- Phần thông tin văn bản bên lề (Công báo) -->
        <div class="policy-sidebar-meta">
            <h4 class="fw-bold border-bottom pb-2 mb-3 text-secondary" style="font-size: 1.05rem;">
                <i class="bi bi-info-circle-fill"></i> Thuộc tính văn bản
            </h4>
            
            <div class="meta-list">
                <div class="meta-item">
                    <span class="meta-label">Cơ quan ban hành</span>
                    <span class="meta-value">@Model.IssuingUnit</span>
                </div>
                
                @if (isOfficialDoc)
                {
                    <div class="meta-item">
                        <span class="meta-label">Số hiệu văn bản</span>
                        <span class="meta-value text-primary">@Model.DocumentNumber</span>
                    </div>
                    
                    <div class="meta-item">
                        <span class="meta-label">Loại văn bản</span>
                        <span class="meta-value">@Model.DocumentType</span>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Signer))
                    {
                        <div class="meta-item">
                            <span class="meta-label">Người ký</span>
                            <span class="meta-value">@Model.Signer</span>
                        </div>
                    }

                    @if (Model.EffectiveDate.HasValue)
                    {
                        <div class="meta-item">
                            <span class="meta-label">Ngày có hiệu lực</span>
                            <span class="meta-value">@Model.EffectiveDate.Value.ToString("dd/MM/yyyy")</span>
                        </div>
                    }

                    <div class="meta-item">
                        <span class="meta-label">Trạng thái hiệu lực</span>
                        <span class="meta-value">
                            <span class="status-badge"><i class="bi bi-check-circle-fill"></i> Còn hiệu lực</span>
                        </span>
                    </div>
                }

                <div class="meta-item">
                    <span class="meta-label">Ngày đăng tải công báo</span>
                    <span class="meta-value">@Model.PublishedDate.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>
        </div>

        <!-- Trợ lý pháp luật AI - Redesigned -->
        <div class="ai-chat-wrapper">
            <!-- Header -->
            <div class="ai-chat-header">
                <div class="ai-chat-avatar">🤖</div>
                <div class="ai-chat-header-info">
                    <h4>Trợ lý Pháp luật AI</h4>
                    <small>Powered by Gemini · Phân tích văn bản theo thời gian thực</small>
                </div>
                <div class="ai-status-dot" title="AI đang hoạt động"></div>
            </div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <!-- Chat Messages -->
                <div id="aiChatHistory" class="ai-chat-body">
                    <div class="ai-msg">
                        <div class="ai-msg-bubble">
                            👋 Xin chào! Tôi là <strong>AI Pháp luật CivicConnect</strong>, được huấn luyện để giải đáp mọi thắc mắc về văn bản này.<br/><br/>
                            Bạn có thể hỏi về: <strong>mức xử phạt, ngày hiệu lực, đối tượng áp dụng, cách thực hiện</strong> hoặc bất kỳ điều khoản nào bạn chưa rõ.
                        </div>
                        <div class="ai-msg-meta">
                            <span class="model-tag">Gemini AI</span>
                            <span>Vừa xong</span>
                        </div>
                    </div>
                </div>

                <!-- Quick Suggestions -->
                <div class="ai-chat-suggestions">
                    <span style="font-size:0.65rem; color:#475569; align-self:center; white-space:nowrap;">Gợi ý:</span>
                    <button class="suggestion-btn" onclick="askSuggestion('Tóm tắt nội dung chính của văn bản này')">📋 Tóm tắt nội dung</button>
                    <button class="suggestion-btn" onclick="askSuggestion('Ngày có hiệu lực của văn bản này là khi nào?')">📅 Ngày hiệu lực</button>
                    @if (isOfficialDoc)
                    {
                        <button class="suggestion-btn" onclick="askSuggestion('Mức xử phạt cụ thể trong văn bản này là bao nhiêu?')">⚖️ Mức phạt</button>
                        <button class="suggestion-btn" onclick="askSuggestion('Ai là đối tượng áp dụng của văn bản này?')">👥 Đối tượng áp dụng</button>
                    }
                    else
                    {
                        <button class="suggestion-btn" onclick="askSuggestion('Tin tức này có ảnh hưởng gì đến người dân?')">💬 Ảnh hưởng thế nào?</button>
                    }
                </div>

                <!-- Input Area -->
                <div class="ai-chat-input-area">
                    <div class="ai-input-row">
                        <input type="text" id="aiQuestionInput" class="ai-input-field"
                               placeholder="Đặt câu hỏi về văn bản này..."
                               onkeypress="if(event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); sendQuestion(); }"
                               oninput="updateCharCount(this)" maxlength="300" />
                        <button class="ai-send-btn" type="button" id="sendAiBtn" onclick="sendQuestion()" title="Gửi câu hỏi (Enter)">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                    <div class="ai-char-hint">
                        <span class="shortcut">⌨️ Enter để gửi</span>
                        <span id="charCountDisplay">0 / 300</span>
                    </div>
                </div>
            }
            else
            {
                <div class="ai-lock-state">
                    <div class="ai-lock-icon">🔒</div>
                    <div class="ai-lock-text">
                        Vui lòng <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Context.Request.Path">Đăng nhập</a> để sử dụng Trợ lý Pháp luật AI.
                        <br/><small>Phân tích văn bản · Giải thích điều khoản · Tra cứu mức phạt</small>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
</div> <!-- Đóng policy-detail-container-wrapper -->

<!-- Nút cuộn lên đầu trang (Scroll-to-top) -->
<button class="scroll-btn" id="scrollToTopBtn" title="Cuộn lên đầu trang">
    <i class="bi bi-arrow-up"></i>
</button>

@* ===== FLOATING SELECTION BUTTON ===== *@
<button id="ai-selection-btn" title="AI giải thích đoạn này">
    ✨ Giải thích
</button>

@* ===== EXPLAIN POPOVER ===== *@
<div id="ai-explain-popover">
    <div class="ep-header">
        <div class="ep-header-title">
            <span>🤖</span>
            <span>AI Giải Thích</span>
            <span style="background:rgba(255,255,255,0.25); font-size:0.65rem; padding:0.1rem 0.4rem; border-radius:10px;">Gemini</span>
        </div>
        <button class="ep-close" id="ep-close-btn" title="Đóng">×</button>
    </div>
    <div class="ep-body" id="ep-body">
        <!-- Content injected by JS -->
    </div>
    <div class="ep-footer">
        <i class="bi bi-lightning-charge-fill" style="color:#f59e0b;"></i>
        <span id="ep-model">Gemini AI</span>
        <span>• AI có thể mắc lỗi</span>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Lắng nghe sự kiện cuộn trang để hiện nút
            $(window).scroll(function() {
                if ($(this).scrollTop() > 300) {
                    $('#scrollToTopBtn').fadeIn().css('display', 'flex');
                } else {
                    $('#scrollToTopBtn').fadeOut();
                }
            });

            // Click cuộn lên đầu trang mượt mà
            $('#scrollToTopBtn').click(function() {
                $('html, body').animate({ scrollTop: 0 }, 300);
                return false;
            });

            // Tự động ẩn spinner sau 6 giây nếu tải quá lâu (timeout)
            setTimeout(function() {
                var spinner = $('#iframe-load-spinner');
                if (spinner.length && spinner.is(':visible')) {
                    spinner.fadeOut();
                }
            }, 6000);
        });

        function sendQuestion() {
            var input = $('#aiQuestionInput');
            var question = input.val().trim();
            if (!question) return;

            // Add user message to chat history
            var nowTime = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
            $('#aiChatHistory').append(
                '<div class="user-msg">' +
                '<div class="user-msg-bubble">' + escapeHtml(question) + '</div>' +
                '<div class="user-msg-meta">' + nowTime + '</div>' +
                '</div>'
            );
            input.val('');
            updateCharCount(input[0]);
            
            // Auto scroll chat to bottom
            var chatHistory = $('#aiChatHistory');
            chatHistory.scrollTop(chatHistory[0].scrollHeight);

            // Disable send button
            $('#sendAiBtn').prop('disabled', true);

            // Add typing indicator
            var typingId = 'typing-' + Date.now();
            chatHistory.append(
                '<div class="ai-msg" id="' + typingId + '">' +
                '<div class="ai-msg-bubble" style="display:flex; align-items:center; gap:8px;">' +
                '<span class="spinner-grow spinner-grow-sm" style="color:#818cf8; width:10px; height:10px;" role="status"></span>' +
                '<span style="color:#64748b; font-size:0.82rem;">Đang phân tích văn bản...</span>' +
                '</div>' +
                '</div>'
            );
            chatHistory.scrollTop(chatHistory[0].scrollHeight);

            // Send AJAX request
            var requestData = {
                Question: question,
                DocTitle: "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.Title))",
                DocContent: "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.Excerpt ?? Model.Content))",
                IssuingUnit: "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.IssuingUnit))",
                DocNumber: "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.DocumentNumber ?? ""))",
                Signer: "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.Signer ?? ""))",
                PublishedDate: "@Model.PublishedDate.ToString("o")",
                SourceUrl: "@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.SourceUrl ?? ""))"
            };

            $.ajax({
                url: '/Policy/AskAI',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(requestData),
                success: function(response) {
                    $('#' + typingId).remove();
                    var replyTime = new Date().toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' });
                    if (response.success) {
                        chatHistory.append(
                            '<div class="ai-msg">' +
                            '<div class="ai-msg-bubble">' + formatResponse(response.answer) + '</div>' +
                            '<div class="ai-msg-meta"><span class="model-tag">Gemini AI</span><span>' + replyTime + '</span></div>' +
                            '</div>'
                        );
                    } else {
                        chatHistory.append(
                            '<div class="ai-msg">' +
                            '<div class="ai-msg-bubble" style="color:#f87171; background:rgba(239,68,68,0.1); border-color:rgba(239,68,68,0.2);">' +
                            '<i class="bi bi-exclamation-circle-fill me-1"></i> Có lỗi xảy ra. Vui lòng thử lại.' +
                            '</div></div>'
                        );
                    }
                    chatHistory.scrollTop(chatHistory[0].scrollHeight);
                    $('#sendAiBtn').prop('disabled', false);
                },
                error: function() {
                    $('#' + typingId).remove();
                    chatHistory.append(
                        '<div class="ai-msg">' +
                        '<div class="ai-msg-bubble" style="color:#f87171; background:rgba(239,68,68,0.1); border-color:rgba(239,68,68,0.2);">' +
                        '<i class="bi bi-wifi-off me-1"></i> Lỗi kết nối máy chủ.' +
                        '</div></div>'
                    );
                    chatHistory.scrollTop(chatHistory[0].scrollHeight);
                    $('#sendAiBtn').prop('disabled', false);
                }
            });
        }

        function askSuggestion(question) {
            $('#aiQuestionInput').val(question);
            updateCharCount(document.getElementById('aiQuestionInput'));
            sendQuestion();
        }

        function updateCharCount(input) {
            var len = input ? input.value.length : 0;
            var display = document.getElementById('charCountDisplay');
            if (display) {
                display.textContent = len + ' / 300';
                display.style.color = len > 250 ? '#f87171' : '#475569';
            }
        }

        function escapeHtml(text) {
            return text
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function formatResponse(text) {
            // Convert markdown style **bold** to html
            // Replace newlines with <br/> for readable layout
            var formatted = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            return formatted.replace(/\n/g, '<br/>');
        }
    </script>

    <script>
        // ============================================================
        // GIẢI THÍCH ĐOẠN BÔI ĐEN (Text Selection AI Explain) - TÍCH HỢP CHATBOT
        // ============================================================
        (function () {
            const POLICY_ID  = @Model.Id;
            const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const selBtn     = document.getElementById('ai-selection-btn');
            const content    = document.getElementById('policy-content');

            let selectionTimeout = null;
            let currentSelected  = '';

            // Hiện floating button khi bôi đen trong vùng nội dung
            document.addEventListener('mouseup', function (e) {
                clearTimeout(selectionTimeout);
                selectionTimeout = setTimeout(function () {
                    const sel  = window.getSelection();
                    const text = sel ? sel.toString().trim() : '';

                    let isInContent = false;
                    if (text.length >= 5 && content && sel && sel.rangeCount > 0) {
                        const range = sel.getRangeAt(0);
                        isInContent = content.contains(sel.anchorNode)
                                   || content.contains(sel.focusNode)
                                   || range.intersectsNode(content);
                    }

                    if (isInContent) {
                        currentSelected = text;
                        positionSelectionBtn(e);
                    } else {
                        if (!selBtn.contains(e.target)) {
                            selBtn.classList.remove('visible');
                        }
                    }
                }, 160);
            });

            // Lắng nghe sự kiện bôi đen từ iframe báo gốc
            window.addEventListener('message', function (event) {
                if (!event.data) return;

                if (event.data.type === 'iframeTextSelected') {
                    currentSelected = event.data.text;
                    const iframe = document.querySelector('.iframe-container iframe');
                    if (iframe) {
                        const iframeRect = iframe.getBoundingClientRect();
                        const x = iframeRect.left + event.data.clientX;
                        const y = iframeRect.top + event.data.clientY;
                        
                        const fakeEvent = {
                            clientX: x,
                            clientY: y
                        };
                        positionSelectionBtn(fakeEvent);
                    }
                } else if (event.data.type === 'iframeSelectionCleared') {
                    selBtn.classList.remove('visible');
                }
            });

            const popover = document.getElementById('ai-explain-popover');
            const epBody  = document.getElementById('ep-body');
            const epClose = document.getElementById('ep-close-btn');

            // Thiết lập sự kiện click nút đóng popover
            if (epClose) {
                epClose.addEventListener('click', function (e) {
                    e.stopPropagation();
                    popover.classList.remove('visible');
                });
            }

            // Ẩn khi click ra ngoài
            document.addEventListener('mousedown', function (e) {
                if (!selBtn.contains(e.target)) {
                    selBtn.classList.remove('visible');
                }
                if (popover && !popover.contains(e.target) && !selBtn.contains(e.target)) {
                    popover.classList.remove('visible');
                }
            });

            function positionSelectionBtn(e) {
                const margin = 10;
                let x = e.clientX - 40;
                let y = e.clientY - 48;
                x = Math.max(margin, Math.min(x, window.innerWidth  - 130 - margin));
                y = Math.max(margin, Math.min(y, window.innerHeight - 40  - margin));
                selBtn.style.left = x + 'px';
                selBtn.style.top  = y + 'px';
                selBtn.classList.add('visible');
            }

            // Click nút “Giải thích”
            selBtn.addEventListener('click', function () {
                if (!currentSelected) return;
                selBtn.classList.remove('visible');

                // Định vị popover ở giữa màn hình
                popover.style.top = '50%';
                popover.style.left = '50%';
                popover.style.transform = 'translate(-50%, -50%)';
                popover.classList.add('visible');

                // Kiểm tra xem người dùng đã đăng nhập chưa
                const isAuthenticated = @(User.Identity?.IsAuthenticated == true ? "true" : "false");
                if (!isAuthenticated) {
                    epBody.innerHTML = `
                        <div class="text-danger p-2">
                            <i class="bi bi-lock-fill"></i> Vui lòng đăng nhập để sử dụng tính năng giải thích đoạn bôi đen.
                        </div>`;
                    return;
                }

                // Hiển thị trạng thái tải (Skeleton Loading)
                const displayQuote = currentSelected.length > 180 ? currentSelected.slice(0, 180) + '...' : currentSelected;
                epBody.innerHTML = `
                    <div class="ep-quote">"${escapeHtml(displayQuote)}"</div>
                    <div class="ep-label">💡 Ý nghĩa giản lược</div>
                    <div class="ep-skeleton-line l"></div>
                    <div class="ep-skeleton-line m"></div>
                    <div class="ep-skeleton-line s"></div>
                    
                    <div class="ep-label mt-3">⚖️ Tác động thực tế</div>
                    <div class="ep-skeleton-line l"></div>
                    <div class="ep-skeleton-line m"></div>
                `;
                document.getElementById('ep-model').textContent = 'Gemini AI';

                // Gửi yêu cầu giải thích qua AJAX
                $.ajax({
                    url: '/Policy/ExplainSelection',
                    type: 'POST',
                    headers: {
                        'RequestVerificationToken': TOKEN || ''
                    },
                    contentType: 'application/json',
                    data: JSON.stringify({ policyId: POLICY_ID, selectedText: currentSelected }),
                    success: function(response) {
                        if (response.success) {
                            let html = `
                                <div class="ep-quote">"${escapeHtml(currentSelected)}"</div>
                                <div class="ep-label">💡 Ý nghĩa giản lược</div>
                                <div class="ep-text">${formatResponse(response.simpleExplanation)}</div>
                            `;
                            
                            if (response.keyTerm) {
                                html += `
                                    <div class="ep-key-term">
                                        <i class="bi bi-journal-bookmark-fill" style="margin-top:2px;"></i>
                                        <div><strong>Thuật ngữ:</strong> ${formatResponse(response.keyTerm)}</div>
                                    </div>
                                `;
                            }
                            
                            html += `
                                <div class="ep-label mt-2">⚖️ Tác động thực tế</div>
                                <div class="ep-practical">${formatResponse(response.practicalMeaning)}</div>
                            `;
                            
                            epBody.innerHTML = html;
                            document.getElementById('ep-model').textContent = response.modelUsed || "Gemini AI";
                        } else {
                            epBody.innerHTML = `
                                <div class="text-danger p-2">
                                    <i class="bi bi-exclamation-circle-fill"></i> Có lỗi xảy ra: ${escapeHtml(response.error)}
                                </div>`;
                        }
                    },
                    error: function() {
                        epBody.innerHTML = `
                            <div class="text-danger p-2">
                                <i class="bi bi-exclamation-circle-fill"></i> Lỗi kết nối đến máy chủ.
                            </div>`;
                    }
                });

                // Xoá vùng bôi đen
                if (window.getSelection) {
                    window.getSelection().removeAllRanges();
                }
            });

            function escHtml(str) {
                return (str || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;');
            }
        })();
    </script>
}
