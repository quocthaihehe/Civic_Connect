@model CivicConnect.Web.Models.Entities.Policy
@{
    ViewData["Title"] = Model.Title;
}

@Html.AntiForgeryToken()

<style>
    /* ===== AI Summary Panel ===== */
    .ai-summary-panel {
        display: none;
        background: linear-gradient(135deg, rgba(99,102,241,0.06) 0%, rgba(59,130,246,0.08) 100%);
        border: 1px solid rgba(99,102,241,0.2);
        border-radius: 16px;
        padding: 1.5rem;
        margin: 1.5rem 0;
        animation: slideDown 0.35s ease;
        position: relative;
    }

    .ai-summary-panel.visible {
        display: block;
    }

    @@keyframes slideDown {
        from { opacity: 0; transform: translateY(-12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .ai-panel-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.2rem;
    }

    .ai-panel-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #4f46e5;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .ai-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        color: #fff;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
        letter-spacing: 0.03em;
    }

    .ai-close-btn {
        background: none;
        border: none;
        color: var(--gray-400, #9ca3af);
        cursor: pointer;
        font-size: 1.1rem;
        line-height: 1;
        padding: 0.2rem 0.4rem;
        border-radius: 6px;
        transition: background 0.15s, color 0.15s;
    }
    .ai-close-btn:hover { background: rgba(0,0,0,0.06); color: #374151; }

    /* Sections */
    .ai-section {
        margin-bottom: 1.1rem;
    }

    .ai-section-label {
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: #6366f1;
        margin-bottom: 0.4rem;
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .ai-section-text {
        font-size: 0.95rem;
        color: var(--gray-800, #1f2937);
        line-height: 1.7;
    }

    .ai-bullet-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .ai-bullet-list li {
        font-size: 0.93rem;
        color: var(--gray-800, #1f2937);
        padding: 0.3rem 0 0.3rem 1.4rem;
        position: relative;
        line-height: 1.6;
    }

    .ai-bullet-list li::before {
        content: "✦";
        position: absolute;
        left: 0;
        color: #6366f1;
        font-size: 0.65rem;
        top: 0.55rem;
    }

    .ai-example-box {
        background: rgba(59,130,246,0.07);
        border-left: 3px solid #3b82f6;
        border-radius: 0 8px 8px 0;
        padding: 0.7rem 1rem;
        font-size: 0.92rem;
        color: var(--gray-800, #1f2937);
        line-height: 1.7;
    }

    .ai-footer {
        margin-top: 1rem;
        padding-top: 0.75rem;
        border-top: 1px solid rgba(99,102,241,0.15);
        font-size: 0.75rem;
        color: var(--gray-400, #9ca3af);
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    /* ===== Skeleton loader ===== */
    .ai-skeleton {
        display: none;
    }

    .ai-skeleton.visible {
        display: block;
    }

    .skeleton-line {
        background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 6px;
        height: 14px;
        margin-bottom: 10px;
    }

    .skeleton-line.short  { width: 60%; }
    .skeleton-line.medium { width: 80%; }
    .skeleton-line.long   { width: 95%; }

    @@keyframes shimmer {
        0%   { background-position: 200% 0; }
        100% { background-position: -200% 0; }
    }

    /* ===== Nút AI ===== */
    #btn-ai-summarize {
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 0.55rem 1.2rem;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 2px 8px rgba(99,102,241,0.35);
    }

    #btn-ai-summarize:hover {
        opacity: 0.92;
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(99,102,241,0.45);
    }

    #btn-ai-summarize:disabled {
        opacity: 0.6;
        cursor: not-allowed;
        transform: none;
    }

    /* ===== Error toast ===== */
    .ai-error-toast {
        display: none;
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 10px;
        padding: 0.75rem 1rem;
        margin: 0.75rem 0;
        font-size: 0.88rem;
        color: #b91c1c;
        align-items: center;
        gap: 0.5rem;
    }

    .ai-error-toast.visible { display: flex; }

    /* ===== Selection floating button ===== */
    #ai-selection-btn {
        display: none;
        position: fixed;
        z-index: 9999;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        color: #fff;
        border: none;
        border-radius: 20px;
        padding: 0.38rem 0.85rem;
        font-size: 0.8rem;
        font-weight: 600;
        cursor: pointer;
        align-items: center;
        gap: 0.35rem;
        box-shadow: 0 4px 16px rgba(99,102,241,0.45);
        white-space: nowrap;
        animation: popIn 0.18s ease;
        transform-origin: bottom center;
        pointer-events: auto;
    }
    #ai-selection-btn.visible { display: inline-flex; }
    #ai-selection-btn:hover { opacity: 0.9; transform: scale(1.04); }

    @@keyframes popIn {
        from { opacity: 0; transform: scale(0.82); }
        to   { opacity: 1; transform: scale(1); }
    }

    /* ===== Selection explain popover ===== */
    #ai-explain-popover {
        display: none;
        position: fixed;
        z-index: 9998;
        width: min(380px, 92vw);
        background: #fff;
        border: 1px solid rgba(99,102,241,0.2);
        border-radius: 16px;
        box-shadow: 0 12px 40px rgba(0,0,0,0.15);
        overflow: hidden;
        animation: slideDown 0.25s ease;
    }
    #ai-explain-popover.visible { display: block; }

    .ep-header {
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        padding: 0.7rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .ep-header-title {
        color: #fff;
        font-size: 0.82rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }
    .ep-close {
        background: rgba(255,255,255,0.2);
        border: none;
        color: #fff;
        border-radius: 50%;
        width: 22px; height: 22px;
        font-size: 0.75rem;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.15s;
    }
    .ep-close:hover { background: rgba(255,255,255,0.35); }

    .ep-body { padding: 1rem; }

    .ep-quote {
        background: #f5f3ff;
        border-left: 3px solid #8b5cf6;
        border-radius: 0 8px 8px 0;
        padding: 0.4rem 0.7rem;
        font-size: 0.78rem;
        color: #5b21b6;
        line-height: 1.5;
        margin-bottom: 0.85rem;
        max-height: 56px;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .ep-label {
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: #6366f1;
        margin-bottom: 0.3rem;
    }

    .ep-text {
        font-size: 0.9rem;
        color: #1f2937;
        line-height: 1.65;
        margin-bottom: 0.75rem;
    }

    .ep-key-term {
        background: #fef3c7;
        border: 1px solid #fde68a;
        border-radius: 8px;
        padding: 0.4rem 0.7rem;
        font-size: 0.82rem;
        color: #92400e;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: flex-start;
        gap: 0.4rem;
    }

    .ep-practical {
        background: rgba(59,130,246,0.07);
        border-left: 3px solid #3b82f6;
        border-radius: 0 8px 8px 0;
        padding: 0.4rem 0.7rem;
        font-size: 0.85rem;
        color: #1e3a5f;
        line-height: 1.6;
    }

    .ep-skeleton-line {
        background: linear-gradient(90deg, #e5e7eb 25%, #f3f4f6 50%, #e5e7eb 75%);
        background-size: 200% 100%;
        animation: shimmer 1.4s infinite;
        border-radius: 6px;
        height: 13px;
        margin-bottom: 8px;
    }
    .ep-skeleton-line.s { width: 50%; }
    .ep-skeleton-line.m { width: 75%; }
    .ep-skeleton-line.l { width: 95%; }

    .ep-footer {
        padding: 0.45rem 1rem;
        background: #f9fafb;
        border-top: 1px solid #f0f0f0;
        font-size: 0.7rem;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    /* Vùng nội dung cho phép bôi đen */
    .selectable-content { user-select: text; cursor: text; }

    /* ===== AI Đọc & Giải Thích panel ===== */
    #btn-ai-read {
        background: linear-gradient(135deg, #059669, #0d9488);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 0.55rem 1.2rem;
        font-size: 0.88rem;
        font-weight: 600;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 2px 8px rgba(5,150,105,0.35);
        margin-left: 0.75rem;
    }
    #btn-ai-read:hover   { opacity: 0.92; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(5,150,105,0.45); }
    #btn-ai-read:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

    .ai-read-panel {
        display: none;
        background: linear-gradient(135deg, rgba(5,150,105,0.05) 0%, rgba(13,148,136,0.07) 100%);
        border: 1px solid rgba(5,150,105,0.2);
        border-radius: 16px;
        padding: 1.5rem;
        margin: 1.5rem 0;
        animation: slideDown 0.35s ease;
    }
    .ai-read-panel.visible { display: block; }

    .ai-read-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1rem;
    }
    .ai-read-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #047857;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .ai-read-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        background: linear-gradient(135deg, #059669, #0d9488);
        color: #fff;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.2rem 0.6rem;
        border-radius: 20px;
    }

    .ai-read-gist {
        background: rgba(5,150,105,0.08);
        border-left: 3px solid #059669;
        border-radius: 0 8px 8px 0;
        padding: 0.55rem 1rem;
        font-size: 0.9rem;
        color: #064e3b;
        font-weight: 500;
        margin-bottom: 1.2rem;
        line-height: 1.6;
    }

    .section-card {
        background: #fff;
        border: 1px solid rgba(5,150,105,0.15);
        border-radius: 12px;
        margin-bottom: 0.85rem;
        overflow: hidden;
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 0.35s ease, transform 0.35s ease;
    }
    .section-card.show { opacity: 1; transform: translateY(0); }

    .section-card-header {
        background: linear-gradient(90deg, rgba(5,150,105,0.08), rgba(13,148,136,0.05));
        padding: 0.65rem 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        user-select: none;
    }
    .section-card-title {
        font-size: 0.88rem;
        font-weight: 700;
        color: #047857;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .section-card-toggle {
        font-size: 0.75rem;
        color: #6b7280;
        transition: transform 0.2s;
    }
    .section-card-toggle.open { transform: rotate(180deg); }

    .section-card-body { padding: 0.85rem 1rem; }

    .section-original {
        background: #f9fafb;
        border-left: 2px solid #d1d5db;
        border-radius: 0 6px 6px 0;
        padding: 0.35rem 0.7rem;
        font-size: 0.78rem;
        color: #6b7280;
        font-style: italic;
        margin-bottom: 0.65rem;
        line-height: 1.55;
    }
    .section-explain {
        font-size: 0.92rem;
        color: #1f2937;
        line-height: 1.7;
        margin-bottom: 0.5rem;
    }
    .section-action {
        display: flex;
        align-items: flex-start;
        gap: 0.4rem;
        background: #fef3c7;
        border: 1px solid #fde68a;
        border-radius: 8px;
        padding: 0.4rem 0.7rem;
        font-size: 0.82rem;
        color: #92400e;
        margin-top: 0.5rem;
    }

    .ai-read-footer {
        margin-top: 0.75rem;
        padding-top: 0.65rem;
        border-top: 1px solid rgba(5,150,105,0.15);
        font-size: 0.75rem;
        color: #9ca3af;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    /* Skeleton cho read panel */
    #ai-read-skeleton { display: none; }
    #ai-read-skeleton.visible { display: block; }
    .ai-read-skeleton-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 0.85rem 1rem;
        margin-bottom: 0.85rem;
    }
</style>

<div class="section-block fade-in-up">
    <div class="mb-4">
        <a href="/Policy" class="btn btn-secondary" style="font-size: 0.85rem;"><i class="bi bi-arrow-left me-1"></i> Quay lại danh sách</a>
    </div>
    
    <div class="news-tag @Model.TagClass mb-3">@Model.Tag</div>
    <h1 class="fw-bold mb-3" style="font-family: var(--font-display); font-size: 2rem; color: var(--gray-800);">@Model.Title</h1>
    
    <div class="news-meta mb-3 pb-3 border-bottom" style="font-size: 0.85rem; color: var(--gray-400);">
        <span class="me-3"><i class="bi bi-building"></i> @Model.IssuingUnit</span>
        <span><i class="bi bi-calendar3"></i> @Model.PublishedDate.ToString("dd/MM/yyyy HH:mm")</span>
    </div>

    @* ===== NÚT AI TÓM TẮT ===== *@
    <div class="mb-4" id="ai-btn-wrapper">
        <div style="display:flex; align-items:center; flex-wrap:wrap; gap:0.5rem;">
            <button id="btn-ai-summarize" onclick="requestAiSummary()">
                🤖 Tóm tắt bằng AI
            </button>
            <button id="btn-ai-read" onclick="requestAiRead()">
                📖 AI Đọc &amp; Giải Thích
            </button>
        </div>
        <div style="margin-top: 0.5rem; font-size: 0.78rem; color: var(--gray-400);">
            <span>🤖 Tóm tắt nhanh · 📖 Đọc hiểu từng phần chi tiết · ✨ Bôi đen đoạn bất kỳ để AI giải thích ngay</span>
        </div>
    </div>

    @* ===== SKELETON LOADING ===== *@
    <div class="ai-skeleton" id="ai-skeleton">
        <div class="skeleton-line short" style="height:12px; margin-bottom:16px;"></div>
        <div class="skeleton-line long"></div>
        <div class="skeleton-line medium"></div>
        <div class="skeleton-line long"></div>
        <div class="skeleton-line short" style="margin-top:12px;"></div>
        <div class="skeleton-line medium"></div>
        <div class="skeleton-line long"></div>
    </div>

    @* ===== ERROR TOAST ===== *@
    <div class="ai-error-toast" id="ai-error-toast">
        <i class="bi bi-exclamation-circle-fill"></i>
        <span id="ai-error-text">Không thể tóm tắt lúc này. Vui lòng thử lại sau.</span>
    </div>

    @* ===== AI SUMMARY PANEL ===== *@
    <div class="ai-summary-panel" id="ai-summary-panel">
        <div class="ai-panel-header">
            <div class="ai-panel-title">
                <span class="ai-badge">✨ Gemini AI</span>
                Phân tích thông minh
            </div>
            <button class="ai-close-btn" onclick="closeAiPanel()" title="Đóng">✕</button>
        </div>

        <div class="ai-section">
            <div class="ai-section-label">📌 Tóm tắt</div>
            <div class="ai-section-text" id="ai-short-summary"></div>
        </div>

        <div class="ai-section">
            <div class="ai-section-label">📋 Các điểm chính</div>
            <ul class="ai-bullet-list" id="ai-bullet-list"></ul>
        </div>

        <div class="ai-section">
            <div class="ai-section-label">💡 Ví dụ thực tế</div>
            <div class="ai-example-box" id="ai-example"></div>
        </div>

        <div class="ai-footer">
            <i class="bi bi-lightning-charge-fill" style="color:#f59e0b;"></i>
            <span>Tóm tắt bởi Gemini AI</span>
            <span>•</span>
            <span id="ai-generated-at"></span>
            <span id="ai-cache-badge" style="display:none; background:#e0e7ff; color:#4338ca; font-size:0.68rem; padding:0.1rem 0.45rem; border-radius:20px; font-weight:600; margin-left:0.3rem;">Từ cache</span>
        </div>
    </div>

    @* ===== AI ĐỌC & GIẢI THÍCH — SKELETON ===== *@
    <div id="ai-read-skeleton">
        <div class="ai-read-skeleton-card">
            <div class="skeleton-line short" style="height:12px; margin-bottom:12px;"></div>
            <div class="skeleton-line long"></div>
            <div class="skeleton-line medium"></div>
        </div>
        <div class="ai-read-skeleton-card">
            <div class="skeleton-line short" style="height:12px; margin-bottom:12px;"></div>
            <div class="skeleton-line long"></div>
            <div class="skeleton-line medium"></div>
            <div class="skeleton-line long"></div>
        </div>
        <div class="ai-read-skeleton-card">
            <div class="skeleton-line short" style="height:12px; margin-bottom:12px;"></div>
            <div class="skeleton-line medium"></div>
            <div class="skeleton-line long"></div>
        </div>
    </div>

    @* ===== AI ĐỌC & GIẢI THÍCH — PANEL KẾT QUẢ ===== *@
    <div class="ai-read-panel" id="ai-read-panel">
        <div class="ai-read-header">
            <div class="ai-read-title">
                <span class="ai-read-badge">📖 Gemini AI</span>
                Đọc Hiểu Từng Phần
            </div>
            <button class="ai-close-btn" onclick="closeReadPanel()" title="Đóng">✕</button>
        </div>
        <div class="ai-read-gist" id="ai-read-gist"></div>
        <div id="ai-read-sections"></div>
        <div class="ai-read-footer">
            <i class="bi bi-book-fill" style="color:#059669;"></i>
            <span>Phân tích bởi</span>
            <span id="ai-read-model">Gemini AI</span>
        </div>
    </div>

    <div class="news-content text-secondary selectable-content" id="policy-content" style="font-size: 1.05rem; line-height: 1.8;">
        <p class="lead text-dark fw-semibold mb-4" style="font-size: 1.15rem; border-left: 4px solid #3b82f6; padding-left: 1rem; font-style: italic;">@Model.Excerpt</p>
        
        @Html.Raw(Model.Content)
    </div>
</div>

@* ===== FLOATING SELECTION BUTTON ===== *@
<button id="ai-selection-btn" title="AI giải thích đoạn này">
    ✨ Giải thích
</button>

@* ===== EXPLAIN POPOVER ===== *@
<div id="ai-explain-popover">
    <div class="ep-header">
        <div class="ep-header-title">
            <span>🤖</span>
            <span>AI Giải Thích</span>
            <span style="background:rgba(255,255,255,0.25); font-size:0.65rem; padding:0.1rem 0.4rem; border-radius:10px;">Gemini</span>
        </div>
        <button class="ep-close" id="ep-close-btn" title="Đóng">×</button>
    </div>
    <div class="ep-body" id="ep-body">
        <!-- Content injected by JS -->
    </div>
    <div class="ep-footer">
        <i class="bi bi-lightning-charge-fill" style="color:#f59e0b;"></i>
        <span id="ep-model">Gemini AI</span>
        <span>• AI có thể mắc lỗi</span>
    </div>
</div>

<script>
(function () {
    const POLICY_ID  = @Model.Id;
    const SESSION_KEY = 'ai_summary_policy_' + POLICY_ID;
    const TOKEN = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    // ============================================================
    // Phần 1 — KHÔI PHỤC TÓM TẮt TÒAN BỘ (logic cũ)
    // ============================================================
    const cached = sessionStorage.getItem(SESSION_KEY);
    if (cached) {
        try { renderSummary(JSON.parse(cached)); } catch (_) {}
    }

    window.requestAiSummary = async function () {
        const btn       = document.getElementById('btn-ai-summarize');
        const skeleton  = document.getElementById('ai-skeleton');
        const errorToast = document.getElementById('ai-error-toast');

        btn.disabled = true;
        btn.textContent = '⏳ Đang tóm tắt...';
        errorToast.classList.remove('visible');
        skeleton.classList.add('visible');

        try {
            const resp = await fetch('/Policy/Summarize/' + POLICY_ID, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': TOKEN || ''
                }
            });
            const data = await resp.json();
            skeleton.classList.remove('visible');

            if (data.success) {
                sessionStorage.setItem(SESSION_KEY, JSON.stringify(data));
                renderSummary(data);
            } else {
                showSummaryError(data.error || 'Không thể tóm tắt lúc này.');
                btn.disabled = false;
                btn.innerHTML = '🤖 Thử lại';
            }
        } catch (err) {
            skeleton.classList.remove('visible');
            showSummaryError('Lỗi kết nối. Vui lòng kiểm tra mạng.');
            btn.disabled = false;
            btn.innerHTML = '🤖 Thử lại';
        }
    };

    function renderSummary(data) {
        document.getElementById('ai-short-summary').textContent = data.shortSummary || '';
        const bulletList = document.getElementById('ai-bullet-list');
        bulletList.innerHTML = '';
        (data.bulletPoints || []).forEach(function (bp) {
            const li = document.createElement('li');
            li.textContent = bp;
            bulletList.appendChild(li);
        });
        document.getElementById('ai-example').textContent = data.realWorldExample || '';
        document.getElementById('ai-generated-at').textContent = data.generatedAt || '';
        const cacheBadge = document.getElementById('ai-cache-badge');
        cacheBadge.style.display = data.fromCache ? 'inline' : 'none';
        document.getElementById('ai-summary-panel').classList.add('visible');
        document.getElementById('ai-btn-wrapper').style.display = 'none';
        document.getElementById('ai-error-toast').classList.remove('visible');
    }

    window.closeAiPanel = function () {
        document.getElementById('ai-summary-panel').classList.remove('visible');
        const wrapper = document.getElementById('ai-btn-wrapper');
        wrapper.style.display = '';
        const btn = document.getElementById('btn-ai-summarize');
        btn.disabled = false;
        btn.innerHTML = '🤖 Tóm tắt bằng AI';
    };

    function showSummaryError(msg) {
        const toast = document.getElementById('ai-error-toast');
        document.getElementById('ai-error-text').textContent = msg;
        toast.classList.add('visible');
    }

    // ============================================================
    // Phần 2 — GIẢI THÍCH ĐOẠN BÔI ĐEN (logic mới)
    // ============================================================
    const selBtn     = document.getElementById('ai-selection-btn');
    const popover    = document.getElementById('ai-explain-popover');
    const epBody     = document.getElementById('ep-body');
    const epModel    = document.getElementById('ep-model');
    const epCloseBtn = document.getElementById('ep-close-btn');
    const content    = document.getElementById('policy-content');

    let selectionTimeout = null;
    let currentSelected  = '';

    // Hiện floating button khi bôi đen trong vùng nội dung
    document.addEventListener('mouseup', function (e) {
        clearTimeout(selectionTimeout);
        selectionTimeout = setTimeout(function () {
            const sel  = window.getSelection();
            const text = sel ? sel.toString().trim() : '';

            // Kiểm tra selection có liên quan đến #policy-content
            // Dùng 3 điều kiện OR để cover mọi hướng kéo chuột:
            // 1. anchorNode nằm trong content (kéo từ trái sang phải)
            // 2. focusNode nằm trong content  (kéo từ phải sang trái)
            // 3. range intersectsNode content  (kéo từ ngoài vào trong)
            let isInContent = false;
            if (text.length >= 5 && content && sel && sel.rangeCount > 0) {
                const range = sel.getRangeAt(0);
                isInContent = content.contains(sel.anchorNode)
                           || content.contains(sel.focusNode)
                           || range.intersectsNode(content);
            }

            if (isInContent) {
                currentSelected = text;
                positionSelectionBtn(e);
            } else {
                // Nếu click ra ngoài popover thì ẩn cả
                if (!popover.contains(e.target) && !selBtn.contains(e.target)) {
                    hideSelectionUI();
                }
            }
        }, 160);
    });

    // Ẩn khi bắt đầu drag mới
    document.addEventListener('mousedown', function (e) {
        // Dùng .contains() thay vì === để cover cả click vào icon/text bên trong nút
        if (!popover.contains(e.target) && !selBtn.contains(e.target)) {
            selBtn.classList.remove('visible');
        }
    });

    function positionSelectionBtn(e) {
        const margin = 10;
        let x = e.clientX - 40;
        let y = e.clientY - 48;
        // Giữ trong viewport
        x = Math.max(margin, Math.min(x, window.innerWidth  - 130 - margin));
        y = Math.max(margin, Math.min(y, window.innerHeight - 40  - margin));
        selBtn.style.left = x + 'px';
        selBtn.style.top  = y + 'px';
        selBtn.classList.add('visible');
    }

    // Click nút “Giải thích”
    selBtn.addEventListener('click', async function () {
        if (!currentSelected) return;
        selBtn.classList.remove('visible');
        openPopoverLoading(currentSelected);

        try {
            const resp = await fetch('/Policy/ExplainSelection', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': TOKEN || ''
                },
                body: JSON.stringify({ policyId: POLICY_ID, selectedText: currentSelected })
            });
            const data = await resp.json();

            if (data.success) {
                renderExplanation(currentSelected, data);
            } else {
                renderExplainError(data.error || 'Không thể giải thích lúc này.');
            }
        } catch (_) {
            renderExplainError('Lỗi kết nối. Vui lòng thử lại.');
        }
    });

    epCloseBtn.addEventListener('click', hideSelectionUI);

    function openPopoverLoading(selectedText) {
        // Hiện popover giữa màn hình
        positionPopoverCenter();
        popover.classList.add('visible');

        // Skeleton + quote
        const shortQuote = selectedText.length > 100
            ? selectedText.slice(0, 100) + '...'
            : selectedText;

        epBody.innerHTML =
            '<div class="ep-quote">\u201C' + escHtml(shortQuote) + '\u201D</div>' +
            '<div class="ep-skeleton-line l"></div>' +
            '<div class="ep-skeleton-line m"></div>' +
            '<div class="ep-skeleton-line s"></div>' +
            '<div style="margin-top:10px;"></div>' +
            '<div class="ep-skeleton-line m"></div>' +
            '<div class="ep-skeleton-line l"></div>';
    }

    function renderExplanation(selectedText, data) {
        const shortQuote = selectedText.length > 120
            ? selectedText.slice(0, 120) + '...'
            : selectedText;

        let keyTermHtml = '';
        if (data.keyTerm) {
            keyTermHtml =
                '<div class="ep-key-term">' +
                '<span>\uD83D\uDCDA</span>' +
                '<span><b>Thuật ngữ:</b> ' + escHtml(data.keyTerm) + '</span>' +
                '</div>';
        }

        epBody.innerHTML =
            '<div class="ep-quote">\u201C' + escHtml(shortQuote) + '\u201D</div>' +
            '<div class="ep-label">\uD83D\uDCA1 Ý nghĩa</div>' +
            '<div class="ep-text">' + escHtml(data.simpleExplanation) + '</div>' +
            keyTermHtml +
            '<div class="ep-practical">' + escHtml(data.practicalMeaning) + '</div>';

        epModel.textContent = data.modelUsed || 'Gemini AI';
    }

    function renderExplainError(msg) {
        epBody.innerHTML =
            '<div style="color:#b91c1c; font-size:0.88rem; display:flex; gap:0.5rem; align-items:center;">' +
            '<i class="bi bi-exclamation-circle-fill"></i> ' + escHtml(msg) +
            '</div>';
    }

    function positionPopoverCenter() {
        // Popover xuất hiện gần giữa cửa sổ, hơi lệch trên
        popover.style.left = '50%';
        popover.style.top  = '50%';
        popover.style.transform = 'translate(-50%, -50%)';
    }

    function hideSelectionUI() {
        selBtn.classList.remove('visible');
        popover.classList.remove('visible');
        currentSelected = '';
    }

    // Đóng popover khi click ra ngoài
    document.addEventListener('click', function (e) {
        if (popover.classList.contains('visible') &&
            !popover.contains(e.target) &&
            e.target !== selBtn) {
            hideSelectionUI();
        }
    });

    function escHtml(str) {
        return (str || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }
})();
</script>

<script>
// ============================================================
// Ph\u1ea7n 3 \u2014 AI \u0110\u1eccC & GI\u1ea2I TH\u00cdCH T\u1eea\u0130NG PH\u1ea6N
// ============================================================
(function () {
    const POLICY_ID   = @Model.Id;
    const READ_KEY    = 'ai_read_policy_' + POLICY_ID;
    const TOKEN       = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

    const btnRead     = document.getElementById('btn-ai-read');
    const skeleton    = document.getElementById('ai-read-skeleton');
    const panel       = document.getElementById('ai-read-panel');
    const gistEl      = document.getElementById('ai-read-gist');
    const sectionsEl  = document.getElementById('ai-read-sections');
    const modelEl     = document.getElementById('ai-read-model');

    // Kh\u00f4i ph\u1ee5c t\u1eeb session cache khi t\u1ea3i trang
    const cached = sessionStorage.getItem(READ_KEY);
    if (cached) {
        try { renderReadResult(JSON.parse(cached)); } catch (_) {}
    }

    window.requestAiRead = async function () {
        if (btnRead.disabled) return;

        btnRead.disabled = true;
        btnRead.innerHTML = '\u23f3 \u0110ang ph\u00e2n t\u00edch...';
        skeleton.classList.add('visible');
        panel.classList.remove('visible');

        try {
            const resp = await fetch('/Policy/ReadAndExplain/' + POLICY_ID, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': TOKEN || ''
                }
            });
            const data = await resp.json();
            skeleton.classList.remove('visible');

            if (data.success) {
                sessionStorage.setItem(READ_KEY, JSON.stringify(data));
                renderReadResult(data);
            } else {
                showReadError(data.error || 'Kh\u00f4ng th\u1ec3 ph\u00e2n t\u00edch l\u00fac n\u00e0y.');
                btnRead.disabled = false;
                btnRead.innerHTML = '\ud83d\udcd6 AI \u0110\u1ecdc & Gi\u1ea3i Th\u00edch';
            }
        } catch (_) {
            skeleton.classList.remove('visible');
            showReadError('L\u1ed7i k\u1ebft n\u1ed1i. Vui l\u00f2ng ki\u1ec3m tra m\u1ea1ng.');
            btnRead.disabled = false;
            btnRead.innerHTML = '\ud83d\udcd6 AI \u0110\u1ecdc & Gi\u1ea3i Th\u00edch';
        }
    };

    function renderReadResult(data) {
        // Overall gist
        gistEl.textContent = data.overallGist || '';
        modelEl.textContent = data.modelUsed || 'Gemini AI';

        // X\u00e2y d\u1ef1ng section cards
        sectionsEl.innerHTML = '';
        var icons = ['\ud83d\udccc', '\ud83d\udcc4', '\u2696\ufe0f', '\ud83d\udcc5', '\ud83d\udce2'];
        (data.sections || []).forEach(function (sec, idx) {
            var card = document.createElement('div');
            card.className = 'section-card';
            card.id = 'sec-card-' + idx;

            var actionHtml = '';
            if (sec.actionRequired) {
                actionHtml =
                    '<div class="section-action">' +
                    '<span>\ud83d\udc64</span>' +
                    '<span>' + escHtml(sec.actionRequired) + '</span>' +
                    '</div>';
            }

            card.innerHTML =
                '<div class="section-card-header" onclick="toggleSection(' + idx + ')">' +
                '<div class="section-card-title">' +
                '<span>' + (icons[idx % icons.length]) + '</span>' +
                '<span>' + escHtml(sec.title) + '</span>' +
                '</div>' +
                '<span class="section-card-toggle open" id="sec-toggle-' + idx + '">\u25bc</span>' +
                '</div>' +
                '<div class="section-card-body" id="sec-body-' + idx + '">' +
                '<div class="section-original">\u201C' + escHtml(sec.originalText) + '\u201D</div>' +
                '<div class="section-explain">' + escHtml(sec.simpleExplanation) + '</div>' +
                actionHtml +
                '</div>';

            sectionsEl.appendChild(card);

            // Stagger animation: m\u1ed7i card hi\u1ec7n l\u1ea7n l\u01b0\u1ee3t
            setTimeout(function () {
                card.classList.add('show');
            }, 80 + idx * 120);
        });

        panel.classList.add('visible');
        // \u1ea8n wrapper n\u00fat ch\u1ec9 khi \u0111\u00f3ng panel m\u1edbi hi\u1ec7n l\u1ea1i \u2014 gi\u1eef n\u00fat lu\u00f4n visible
        btnRead.disabled = false;
        btnRead.innerHTML = '\ud83d\udcd6 AI \u0110\u1ecdc & Gi\u1ea3i Th\u00edch';
    }

    // Toggle collapse t\u1eebng section
    window.toggleSection = function (idx) {
        var body   = document.getElementById('sec-body-' + idx);
        var toggle = document.getElementById('sec-toggle-' + idx);
        if (!body) return;
        if (body.style.display === 'none') {
            body.style.display = '';
            toggle.classList.add('open');
        } else {
            body.style.display = 'none';
            toggle.classList.remove('open');
        }
    };

    window.closeReadPanel = function () {
        panel.classList.remove('visible');
        btnRead.disabled = false;
        btnRead.innerHTML = '\ud83d\udcd6 AI \u0110\u1ecdc & Gi\u1ea3i Th\u00edch';
    };

    function showReadError(msg) {
        skeleton.classList.remove('visible');
        // Hi\u1ec7n l\u1ed7i t\u1ea1m th\u1eddi trong gist box
        gistEl.textContent = '\u26a0\ufe0f ' + msg;
        panel.classList.add('visible');
        sectionsEl.innerHTML = '';
    }

    function escHtml(str) {
        return (str || '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }
})();
</script>
