@model IEnumerable<CivicConnect.Web.Models.Entities.Policy>
@{
    ViewData["Title"] = "Chính sách & Tin tức";
    var laws = Model.Where(p => p.Tag == "Nghị định" || p.Tag == "Thông tư" || p.Tag == "Chính sách");
    var newsAndNotices = Model.Where(p => p.Tag == "Thông báo" || p.Tag == "Tin tức" || p.Tag == "tag-news" || p.TagClass == "tag-news");
}

<style>
    .page-container {
        display: grid;
        grid-template-columns: 1.8fr 1.2fr;
        gap: 30px;
        margin-top: 20px;
    }
    @@media (max-width: 991px) {
        .page-container {
            grid-template-columns: 1fr;
        }
    }
    .main-laws-panel {
        background: var(--card-bg, #ffffff);
        border: 1px solid var(--border-color, #e5e7eb);
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
    .sidebar-news-panel {
        background: var(--card-bg, #ffffff);
        border: 1px solid var(--border-color, #e5e7eb);
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        align-self: start;
    }
    .panel-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--gray-800, #1f2937);
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
        padding-bottom: 12px;
        border-bottom: 2px solid #e5e7eb;
    }
    .law-card {
        border-bottom: 1px solid var(--border-color, #e5e7eb);
        padding-bottom: 20px;
        margin-bottom: 20px;
        transition: all 0.2s ease;
        display: block;
        text-decoration: none;
    }
    .law-card:last-child {
        border-bottom: none;
        padding-bottom: 0;
        margin-bottom: 0;
    }
    .law-card:hover {
        transform: translateX(4px);
    }
    .law-card:hover .law-title {
        color: #0d6efd;
    }
    .law-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--gray-800, #1f2937);
        margin-bottom: 8px;
        line-height: 1.4;
        transition: color 0.15s ease;
    }
    .law-excerpt {
        font-size: 0.925rem;
        color: var(--text-muted, #4b5563);
        margin-bottom: 12px;
        line-height: 1.5;
    }
    .law-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        font-size: 0.8rem;
        color: #6b7280;
        align-items: center;
    }
    .law-meta span {
        display: flex;
        align-items: center;
        gap: 4px;
    }
    .gov-badge {
        background-color: #d1e7dd;
        color: #0f5132;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 4px 8px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border: 1px solid #a3cfbb;
    }
    .side-news-card {
        padding: 16px 0;
        border-bottom: 1px dashed var(--border-color, #e5e7eb);
        display: block;
        text-decoration: none;
        transition: all 0.15s ease;
    }
    .side-news-card:first-child {
        padding-top: 0;
    }
    .side-news-card:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }
    .side-news-card:hover {
        padding-left: 4px;
    }
    .side-news-card:hover .side-news-title {
        color: #dc3545;
    }
    .side-news-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--gray-800, #1f2937);
        line-height: 1.4;
        margin-bottom: 8px;
        transition: color 0.15s ease;
    }
    .side-news-excerpt {
        font-size: 0.85rem;
        color: #4b5563;
        margin-bottom: 8px;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .side-news-meta {
        font-size: 0.75rem;
        color: #6b7280;
        display: flex;
        gap: 12px;
        align-items: center;
    }
    .tag-badge {
        font-size: 0.7rem;
        padding: 2px 6px;
        border-radius: 4px;
        font-weight: bold;
        text-transform: uppercase;
    }
    .tag-badge.tag-notice {
        background-color: #fff3cd;
        color: #664d03;
        border: 1px solid #ffecb5;
    }
    .tag-badge.tag-news {
        background-color: #cff4fc;
        color: #087990;
        border: 1px solid #b6effb;
    }
</style>

<div class="section-block fade-in-up">
    <div class="section-header">
        <div class="section-title-wrap">
            <span class="section-icon bg-blue"><i class="bi bi-newspaper"></i></span>
            <h2 class="section-title">Chính Sách Pháp Luật & Tin Tức Hàng Ngày</h2>
        </div>
    </div>

    <div class="page-container">
        <!-- Cột Trái: Văn bản Pháp luật & Chính sách -->
        <div class="main-laws-panel">
            <h3 class="panel-title text-primary">
                <i class="bi bi-shield-check text-success"></i> Văn bản Pháp luật & Chính sách
            </h3>
            
            @if (!laws.Any())
            {
                <div class="text-center py-5 text-secondary">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    <span>Chưa có văn bản pháp luật nào được đăng tải.</span>
                </div>
            }
            else
            {
                <div class="laws-list">
                    @foreach (var law in laws)
                    {
                        var detailUrl = law.Id == 0 
                            ? Url.Action("Details", "Policy", new { id = 0, url = law.SourceUrl }) 
                            : Url.Action("Details", "Policy", new { id = law.Id });
                        <a href="@detailUrl" class="law-card">
                            <div class="law-title">@law.Title</div>
                            <p class="law-excerpt">@law.Excerpt</p>
                            <div class="law-meta">
                                <span class="gov-badge">
                                    <i class="bi bi-check-circle-fill"></i> Minh bạch từ nhà nước
                                </span>
                                <span><i class="bi bi-building"></i> @law.IssuingUnit</span>
                                <span><i class="bi bi-hash"></i> @(law.DocumentNumber ?? "Đang cập nhật")</span>
                                <span><i class="bi bi-calendar3"></i> @law.PublishedDate.ToString("dd/MM/yyyy")</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>

        <!-- Cột Phải: Tin tức & Thông báo đô thị hàng ngày -->
        <div class="sidebar-news-panel">
            <h3 class="panel-title text-danger">
                <i class="bi bi-lightning-fill text-warning"></i> Tin tức & Thông báo đô thị
            </h3>

            @if (!newsAndNotices.Any())
            {
                <div class="text-center py-5 text-secondary">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    <span>Chưa có tin tức hoạt động nào mới.</span>
                </div>
            }
            else
            {
                <div class="news-list">
                    @foreach (var item in newsAndNotices)
                    {
                        var detailUrl = item.Id == 0 
                            ? Url.Action("Details", "Policy", new { id = 0, url = item.SourceUrl }) 
                            : Url.Action("Details", "Policy", new { id = item.Id });
                        <a href="@detailUrl" class="side-news-card">
                            <div class="side-news-title">@item.Title</div>
                            <p class="side-news-excerpt">@item.Excerpt</p>
                            <div class="side-news-meta">
                                <span class="tag-badge @(item.Tag == "Thông báo" ? "tag-notice" : "tag-news")">
                                    @item.Tag
                                </span>
                                <span><i class="bi bi-clock"></i> @item.PublishedDate.ToString("dd/MM/yyyy")</span>
                                <span><i class="bi bi-eye"></i> Xem chi tiết</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>
