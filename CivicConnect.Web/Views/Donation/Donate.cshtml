@model CivicConnect.Core.Entities.DonationCategory
@{
    ViewData["Title"] = "Quyên góp - " + Model.Name;
}

<style>
    .donate-container {
        max-width: 650px;
        margin: 0 auto;
    }
    .fund-header-card {
        background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
        border: 1px solid #ddd6fe;
        border-radius: 16px;
        padding: 24px;
        margin-bottom: 24px;
    }
    .form-card {
        background: var(--card-bg, #ffffff);
        border: 1px solid var(--border-color, #e5e7eb);
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }
    .preset-amount-btn {
        border: 1px solid var(--border-color, #e5e7eb);
        background-color: var(--card-bg, #ffffff);
        color: var(--text-dark, #374151);
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.2s ease;
        text-align: center;
        cursor: pointer;
    }
    .preset-amount-btn:hover {
        border-color: #8b5cf6;
        color: #7c3aed;
        background-color: #f5f3ff;
    }
    .preset-amount-btn.active {
        background-color: #7c3aed;
        color: white;
        border-color: #7c3aed;
        box-shadow: 0 4px 10px rgba(124, 58, 237, 0.25);
    }
    .payment-methods-container {
        display: flex;
        gap: 16px;
        margin-bottom: 24px;
    }
    .payment-method-card {
        flex: 1;
        border: 2px solid var(--border-color, #e5e7eb);
        border-radius: 12px;
        padding: 16px;
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
        text-align: center;
        background: var(--card-bg, #ffffff);
    }
    .payment-method-card:hover {
        border-color: #d82d8b;
        background-color: #fff0f6;
    }
    .payment-method-card.active {
        border-color: #a50064;
        background-color: #fff0f6;
        box-shadow: 0 4px 12px rgba(165, 0, 100, 0.15);
    }
    .payment-method-card input[type="radio"] {
        display: none;
    }
    .payment-method-card .method-icon {
        font-size: 2rem;
        color: #a50064;
        margin-bottom: 8px;
        display: block;
    }
    .payment-method-card .method-title {
        font-weight: bold;
        font-size: 0.95rem;
        color: var(--text-dark, #374151);
        display: block;
        margin-bottom: 4px;
    }
    .payment-method-card .method-desc {
        font-size: 0.8rem;
        color: #6b7280;
        display: block;
    }
</style>

<div class="donate-container">
    <div class="mb-4">
        <a asp-action="Index" class="text-secondary text-decoration-none fw-semibold">
            <i class="bi bi-arrow-left"></i> Quay lại Danh sách Quỹ
        </a>
    </div>

    <!-- Fund Info Card -->
    <div class="fund-header-card">
        <span class="badge bg-purple-subtle text-purple mb-2 px-3 py-1 rounded-pill" style="background-color: #ddd6fe; color: #6d28d9;">Đóng góp dự án</span>
        <h2 class="fw-bold text-dark mb-2" style="font-size: 1.5rem;">@Model.Name</h2>
        <p class="text-secondary mb-0 small">@Model.Description</p>
    </div>

    <!-- Donation Form -->
    <div class="form-card">
        <h4 class="fw-bold text-dark mb-4 pb-2 border-bottom"><i class="bi bi-wallet2 text-success"></i> Nhập Thông Tin Đóng Góp</h4>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" role="alert">
                <div asp-validation-summary="All" class="text-danger small"></div>
            </div>
        }

        <form asp-action="SubmitDonation" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="CategoryId" value="@Model.Id" />

            <!-- Preset Amounts -->
            <div class="mb-4">
                <label class="form-label fw-bold text-dark mb-2">Chọn số tiền đóng góp nhanh</label>
                <div class="row g-2">
                    <div class="col-4">
                        <div class="preset-amount-btn" onclick="setAmount(50000, this)">50.000 đ</div>
                    </div>
                    <div class="col-4">
                        <div class="preset-amount-btn" onclick="setAmount(100000, this)">100.000 đ</div>
                    </div>
                    <div class="col-4">
                        <div class="preset-amount-btn" onclick="setAmount(200000, this)">200.000 đ</div>
                    </div>
                    <div class="col-4">
                        <div class="preset-amount-btn" onclick="setAmount(500000, this)">500.000 đ</div>
                    </div>
                    <div class="col-4">
                        <div class="preset-amount-btn" onclick="setAmount(1000000, this)">1.000.000 đ</div>
                    </div>
                    <div class="col-4">
                        <div class="preset-amount-btn" onclick="setAmount(2000000, this)">2.000.000 đ</div>
                    </div>
                </div>
            </div>

            <!-- Custom Amount -->
            <div class="mb-4">
                <label for="AmountInput" class="form-label fw-bold text-dark">Số tiền quyên góp tùy ý (VNĐ)</label>
                <div class="input-group input-group-lg">
                    <input type="number" step="1000" min="1000" id="AmountInput" name="Amount" class="form-control fw-bold text-success" style="font-size: 1.5rem;" placeholder="Nhập số tiền..." required />
                    <span class="input-group-text fw-bold">VNĐ</span>
                </div>
            </div>

            <div class="row">
                <!-- Donor Name -->
                <div class="col-md-6 mb-3">
                    <label for="DonorName" class="form-label fw-semibold text-dark">Tên người gửi (Công khai)</label>
                    <input type="text" id="DonorName" name="DonorName" class="form-control" placeholder="Nhập tên hiển thị..." value="@(User.Identity?.IsAuthenticated == true ? User.Identity.Name : "")" />
                    <div class="form-text small">Để trống sẽ tự động hiển thị là "Nhà hảo tâm"</div>
                </div>

                <!-- Email -->
                <div class="col-md-6 mb-3">
                    <label for="Email" class="form-label fw-semibold text-dark">Địa chỉ Email (Nếu có)</label>
                    <input type="email" id="Email" name="Email" class="form-control" placeholder="example@gmail.com" />
                </div>
            </div>

            <!-- Message -->
            <div class="mb-3">
                <label for="OrderInfo" class="form-label fw-semibold text-dark">Lời nhắn gửi (Tùy chọn)</label>
                <textarea id="OrderInfo" name="OrderInfo" class="form-control" rows="2" placeholder="Gửi lời chúc, lời nhắn động viên tới địa phương..."></textarea>
            </div>

            <!-- Chọn phương thức thanh toán -->
            <div class="mb-4">
                <label class="form-label fw-bold text-dark mb-2">Chọn phương thức thanh toán qua MoMo</label>
                <div class="payment-methods-container">
                    <div class="payment-method-card active" onclick="selectPaymentMethod('captureWallet', this)">
                        <input type="radio" id="methodWallet" name="PaymentMethod" value="captureWallet" checked />
                        <span class="method-icon"><i class="bi bi-qr-code-scan"></i></span>
                        <span class="method-title">Ví MoMo (Mã QR)</span>
                        <span class="method-desc">Sử dụng ứng dụng MoMo để quét mã QR thanh toán</span>
                    </div>
                    <div class="payment-method-card" onclick="selectPaymentMethod('payWithATM', this)">
                        <input type="radio" id="methodATM" name="PaymentMethod" value="payWithATM" />
                        <span class="method-icon"><i class="bi bi-credit-card-2-front-fill"></i></span>
                        <span class="method-title">Thẻ ATM nội địa</span>
                        <span class="method-desc">Thanh toán qua thẻ ATM của 40+ ngân hàng Việt Nam</span>
                    </div>
                </div>
            </div>

            <!-- Anonymous Checkbox -->
            <div class="mb-4">
                <div class="form-check form-switch p-3 border rounded bg-light d-flex align-items-center justify-content-between">
                    <div>
                        <label class="form-check-label fw-bold text-dark" for="IsAnonymous">Quyên góp ẩn danh</label>
                        <div class="text-secondary small">Nếu bật, tên của bạn sẽ bị ẩn trên Bảng vinh danh công khai.</div>
                    </div>
                    <input class="form-check-input ms-0" type="checkbox" id="IsAnonymous" name="IsAnonymous" value="true">
                </div>
            </div>

            <!-- Note about Sandbox -->
            <div class="alert alert-warning d-flex align-items-start gap-2 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill text-warning fs-5"></i>
                <div class="small">
                    Hệ thống đang chạy chế độ thử nghiệm **MoMo Sandbox**. Bạn sẽ **không bị trừ tiền thật**. 
                </div>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn btn-success w-100 py-3 rounded-pill fw-bold text-uppercase shadow-sm">
                Xác nhận Quyên góp qua MoMo <i class="bi bi-wallet2"></i>
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function setAmount(amount, buttonElement) {
            // Cập nhật input
            document.getElementById('AmountInput').value = amount;

            // Xoá active class của các nút khác
            const buttons = document.querySelectorAll('.preset-amount-btn');
            buttons.forEach(btn => btn.classList.remove('active'));

            // Gán active cho nút hiện tại
            buttonElement.classList.add('active');
        }

        // Lắng nghe thay đổi input tự nhập để gỡ nút active
        document.getElementById('AmountInput').addEventListener('input', function() {
            const buttons = document.querySelectorAll('.preset-amount-btn');
            buttons.forEach(btn => btn.classList.remove('active'));
        });

        function selectPaymentMethod(method, cardElement) {
            // Check the radio input
            if (method === 'captureWallet') {
                document.getElementById('methodWallet').checked = true;
            } else {
                document.getElementById('methodATM').checked = true;
            }

            // Update UI active class
            const cards = document.querySelectorAll('.payment-method-card');
            cards.forEach(card => card.classList.remove('active'));
            cardElement.classList.add('active');
        }
    </script>
}
