@model IEnumerable<CivicConnect.Core.Entities.DonationCategory>
@{
    ViewData["Title"] = "Quỹ Cộng Đồng";
    var recentDonations = ViewBag.RecentDonations as List<CivicConnect.Core.Entities.Donation> ?? new List<CivicConnect.Core.Entities.Donation>();
    var totalAmount = (decimal)ViewBag.TotalAmount;
    var totalCount = (int)ViewBag.TotalCount;
}

<style>
    .donation-hero {
        background: linear-gradient(135deg, rgba(var(--bs-primary-rgb), 0.25) 0%, rgba(var(--bs-primary-rgb), 0.1) 100%);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border-glass);
        border-radius: var(--radius-lg);
        padding: 40px;
        color: var(--text-main);
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
    }
    .donation-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -10%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, rgba(255,255,255,0) 70%);
        border-radius: 50%;
    }
    .stat-badge {
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(10px);
        border: 1px solid var(--border-glass);
        border-radius: var(--radius-md);
        padding: 20px;
        text-align: center;
        transition: transform 0.3s ease;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    .stat-badge:hover {
        transform: translateY(-3px);
        background: rgba(255, 255, 255, 0.7);
    }
    
    .progress-bar-custom {
        height: 8px;
        border-radius: 4px;
        background-color: rgba(255, 255, 255, 0.1);
        overflow: hidden;
        position: relative;
    }
    .progress-fill {
        height: 100%;
        border-radius: 4px;
        background: linear-gradient(90deg, var(--primary-color) 0%, var(--primary-500) 100%);
        transition: width 1s ease-in-out;
    }
    
    .contributor-item {
        display: flex;
        align-items: center;
        padding: 16px;
        border-bottom: 1px dashed var(--border-glass);
        transition: background-color 0.2s ease;
    }
    .contributor-item:last-child {
        border-bottom: none;
    }
    .contributor-item:hover {
        background-color: rgba(255, 255, 255, 0.03);
    }
    .contributor-avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(var(--bs-primary-rgb), 0.15) 0%, rgba(var(--bs-primary-rgb), 0.3) 100%);
        color: var(--primary-color);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.2rem;
        margin-right: 16px;
        flex-shrink: 0;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .contributor-anon {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
    }
    .amount-text {
        font-weight: 700;
        color: var(--accent-500);
        font-size: 1.1rem;
    }
    .heart-pulse {
        animation: pulse 2s infinite;
    }
    @@keyframes pulse {
        0% { transform: scale(1); }
        50% { transform: scale(1.15); }
        100% { transform: scale(1); }
    }
</style>

<div class="container-fluid px-0">
    <!-- Hero Header & Stats -->
    <div class="donation-hero">
        <div class="row align-items-center position-relative" style="z-index: 1;">
            <div class="col-lg-7">
                <h1 class="display-5 fw-bold mb-3 d-flex align-items-center gap-3 text-dark">
                    <i class="bi bi-heart-fill heart-pulse text-danger" style="filter: drop-shadow(0 0 10px rgba(220,53,69,0.2));"></i> 
                    Quỹ Cộng Đồng
                </h1>
                <p class="lead mb-4 text-secondary" style="font-weight: 400; line-height: 1.6;">
                    Chung tay kiến tạo và nâng cấp hạ tầng đô thị. Mỗi đóng góp của bạn đều được quản lý công khai, minh bạch 100% phục vụ trực tiếp cho các dự án địa phương.
                </p>
            </div>
            <div class="col-lg-5">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="stat-badge">
                            <div class="small text-secondary mb-2"><i class="bi bi-wallet2"></i> TỔNG QUYÊN GÓP</div>
                            <h3 class="fw-bold mb-0 text-primary">@totalAmount.ToString("N0") <span style="font-size: 1rem; color: var(--text-main);">đ</span></h3>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="stat-badge">
                            <div class="small text-secondary mb-2"><i class="bi bi-people-fill"></i> LƯỢT HẢO TÂM</div>
                            <h3 class="fw-bold mb-0 text-primary">@totalCount.ToString("N0")</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Funds -->
    <div class="row g-4 mb-5">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-between mb-3 border-bottom border-secondary border-opacity-25 pb-3">
                <h3 class="fw-bold text-white m-0"><i class="bi bi-flag-fill text-primary me-2"></i> Các Quỹ Đang Huy Động</h3>
                <span class="badge bg-primary bg-opacity-25 text-primary border border-primary px-3 py-2 rounded-pill">Đang hoạt động</span>
            </div>
        </div>

        @foreach (var fund in Model)
        {
            var percent = fund.TargetAmount > 0 ? (double)(fund.CurrentAmount / fund.TargetAmount * 100) : 0;
            var displayPercent = percent > 100 ? 100 : percent;

            <div class="col-md-6 col-lg-4">
                <div class="glass-card h-100 p-4 d-flex flex-column justify-content-between transition-hover" style="border-top: 3px solid var(--primary-500);">
                    <div>
                        <h4 class="fw-bold text-white mb-3" style="font-size: 1.2rem; line-height: 1.4;">@fund.Name</h4>
                        <p class="text-secondary" style="font-size: 0.95rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5;">
                            @fund.Description
                        </p>
                    </div>

                    <div class="mt-4 pt-3 border-top border-secondary border-opacity-25">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <span class="text-primary fw-bold" style="font-size: 0.9rem;">@percent.ToString("F1")%</span>
                            <span class="text-muted" style="font-size: 0.8rem;">Mục tiêu: @fund.TargetAmount.ToString("N0") đ</span>
                        </div>
                        
                        <div class="progress-bar-custom mb-3 shadow-inner">
                            <div class="progress-fill" style="width: @displayPercent.ToString("F0")%"></div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <div>
                                <span class="text-secondary d-block" style="font-size: 0.8rem;">Đã huy động</span>
                                <span class="fw-bold text-success" style="font-size: 1.2rem;">@fund.CurrentAmount.ToString("N0") đ</span>
                            </div>
                            <a asp-action="Donate" asp-route-id="@fund.Id" class="btn btn-primary rounded-pill px-4 py-2 fw-semibold shadow-sm">
                                Quyên góp <i class="bi bi-arrow-right-short"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Contributions Board -->
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="glass-card p-4 p-md-5">
                <h3 class="fw-bold text-white mb-4 pb-3 border-bottom border-secondary border-opacity-25 d-flex align-items-center gap-2">
                    <i class="bi bi-bookmark-star-fill text-warning"></i> Bảng Vinh Danh Nhà Hảo Tâm
                </h3>

                @if (recentDonations.Count == 0)
                {
                    <div class="text-center py-5">
                        <i class="bi bi-gift text-muted opacity-50 display-1 mb-3"></i>
                        <p class="text-secondary fs-5">Chưa có lượt quyên góp nào. Hãy là người mở bát đầu tiên!</p>
                    </div>
                }
                else
                {
                    <div class="contributor-list">
                        @foreach (var item in recentDonations)
                        {
                            var initial = item.IsAnonymous ? "?" : (string.IsNullOrEmpty(item.DonorName) ? "H" : item.DonorName.Substring(0, 1).ToUpper());
                            <div class="contributor-item">
                                <div class="contributor-avatar @(item.IsAnonymous ? "contributor-anon" : "")">
                                    @initial
                                </div>
                                <div class="flex-grow-1">
                                    <div class="d-flex flex-wrap justify-content-between align-items-center mb-1 gap-2">
                                        <span class="fw-bold text-white" style="font-size: 1.05rem;">@(item.IsAnonymous ? "Nhà hảo tâm ẩn danh" : item.DonorName)</span>
                                        <span class="amount-text">+@item.Amount.ToString("N0") đ</span>
                                    </div>
                                    <div class="d-flex flex-wrap justify-content-between align-items-center mt-1">
                                        <span class="text-secondary font-italic" style="font-size: 0.9rem;">
                                            @if (!string.IsNullOrEmpty(item.OrderInfo))
                                            {
                                                <i class="bi bi-quote text-muted"></i> @item.OrderInfo
                                            }
                                            else
                                            {
                                                <span>Ủng hộ quỹ cộng đồng</span>
                                            }
                                        </span>
                                        <span class="text-muted" style="font-size: 0.8rem;"><i class="bi bi-clock me-1"></i> @item.CreatedAt.AddHours(7).ToString("dd/MM/yyyy HH:mm")</span>
                                    </div>
                                    <div class="mt-2">
                                        <span class="badge bg-dark border border-secondary border-opacity-50 text-light fw-normal" style="font-size: 0.75rem;">
                                            <i class="bi bi-tag-fill text-primary me-1"></i> @item.DonationCategory?.Name
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
